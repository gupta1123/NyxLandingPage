---
interface Props {
  currentPath?: string;
  variant?: 'default' | 'hero';
}

const { currentPath = '/', variant = 'default' } = Astro.props;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/products', label: 'Products' },
  { href: '/briefly-docs', label: 'Briefly Docs' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' }
];

const isActive = (href: string) => currentPath === href;
---

<header class:list={{ 'site-header': true, 'site-header--hero': variant === 'hero' }}>
  <div class="container">
    <nav class="top-nav" aria-label="Primary">
      <a href="/" class="brand">Nyx Solutions</a>
      <div class="nav-links">
        {navItems.map((item) => (
          <a href={item.href} class:list={{ active: isActive(item.href) }}>{item.label}</a>
        ))}
      </div>

    </nav>
  </div>
</header>
