---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="AI-Powered Photoshoots | Nyx Solution" description="Upload your garment, choose a model, and generate campaign-ready fashion visuals with AI.">
<style>
/* ── EXACT BRIEFLY DOCS TOKENS ── */
:root{
  --rust-50:#fdf8ef;--rust-100:#f5ebda;--rust-200:#e9c9a8;
  --rust-300:#da956a;--rust-400:#c56f45;--rust-500:#a24a2a;
  --rust-600:#85361c;--rust-700:#6b2a14;
  --sand-50:#fff8ed;--sand-100:#f5e8d4;--sand-200:#d8c8b3;
  --ink:#1f1a16;--ink-soft:#5f5148;--ink-muted:#7a5c4c;
  --surface:#fdf8ef;--line:rgba(216,200,179,.78);--line-mid:rgba(196,160,126,.45);
  --green:#2e8c4f;--amber:#c07820;--dark-bg:#2e1f19;
  --ff-d:'Instrument Serif',Georgia,serif;
  --ff-b:'Sora',sans-serif;--ff-m:'DM Mono',monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  background:
    radial-gradient(circle at 92% 4%,rgba(162,74,42,.13) 0,rgba(162,74,42,0) 40%),
    radial-gradient(circle at 6% 18%,rgba(255,226,171,.26) 0,rgba(255,226,171,0) 38%),
    var(--surface);
  color:var(--ink);font-family:var(--ff-b);font-size:16px;line-height:1.7;overflow-x:hidden;
}

/* ── KEYFRAMES ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:none}}
@keyframes fadeScale{from{opacity:0;transform:scale(.93)}to{opacity:1;transform:none}}
@keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-7px)}}
@keyframes ping{0%{box-shadow:0 0 0 0 rgba(162,74,42,.55)}70%{box-shadow:0 0 0 10px rgba(162,74,42,0)}100%{box-shadow:0 0 0 0 rgba(162,74,42,0)}}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
@keyframes scanBeam{0%{top:0;opacity:.8}88%{top:calc(100% - 2px);opacity:.8}94%{opacity:0}100%{top:0;opacity:0}}
@keyframes scanPulse{0%{box-shadow:0 0 0 0 rgba(162,74,42,.4)}70%{box-shadow:0 0 0 8px rgba(162,74,42,0)}100%{box-shadow:0 0 0 0 rgba(162,74,42,0)}}
@keyframes resultSlide{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}
@keyframes badgeIn{from{opacity:0;transform:scale(.8) translateY(6px)}to{opacity:1;transform:scale(1) translateY(0)}}
@keyframes connGrow{from{transform:scaleX(0)}to{transform:scaleX(1)}}
@keyframes stepIn{from{opacity:0;transform:translateX(-20px)}to{opacity:1;transform:none}}
@keyframes listIn{from{opacity:0;transform:translateX(16px)}to{opacity:1;transform:none}}
@keyframes cardFadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:none}}
@keyframes glowPulse{0%,100%{opacity:.5;transform:scale(1)}50%{opacity:.8;transform:scale(1.07)}}
@keyframes imgReveal{from{opacity:0;transform:scale(.92) translateY(12px)}to{opacity:1;transform:none}}
@keyframes shimmer{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}
@keyframes progressFill{from{width:0}to{width:100%}}
@keyframes tagPop{from{opacity:0;transform:scale(.7) translateY(4px)}to{opacity:1;transform:none}}
@keyframes checkDraw{from{stroke-dashoffset:20}to{stroke-dashoffset:0}}
@keyframes poseSlideIn{from{opacity:0;transform:translateX(18px) scale(.96)}to{opacity:1;transform:none}}
@keyframes accessoryPop{from{opacity:0;transform:scale(.6) rotate(-6deg)}to{opacity:1;transform:scale(1) rotate(0)}}

.reveal-up{animation:fadeUp .75s cubic-bezier(.22,.85,.44,1) both}
.reveal-fade{animation:fadeScale .7s cubic-bezier(.22,.85,.44,1) both}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:.9rem 2.8rem;background:rgba(253,248,239,.93);backdrop-filter:blur(16px);border-bottom:1px solid var(--line);transition:padding .3s}
nav.scrolled{padding-top:.6rem;padding-bottom:.6rem}
.nav-left{display:flex;align-items:center;gap:.7rem}
.nav-back{width:34px;height:34px;border-radius:8px;border:1px solid var(--line);background:rgba(255,252,244,.7);color:var(--rust-600);text-decoration:none;display:inline-flex;align-items:center;justify-content:center;transition:background .2s,border-color .2s,transform .15s}
.nav-back:hover{background:var(--rust-50);border-color:var(--rust-300);transform:translateY(-1px)}
.nav-back svg{width:14px;height:14px}
.nav-logo{font-family:var(--ff-d);font-size:1.3rem;font-style:italic;color:var(--rust-600)}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{font-size:.83rem;font-weight:400;color:var(--ink-soft);text-decoration:none;transition:color .2s}
.nav-links a:hover{color:var(--rust-500)}
.nav-cta{font-size:.83rem;font-weight:600;padding:.46rem 1.15rem;border-radius:8px;background:var(--rust-500);color:#fff;text-decoration:none;transition:background .2s,transform .15s}
.nav-cta:hover{background:var(--rust-600);transform:translateY(-1px)}

/* ── TICKER ── */
.ticker-wrap{margin-top:63px;overflow:hidden;background:linear-gradient(90deg,#f3e6cf,#ecd8b8);border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:.5rem 0}
.ticker{display:flex;white-space:nowrap;animation:ticker 32s linear infinite}
.ticker-item{font-size:.7rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--rust-600);padding:0 2.2rem;flex-shrink:0}
.ticker-item::after{content:'·';margin-left:2.2rem;color:var(--rust-400)}

/* ── LAYOUT ── */
.container{max-width:1160px;margin:0 auto;padding:0 2.4rem}
.narrow{max-width:820px;margin:0 auto;padding:0 2.4rem}
.eyebrow{font-size:.7rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--rust-500);display:block;margin-bottom:.55rem}
.sh2{font-family:var(--ff-d);font-size:clamp(1.8rem,3.2vw,2.6rem);font-weight:400;line-height:1.18;letter-spacing:-.01em;color:var(--ink)}
.sh2 em{font-style:italic;color:var(--rust-500)}
.btn{display:inline-block;font-size:.88rem;font-weight:600;border-radius:8px;text-decoration:none;padding:.66rem 1.5rem;transition:background .2s,transform .15s,box-shadow .2s}
.btn.primary{background:var(--rust-500);color:#fff;box-shadow:0 4px 18px rgba(162,74,42,.28)}
.btn.primary:hover{background:var(--rust-600);transform:translateY(-2px)}
.btn.ghost{border:1.5px solid var(--line-mid);color:var(--rust-600)}
.btn.ghost:hover{background:var(--rust-50);transform:translateY(-2px)}
.cta-row{display:flex;gap:.85rem;flex-wrap:wrap}
.cta-row.center{justify-content:center}

/* ══ HERO ══ */
.bd-hero{padding:5.5rem 0 4.5rem;position:relative;overflow:hidden}
.bd-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 55% at 80% 10%,rgba(162,74,42,.11),transparent),radial-gradient(ellipse 45% 55% at 5% 90%,rgba(255,215,140,.18),transparent);pointer-events:none}
.bd-hero::after{content:'';position:absolute;inset:0;background-image:linear-gradient(var(--line) 1px,transparent 1px),linear-gradient(90deg,var(--line) 1px,transparent 1px);background-size:48px 48px;mask-image:radial-gradient(ellipse 75% 75% at 68% 38%,black 0%,transparent 100%);pointer-events:none}
.bd-hero__grid{display:grid;grid-template-columns:1fr 1.1fr;gap:3.5rem;align-items:center}
.bd-hero__eyebrow{display:inline-flex;align-items:center;gap:.55rem;margin-bottom:.9rem}
.eyebrow-dot{width:8px;height:8px;border-radius:50%;background:var(--rust-500);animation:ping 2.2s ease-in-out infinite}
.eyebrow-text{font-size:.7rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--rust-600)}
.bd-hero__h1{font-family:var(--ff-d);font-size:clamp(2.4rem,4.8vw,4rem);line-height:1.1;letter-spacing:-.01em;color:var(--ink);margin-bottom:1.2rem}
.bd-hero__h1 em{font-style:italic;color:var(--rust-500);position:relative}
.bd-hero__h1 em::after{content:'';position:absolute;left:0;right:0;bottom:-3px;height:2px;border-radius:2px;background:var(--rust-400);opacity:.4}
.bd-hero__lead{font-size:1.04rem;font-weight:300;color:var(--ink-soft);line-height:1.75;max-width:50ch;margin-bottom:1.5rem}

/* hero step flow */
.hero-steps-strip{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:1.8rem;padding:.85rem 1rem;background:rgba(255,248,230,.8);border:1px solid var(--line-mid);border-radius:12px}
.hs-pill{display:flex;flex-direction:column;align-items:center;gap:.15rem;padding:.2rem .3rem}
.hs-pill-num{font-family:var(--ff-m);font-size:.58rem;font-weight:700;color:var(--rust-500)}
.hs-pill-label{font-size:.72rem;font-weight:600;color:var(--ink);white-space:nowrap}
.hs-pill.done .hs-pill-num{color:#2e6e43}.hs-pill.done .hs-pill-label{color:#2e6e43}
.hs-arrow{color:var(--rust-400);font-size:.9rem;flex-shrink:0}

/* ── HERO DEMO WINDOW ── */
.bd-hero__demo{position:relative}
.demo-window{border:1.5px solid var(--line-mid);border-radius:20px;background:rgba(255,252,242,.97);box-shadow:0 28px 72px rgba(75,42,21,.13),0 4px 18px rgba(75,42,21,.06);overflow:hidden}
.demo-bar{display:flex;align-items:center;gap:.45rem;padding:.7rem 1rem;background:rgba(245,235,218,.7);border-bottom:1px solid var(--line)}
.demo-dot{width:10px;height:10px;border-radius:50%}
.demo-dot-r{background:#f06257}.demo-dot-y{background:#f5a623}.demo-dot-g{background:#57c257}
.demo-bar-title{margin-left:.4rem;font-size:.78rem;font-weight:600;color:var(--ink-soft);letter-spacing:.04em;font-family:var(--ff-m);flex:1}
.demo-bar-live{display:flex;align-items:center;gap:.3rem;font-family:var(--ff-m);font-size:.62rem;color:#5a8a50;font-weight:700}
.demo-bar-live-dot{width:6px;height:6px;border-radius:50%;background:#7db87b;animation:ping 2s ease-in-out infinite}
.demo-body{padding:1rem;display:flex;flex-direction:column;gap:.65rem}

/* step pills in demo */
.demo-steps-row{display:flex;border-bottom:1px solid var(--line);margin:-1rem -1rem .8rem;background:rgba(245,235,218,.35)}
.demo-step-pill{flex:1;padding:.42rem .3rem;text-align:center;font-family:var(--ff-m);font-size:.6rem;font-weight:600;color:var(--ink-muted);border-right:1px solid var(--line);cursor:pointer;transition:background .3s,color .3s;user-select:none}
.demo-step-pill:last-child{border-right:none}
.demo-step-pill.active{background:var(--rust-500);color:#fff8ee}
.demo-step-pill.done{background:rgba(46,140,79,.1);color:#2e6e43}

/* ── STEP PANELS ── */
.demo-panel{display:none;flex-direction:column;gap:.6rem;min-height:260px}
.demo-panel.active{display:flex}

/* STEP 1: upload */
.up-garment-row{display:flex;align-items:center;gap:.75rem;background:#fff;border:1px solid var(--line);border-radius:10px;padding:.65rem .85rem;position:relative;overflow:hidden}
.up-garment-img{width:48px;height:62px;border-radius:7px;object-fit:cover;flex-shrink:0}
.up-garment-meta{flex:1}
.up-garment-name{font-family:var(--ff-m);font-size:.76rem;font-weight:600;color:var(--ink)}
.up-garment-detail{font-family:var(--ff-m);font-size:.62rem;color:var(--ink-muted);margin-top:.12rem}
.up-scan-beam{position:absolute;left:0;right:0;top:0;height:2px;background:linear-gradient(90deg,transparent,rgba(162,74,42,.7),transparent);animation:scanBeam 2.4s ease-in-out infinite;box-shadow:0 0 8px rgba(162,74,42,.4)}
.up-status{font-family:var(--ff-m);font-size:.62rem;font-weight:600;border-radius:999px;padding:.15rem .52rem;flex-shrink:0}
.st-scanning{background:rgba(192,120,32,.1);color:var(--amber);border:1px solid rgba(192,120,32,.22);animation:scanPulse 1.4s ease infinite}
.st-done{background:rgba(46,140,79,.1);color:#1c6535;border:1px solid rgba(46,140,79,.22)}
.attr-tags{display:flex;flex-wrap:wrap;gap:.3rem}
.attr-tag{font-family:var(--ff-m);font-size:.62rem;font-weight:600;background:rgba(162,74,42,.07);color:var(--rust-600);border:1px solid rgba(162,74,42,.16);border-radius:999px;padding:.15rem .5rem;opacity:0}
.attr-tag.show{animation:tagPop .35s cubic-bezier(.34,1.2,.64,1) both}
.acc-row{display:flex;gap:.5rem;align-items:center;background:rgba(162,74,42,.03);border:1px solid var(--line);border-radius:9px;padding:.55rem .75rem}
.acc-img{width:36px;height:36px;border-radius:6px;object-fit:cover;flex-shrink:0;border:1px solid var(--line)}
.acc-label{font-family:var(--ff-m);font-size:.68rem;font-weight:500;color:var(--ink);flex:1}
.acc-tag{font-family:var(--ff-m);font-size:.6rem;background:rgba(46,140,79,.1);color:#1c6535;border:1px solid rgba(46,140,79,.2);border-radius:999px;padding:.12rem .45rem}

/* STEP 2: model */
.model-select-label{font-family:var(--ff-m);font-size:.65rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-muted)}
.model-img-row{display:flex;align-items:center;gap:.65rem;background:#fff;border:1.5px solid var(--rust-400);border-radius:10px;padding:.65rem .85rem;box-shadow:0 0 0 3px rgba(162,74,42,.1)}
.model-portrait{width:46px;height:60px;border-radius:8px;object-fit:cover;flex-shrink:0;object-position:top}
.model-meta-name{font-size:.85rem;font-weight:600;color:var(--ink)}
.model-meta-detail{font-family:var(--ff-m);font-size:.62rem;color:var(--ink-muted);margin-top:.12rem;line-height:1.45}
.model-compat-badge{display:inline-flex;align-items:center;gap:.3rem;font-family:var(--ff-m);font-size:.62rem;font-weight:600;background:rgba(46,140,79,.1);color:#1c6535;border:1px solid rgba(46,140,79,.22);border-radius:999px;padding:.2rem .55rem;margin-top:.3rem}
.model-compat-badge svg{width:10px;height:10px;flex-shrink:0}
.model-compat-badge svg path{stroke-dasharray:20;stroke-dashoffset:20;animation:checkDraw .4s ease .2s both}
.model-other-hint{font-family:var(--ff-m);font-size:.62rem;color:var(--ink-muted);text-align:center;padding:.35rem}

/* STEP 3: prompt */
.prompt-box{background:#fffaef;border:1.5px solid #d4b994;border-radius:10px;padding:.65rem .85rem;min-height:52px;display:flex;align-items:flex-start;flex-wrap:wrap}
.prompt-box.active{border-color:var(--rust-400);box-shadow:0 0 0 3px rgba(162,74,42,.08)}
.prompt-typed{font-family:var(--ff-m);font-size:.75rem;color:var(--ink);line-height:1.55;display:inline}
.prompt-cursor{font-family:var(--ff-m);font-size:.75rem;color:var(--rust-500);animation:blink 1.1s step-end infinite}
.prompt-chips{display:flex;flex-wrap:wrap;gap:.28rem}
.prompt-chip{font-family:var(--ff-m);font-size:.62rem;font-weight:600;background:rgba(162,74,42,.07);color:var(--rust-600);border:1px solid rgba(162,74,42,.16);border-radius:999px;padding:.15rem .5rem;opacity:0}
.prompt-chip.on{background:rgba(162,74,42,.12);border-color:rgba(162,74,42,.3)}
.prompt-chip.show{animation:tagPop .3s ease both}
.prompt-gen-row{display:flex;align-items:center;gap:.55rem}
.prompt-gen-btn{font-family:var(--ff-m);font-size:.7rem;font-weight:600;background:var(--rust-500);color:#fff8ee;border-radius:8px;padding:.55rem 1rem;flex-shrink:0;cursor:pointer;transition:background .2s;letter-spacing:.06em}
.prompt-gen-btn:hover{background:var(--rust-600)}
.gen-track{flex:1;height:4px;background:rgba(162,74,42,.1);border-radius:999px;overflow:hidden}
.gen-fill{height:100%;background:linear-gradient(90deg,var(--rust-400),var(--rust-500));border-radius:999px;width:0;transition:width 1.8s cubic-bezier(.22,.85,.44,1)}
.gen-pct{font-family:var(--ff-m);font-size:.62rem;color:var(--rust-500);flex-shrink:0;font-weight:600}

/* STEP 4: results */
.result-header{display:flex;align-items:center;justify-content:space-between}
.result-label{font-family:var(--ff-m);font-size:.7rem;font-weight:600;color:var(--ink)}
.result-live{display:flex;align-items:center;gap:.3rem;font-family:var(--ff-m);font-size:.62rem;color:#5a8a50}
.result-live-dot{width:5px;height:5px;border-radius:50%;background:#7db87b;animation:ping 2s ease-in-out infinite}
.result-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:.42rem}
.result-frame{border-radius:9px;overflow:hidden;position:relative;opacity:0}
.result-frame.main{grid-row:span 2}
.result-frame.show{animation:imgReveal .55s cubic-bezier(.34,1.2,.64,1) both}
.result-frame img{width:100%;height:100%;object-fit:cover;object-position:top;display:block}
.result-frame-label{position:absolute;bottom:.4rem;left:.4rem;right:.4rem;font-family:var(--ff-m);font-size:.52rem;font-weight:600;color:rgba(255,245,228,.9);letter-spacing:.06em}
.result-frame-badge{position:absolute;top:.4rem;right:.4rem;font-family:var(--ff-m);font-size:.52rem;font-weight:700;background:rgba(46,140,79,.85);color:#fff;border-radius:4px;padding:.1rem .35rem}
.result-frame-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(20,8,2,.55),transparent 55%)}
.result-download{display:flex;gap:.4rem;align-items:center;background:rgba(162,74,42,.04);border:1px solid rgba(162,74,42,.12);border-radius:8px;padding:.5rem .75rem;opacity:0}
.result-download.show{animation:cardFadeUp .4s ease .8s both}
.rd-label{font-family:var(--ff-m);font-size:.62rem;color:var(--ink-muted);flex:1}
.rd-channels{display:flex;gap:.3rem;flex-wrap:wrap}
.rd-ch{font-family:var(--ff-m);font-size:.6rem;font-weight:700;color:var(--rust-600);background:rgba(162,74,42,.08);border:1px solid rgba(162,74,42,.18);border-radius:999px;padding:.12rem .45rem}

/* floating badges */
.demo-float{position:absolute;display:flex;align-items:center;gap:.4rem;font-size:.74rem;font-weight:600;color:#5a3d2e;background:rgba(255,248,232,.95);border:1.5px solid var(--line);border-radius:999px;padding:.42rem .82rem;box-shadow:0 6px 20px rgba(75,42,21,.12);white-space:nowrap;animation:floatY 3s ease-in-out infinite}
.demo-float svg{width:13px;height:13px;flex-shrink:0;color:var(--rust-500)}
.demo-float-1{bottom:-1.2rem;left:-1.5rem;animation-delay:0s}
.demo-float-2{top:.8rem;right:-1.8rem;animation-delay:1.5s}

/* ── STATS ── */
.stats-strip{background:var(--dark-bg);display:grid;grid-template-columns:repeat(4,1fr);gap:1px;overflow:hidden}
.stat-item{text-align:center;padding:2.2rem 1rem;position:relative}
.stat-item:not(:last-child)::after{content:'';position:absolute;right:0;top:25%;bottom:25%;width:1px;background:rgba(255,255,255,.07)}
.stat-num{font-family:var(--ff-d);font-size:2.6rem;font-style:italic;color:var(--rust-300);display:block;line-height:1;margin-bottom:.35rem}
.stat-label{font-size:.72rem;font-weight:400;color:rgba(255,255,255,.38);letter-spacing:.06em;text-transform:uppercase}

/* ══ OVERVIEW DARK ══ */
.bd-overview{background:#1c1108;color:#f0e0ca;position:relative;overflow:hidden;padding:5.5rem 0}
.bd-overview::before{content:'';position:absolute;top:-20%;right:-8%;width:500px;height:500px;background:radial-gradient(circle,rgba(162,74,42,.12),transparent 65%);pointer-events:none}
.overview-inner{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
.ovl .sh2{color:#f0e0ca;max-width:none}
.ovl .sh2 em{color:#d4906a}
.ovl p{color:#c8a88a;font-weight:300;line-height:1.85;margin-top:.75rem}
.ovl p+p{margin-top:.65rem}
/* process flow on right */
.proc-flow{display:flex;flex-direction:column;gap:0}
.proc-step{display:flex;gap:1rem;align-items:flex-start;opacity:0}
.proc-step.show{animation:cardFadeUp .5s cubic-bezier(.22,.85,.44,1) both}
.proc-step-left{display:flex;flex-direction:column;align-items:center;flex-shrink:0}
.proc-num{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--rust-600),var(--rust-500));color:#fde8d0;font-family:var(--ff-m);font-size:.7rem;font-weight:700;display:flex;align-items:center;justify-content:center;box-shadow:0 0 20px rgba(162,74,42,.3);flex-shrink:0}
.proc-vline{width:1px;flex:1;min-height:36px;background:linear-gradient(to bottom,rgba(162,74,42,.4),rgba(162,74,42,.08));margin:4px 0}
.proc-body{background:rgba(255,255,255,.06);border:1px solid rgba(255,240,210,.1);border-radius:12px;padding:.8rem 1rem;flex:1;margin-bottom:.65rem}
.proc-body-title{font-size:.95rem;font-weight:600;color:#f0e0ca;margin-bottom:.25rem}
.proc-body-sub{font-size:.8rem;color:#c8a88a;font-weight:300;line-height:1.6}
.proc-body-tag{font-family:var(--ff-m);font-size:.6rem;color:rgba(218,149,106,.7);display:inline-block;margin-top:.45rem}

/* ══ FEATURE ROWS ══ — exact Briefly Docs pattern */
.feat-section{padding:4rem 0 2rem}
.feat-row{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;padding:5rem 0;border-bottom:1px solid var(--line)}
.feat-row:last-child{border-bottom:none}
.feat-row.reverse .feat-copy{order:2}
.feat-row.reverse .feat-illu{order:1}
.feat-copy .sh2{margin-bottom:1rem}
.feat-copy p{font-size:.97rem;font-weight:300;color:var(--ink-soft);line-height:1.75;margin-bottom:1rem}
.bullet-list{list-style:none;display:grid;gap:.55rem}
.bullet-list li{position:relative;padding-left:1.1rem;font-size:.9rem;color:var(--ink-soft)}
.bullet-list li::before{content:'';position:absolute;left:0;top:.6em;width:6px;height:6px;border-radius:50%;background:var(--rust-400)}
.illu-panel{border:1.5px solid var(--line-mid);border-radius:18px;overflow:hidden;position:relative;background:var(--sand-50)}

/* ─ PANEL 1: Upload + auto-detect ─ */
.up-panel{padding:1.4rem;min-height:340px;display:flex;flex-direction:column;gap:.65rem}
.up-panel-title{font-family:var(--ff-m);font-size:.7rem;font-weight:600;color:var(--ink)}
.up-main-row{display:flex;align-items:center;gap:.85rem;background:#fff;border:1px solid var(--line);border-radius:11px;padding:.75rem .95rem;position:relative;overflow:hidden}
.up-main-img{width:56px;height:72px;border-radius:8px;object-fit:cover;flex-shrink:0}
.up-main-meta{flex:1}
.up-main-name{font-size:.85rem;font-weight:600;color:var(--ink)}
.up-main-sub{font-family:var(--ff-m);font-size:.62rem;color:var(--ink-muted);margin-top:.12rem}
.up-beam{position:absolute;left:0;right:0;top:0;height:2px;background:linear-gradient(90deg,transparent,rgba(162,74,42,.7),transparent);animation:scanBeam 2.6s ease-in-out infinite;box-shadow:0 0 8px rgba(162,74,42,.4)}
.up-tags-section{background:rgba(162,74,42,.03);border:1px solid rgba(162,74,42,.1);border-radius:9px;padding:.65rem}
.up-tags-label{font-family:var(--ff-m);font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-muted);margin-bottom:.4rem}
.up-tags{display:flex;flex-wrap:wrap;gap:.28rem}
.up-tag{font-family:var(--ff-m);font-size:.62rem;font-weight:600;background:rgba(162,74,42,.07);color:var(--rust-600);border:1px solid rgba(162,74,42,.16);border-radius:999px;padding:.16rem .5rem;opacity:0}
.up-tag.show{animation:tagPop .35s cubic-bezier(.34,1.2,.64,1) both}
.up-acc-row{display:flex;gap:.5rem;align-items:center;background:#fff;border:1px solid var(--line);border-radius:9px;padding:.55rem .75rem;opacity:0}
.up-acc-row.show{animation:cardFadeUp .4s ease both}
.up-acc-img{width:38px;height:38px;border-radius:7px;object-fit:cover;flex-shrink:0;border:1px solid var(--line)}
.up-acc-label{font-family:var(--ff-m);font-size:.7rem;font-weight:500;color:var(--ink);flex:1}
.up-acc-badge{font-family:var(--ff-m);font-size:.6rem;font-weight:600;background:rgba(46,140,79,.1);color:#1c6535;border:1px solid rgba(46,140,79,.2);border-radius:999px;padding:.12rem .45rem}
.up-compat{display:flex;align-items:center;gap:.45rem;font-family:var(--ff-m);font-size:.72rem;font-weight:600;color:#1c6535;background:rgba(46,140,79,.06);border:1px solid rgba(46,140,79,.15);border-radius:8px;padding:.5rem .75rem;opacity:0}
.up-compat.show{animation:cardFadeUp .4s ease both}

/* ─ PANEL 2: Model selection ─ */
.model-panel{padding:1.4rem;min-height:340px;display:flex;flex-direction:column;gap:.65rem}
.model-panel-header{display:flex;align-items:center;justify-content:space-between}
.model-panel-title{font-family:var(--ff-m);font-size:.7rem;font-weight:600;color:var(--ink)}
.model-panel-count{font-family:var(--ff-m);font-size:.62rem;color:var(--ink-muted)}
.model-selected-big{display:flex;align-items:center;gap:.85rem;background:#fff;border:1.5px solid var(--rust-400);border-radius:11px;padding:.7rem .95rem;box-shadow:0 0 0 3px rgba(162,74,42,.1);opacity:0}
.model-selected-big.show{animation:cardFadeUp .45s ease both}
.model-portrait-img{width:52px;height:68px;border-radius:9px;object-fit:cover;object-position:top;flex-shrink:0}
.ms-name{font-size:.88rem;font-weight:700;color:var(--ink)}
.ms-detail{font-family:var(--ff-m);font-size:.63rem;color:var(--ink-muted);margin-top:.12rem;line-height:1.5}
.ms-compat{display:inline-flex;align-items:center;gap:.3rem;font-family:var(--ff-m);font-size:.6rem;font-weight:600;background:rgba(46,140,79,.1);color:#1c6535;border:1px solid rgba(46,140,79,.2);border-radius:999px;padding:.15rem .5rem;margin-top:.35rem}
.ms-compat svg{width:10px;height:10px}
.ms-compat svg path{stroke-dasharray:20;stroke-dashoffset:20;animation:checkDraw .4s ease .2s both}
.model-poses-label{font-family:var(--ff-m);font-size:.65rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-muted)}
.model-poses-row{display:grid;grid-template-columns:repeat(3,1fr);gap:.4rem}
.pose-thumb{border-radius:8px;overflow:hidden;aspect-ratio:2/3;border:1.5px solid var(--line);cursor:pointer;transition:border-color .2s,transform .2s;opacity:0}
.pose-thumb.show{animation:imgReveal .5s cubic-bezier(.34,1.2,.64,1) both}
.pose-thumb.active{border-color:var(--rust-500);box-shadow:0 0 0 2.5px rgba(162,74,42,.15);transform:translateY(-2px)}
.pose-thumb img{width:100%;height:100%;object-fit:cover;object-position:top;display:block}

/* ─ PANEL 3: Prompt + styling ─ */
.prompt-panel{padding:1.4rem;min-height:340px;display:flex;flex-direction:column;gap:.65rem}
.pp-title{font-family:var(--ff-m);font-size:.7rem;font-weight:600;color:var(--ink)}
.pp-context-bar{display:flex;align-items:center;gap:.5rem;background:rgba(162,74,42,.04);border:1px solid rgba(162,74,42,.1);border-radius:8px;padding:.48rem .72rem;flex-wrap:wrap}
.pp-context-item{font-family:var(--ff-m);font-size:.64rem;color:var(--ink-muted)}
.pp-context-item strong{color:var(--ink);font-weight:600}
.pp-context-sep{color:rgba(162,74,42,.3);font-size:.65rem}
.pp-text-area{background:#fffaef;border:1.5px solid #d4b994;border-radius:10px;padding:.65rem .85rem;min-height:62px}
.pp-text-area.active{border-color:var(--rust-400);box-shadow:0 0 0 3px rgba(162,74,42,.08)}
.pp-typed{font-family:var(--ff-m);font-size:.76rem;color:var(--ink);line-height:1.55;display:inline}
.pp-cursor{font-family:var(--ff-m);font-size:.76rem;color:var(--rust-500);animation:blink 1.1s step-end infinite}
.pp-chips-label{font-family:var(--ff-m);font-size:.58rem;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-muted)}
.pp-chips{display:flex;flex-wrap:wrap;gap:.28rem}
.pp-chip{font-family:var(--ff-m);font-size:.62rem;font-weight:600;background:rgba(162,74,42,.07);color:var(--rust-600);border:1px solid rgba(162,74,42,.16);border-radius:999px;padding:.16rem .5rem;opacity:0;cursor:pointer;transition:background .2s,border-color .2s}
.pp-chip.on{background:rgba(162,74,42,.14);border-color:rgba(162,74,42,.35);color:var(--rust-500)}
.pp-chip.show{animation:tagPop .3s ease both}
.pp-gen-row{display:flex;align-items:center;gap:.55rem}
.pp-gen-btn{font-family:var(--ff-m);font-size:.7rem;font-weight:600;background:var(--rust-500);color:#fff8ee;border-radius:8px;padding:.58rem 1rem;flex-shrink:0;cursor:pointer;transition:background .2s;letter-spacing:.06em}
.pp-gen-btn:hover{background:var(--rust-600)}
.pp-track{flex:1;height:4px;background:rgba(162,74,42,.1);border-radius:999px;overflow:hidden}
.pp-fill{height:100%;background:linear-gradient(90deg,var(--rust-400),var(--rust-500));border-radius:999px;width:0;transition:width 1.8s cubic-bezier(.22,.85,.44,1)}
.pp-pct{font-family:var(--ff-m);font-size:.62rem;color:var(--rust-500);flex-shrink:0;font-weight:600}

/* ─ PANEL 4: Output grid ─ */
.output-panel{padding:1.4rem;min-height:340px;display:flex;flex-direction:column;gap:.65rem}
.op-header{display:flex;align-items:center;justify-content:space-between}
.op-title{font-family:var(--ff-m);font-size:.7rem;font-weight:600;color:var(--ink)}
.op-count{font-family:var(--ff-m);font-size:.62rem;color:var(--rust-500)}
.op-context{display:flex;align-items:center;gap:.4rem;background:rgba(162,74,42,.04);border:1px solid rgba(162,74,42,.1);border-radius:7px;padding:.42rem .65rem;font-family:var(--ff-m);font-size:.62rem;color:var(--ink-muted)}
.op-grid{display:grid;grid-template-columns:1.6fr 1fr 1fr;grid-template-rows:1fr 1fr;gap:.42rem;flex:1;min-height:190px}
.op-frame{border-radius:9px;overflow:hidden;position:relative;opacity:0}
.op-frame.main{grid-row:span 2}
.op-frame.show{animation:imgReveal .5s cubic-bezier(.34,1.2,.64,1) both}
.op-frame img{width:100%;height:100%;object-fit:cover;object-position:top;display:block}
.op-frame-ov{position:absolute;inset:0;background:linear-gradient(to top,rgba(20,8,2,.55),transparent 50%)}
.op-frame-label{position:absolute;bottom:.42rem;left:.45rem;right:.45rem;font-family:var(--ff-m);font-size:.52rem;font-weight:600;color:rgba(255,245,228,.9);letter-spacing:.06em}
.op-frame-badge{position:absolute;top:.42rem;right:.42rem;font-family:var(--ff-m);font-size:.52rem;font-weight:700;background:rgba(46,140,79,.85);color:#fff;border-radius:4px;padding:.1rem .35rem}
.op-dl{display:flex;gap:.4rem;align-items:center;background:rgba(162,74,42,.04);border:1px solid rgba(162,74,42,.12);border-radius:8px;padding:.48rem .72rem;opacity:0}
.op-dl.show{animation:cardFadeUp .4s ease .9s both}
.op-dl-label{font-family:var(--ff-m);font-size:.62rem;color:var(--ink-muted);flex:1}
.op-dl-channels{display:flex;gap:.28rem;flex-wrap:wrap}
.op-dl-ch{font-family:var(--ff-m);font-size:.6rem;font-weight:700;color:var(--rust-600);background:rgba(162,74,42,.08);border:1px solid rgba(162,74,42,.18);border-radius:999px;padding:.1rem .42rem}

/* ── HOW IT WORKS ── */
.bd-how{padding:5rem 0;background:linear-gradient(180deg,transparent,rgba(250,240,224,.45) 40%,transparent)}
.bd-how__header{margin-bottom:2.5rem}
.bd-how__steps{display:grid;grid-template-columns:repeat(4,1fr);gap:0;position:relative}
.bd-step{position:relative;opacity:0;animation:stepIn .6s cubic-bezier(.22,.85,.44,1) both;animation-play-state:paused}
.bd-step.in-view{animation-play-state:running}
.bd-step:nth-child(1){animation-delay:0s}.bd-step:nth-child(2){animation-delay:.13s}.bd-step:nth-child(3){animation-delay:.26s}.bd-step:nth-child(4){animation-delay:.39s}
.bd-step__number{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--rust-500),var(--rust-700));color:#fff8ee;font-size:.74rem;font-weight:700;letter-spacing:.05em;display:flex;align-items:center;justify-content:center;margin-bottom:1rem;position:relative;z-index:2;box-shadow:0 4px 16px rgba(162,74,42,.3)}
.bd-step__connector{position:absolute;top:21px;left:calc(42px + 1rem);right:-1rem;height:1.5px;background:var(--line);transform-origin:left;animation:connGrow .55s ease both;animation-play-state:paused}
.bd-step.in-view .bd-step__connector{animation-play-state:running}
.bd-step:last-child .bd-step__connector{display:none}
.bd-step__card{padding-right:1.4rem}
.bd-step__card h3{font-size:.97rem;font-weight:600;color:var(--ink);margin-bottom:.42rem}
.bd-step__card p{font-size:.86rem;font-weight:300;color:var(--ink-soft);line-height:1.68}

/* ── FIT FOR ── */
.bd-audience{padding:5rem 0;background:linear-gradient(to bottom,rgba(250,240,225,.4),transparent)}
.bd-audience__grid{display:grid;grid-template-columns:1fr 1fr;gap:4.5rem;align-items:start}
.bd-audience__list{display:grid;gap:.7rem;margin-top:1.2rem}
.bd-audience__item{display:flex;align-items:center;gap:.85rem;font-size:.96rem;font-weight:500;color:var(--ink);opacity:0;animation:listIn .5s ease both;animation-play-state:paused}
.bd-audience__item.in-view{animation-play-state:running}
.bd-audience__check{width:28px;height:28px;border-radius:50%;background:rgba(162,74,42,.1);border:1.5px solid rgba(162,74,42,.22);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--rust-500)}
.bd-audience__check svg{width:13px;height:13px}
.bd-audience__sub{font-size:.95rem;font-weight:300;color:var(--ink-soft);line-height:1.72;margin-top:.9rem}
.fit-stats{display:flex;flex-direction:column;gap:.85rem}
.fit-stat-card{border:1.5px solid var(--line);border-radius:16px;padding:1.5rem 1.6rem;background:rgba(255,252,244,.9);display:flex;align-items:center;gap:1.3rem;opacity:0}
.fit-stat-card.in-view{animation:cardFadeUp .5s cubic-bezier(.22,.85,.44,1) both}
.fsc-n{font-family:var(--ff-d);font-size:2.6rem;font-style:italic;color:var(--rust-500);line-height:1;flex-shrink:0;width:80px}
.fsc-t{font-size:.87rem;color:var(--ink-soft);line-height:1.6}
.fsc-t strong{color:var(--ink);font-weight:600}

/* ── FEATURES GRID ── */
.feat-grid-sec{padding:5rem 0;border-top:1px solid var(--line)}
.feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);margin-top:2rem;border:1px solid var(--line);border-radius:16px;overflow:hidden}
.fgc{background:var(--rust-50);padding:1.9rem 1.7rem;position:relative;overflow:hidden;transition:background .3s;opacity:0}
.fgc.in-view{animation:fadeUp .5s cubic-bezier(.22,.85,.44,1) both}
.fgc:hover{background:var(--rust-100)}
.fgc::before{content:'';position:absolute;top:0;left:0;right:0;height:2.5px;background:linear-gradient(90deg,var(--rust-400),var(--rust-300));transform:scaleX(0);transform-origin:left;transition:transform .4s ease}
.fgc:hover::before{transform:scaleX(1)}
.fgn{font-family:var(--ff-m);font-size:.6rem;font-weight:600;letter-spacing:.1em;color:var(--rust-400);opacity:.6;margin-bottom:.6rem}
.fgc h3{font-family:var(--ff-d);font-size:1.1rem;font-weight:400;color:var(--ink);margin-bottom:.42rem;line-height:1.2}
.fgc p{font-size:.86rem;font-weight:300;color:var(--ink-soft);line-height:1.75}

/* ── CTA ── */
.bd-cta{padding:3rem 0 5.5rem}
.bd-cta__card{position:relative;border:1.5px solid var(--line);border-radius:26px;padding:3.8rem 3.2rem;background:linear-gradient(148deg,rgba(255,246,230,.98),rgba(252,233,200,.9));box-shadow:0 24px 64px rgba(75,42,21,.1);text-align:center;overflow:hidden;opacity:0}
.bd-cta__card.in-view{animation:fadeUp .8s cubic-bezier(.22,.85,.44,1) forwards}
.bd-cta__glow{position:absolute;top:-60px;right:-60px;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(162,74,42,.13),transparent 70%);animation:glowPulse 4s ease-in-out infinite;pointer-events:none}
.bd-cta__card h2{font-family:var(--ff-d);font-size:clamp(1.5rem,2.8vw,2.2rem);letter-spacing:-.02em;line-height:1.22;color:var(--ink);max-width:56ch;margin:.6rem auto 0}
.bd-cta__sub{margin-top:.9rem;color:var(--ink-soft);font-size:1rem;font-weight:300}

footer{background:var(--dark-bg);color:rgba(255,255,255,.35);text-align:center;padding:2rem 2.4rem;font-size:.82rem;font-weight:300}
footer strong{color:var(--rust-300);font-weight:500}

@media(max-width:980px){
  nav{padding:.9rem 1.5rem}.nav-links{display:none}
  .bd-hero__grid,.overview-inner,.feat-row,.bd-audience__grid{grid-template-columns:1fr;gap:2.5rem}
  .feat-row.reverse .feat-copy,.feat-row.reverse .feat-illu{order:unset}
  .bd-how__steps{grid-template-columns:1fr 1fr;gap:1.4rem}.bd-step__connector{display:none}
  .stats-strip{grid-template-columns:repeat(2,1fr)}
  .demo-float-1,.demo-float-2{display:none}
  .feat-grid{grid-template-columns:1fr 1fr}
  .result-grid,.op-grid{grid-template-columns:1fr 1fr}
  .result-frame.main,.op-frame.main{grid-row:unset}
}
@media(max-width:600px){
  .bd-how__steps{grid-template-columns:1fr}.bd-cta__card{padding:2.2rem 1.4rem}
  .feat-grid{grid-template-columns:1fr}.model-poses-row{grid-template-columns:1fr 1fr}
}
</style>

