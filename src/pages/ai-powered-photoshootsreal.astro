        <div class="fit-stat-card" id="fsc2" style="animation-delay:.12s"><div class="fsc-n">80%</div><div class="fsc-t"><strong>Lower production cost.</strong> No studio fees, model fees, photographer fees, or post-production bills.</div></div>
        <div class="fit-stat-card" id="fsc3" style="animation-delay:.24s"><div class="fsc-n">6+</div><div class="fsc-t"><strong>Channel formats per garment.</strong> Instagram, Meta, catalog, stories, web — all from a single session.</div></div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="bd-cta" id="cta">
  <div class="narrow">
    <div class="bd-cta__card" id="ctaCard">
      <div class="bd-cta__glow"></div>
      <span class="eyebrow">Get started</span>
      <h2>Ready to shoot your next collection — without booking a studio?</h2>
      <p class="bd-cta__sub">Upload a garment, pick a model, describe the scene. We'll show you the output live in your first session.</p>
      <div class="cta-row center" style="margin-top:1.8rem">
        <a class="btn primary" href="/contact">Request a Demo</a>
        <a class="btn ghost" href="/contact">Send us a garment image</a>
      </div>
    </div>
  </div>
</section>

<footer><p>&copy; 2026 <strong>Nyx Solution</strong> · AI-Powered Photoshoots — Creative AI Product</p></footer>

<script is:inline>
/* ── NAV ── */
window.addEventListener('scroll',()=>document.getElementById('mainnav')?.classList.toggle('scrolled',scrollY>40),{passive:true});

/* ── HERO STEP SWITCHER ── */
const hPills=[1,2,3,4].map(n=>document.getElementById('hpill'+n));
const hPanels=[1,2,3,4].map(n=>document.getElementById('hp'+n));
let hCur=0,hTimer=null;
function heroGo(idx){
  hPills.forEach((p,i)=>{p.classList.remove('active','done');if(i<idx)p.classList.add('done');if(i===idx)p.classList.add('active');});
  hPanels.forEach((p,i)=>{p.classList.remove('active');if(i===idx)p.classList.add('active');});
  hCur=idx;
}
function heroAdvance(){heroGo((hCur+1)%4);}
hTimer=setInterval(heroAdvance,4000);

/* hero prompt typewriter */
(()=>{
  const phrases=['Rooftop terrace · golden hour · gold hoop earrings · editorial feel','White minimal studio · soft light · catalog look','Outdoor garden · afternoon sun · candid walk · lifestyle'];
  const el=document.getElementById('heroTyped');
  let pi=0,ti=null;
  function type(){
    if(!el)return;
    const p=phrases[pi++%phrases.length];
    let i=0;el.textContent='';
    clearInterval(ti);
    ti=setInterval(()=>{el.textContent=p.slice(0,++i);if(i>=p.length)clearInterval(ti);},38);
  }
  type();setInterval(type,8500);
})();

/* ── INTERSECTION OBSERVER ── */
const seen=new Set();
const io=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(!e.isIntersecting||seen.has(e.target))return;
    seen.add(e.target);
    e.target.classList.add('in-view');
    const id=e.target.id;
    if(id==='procDiagram')initProc();
    if(id==='uploadPanel')initUpload();
    if(id==='modelPanel')initModel();
    if(id==='promptPanel')initPrompt();
    if(id==='outputPanel')initOutput();
    if(id&&(id.startsWith('fgc')||id.startsWith('fsc')))e.target.classList.add('in-view');
    if(id==='ctaCard')e.target.classList.add('in-view');
    io.unobserve(e.target);
  });
},{threshold:.12,rootMargin:'0px 0px -40px 0px'});

document.querySelectorAll(
  '.bd-step,.bd-audience__item,.fit-stat-card,#procDiagram,#uploadPanel,#modelPanel,#promptPanel,#outputPanel,#fgc1,#fgc2,#fgc3,#fgc4,#fgc5,#fgc6,#fsc1,#fsc2,#fsc3,#ctaCard'
).forEach(el=>io.observe(el));

/* COUNT UP */
const cio=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(!e.isIntersecting)return;
    const el=e.target,tgt=+el.dataset.count,t0=performance.now();
    const tick=now=>{const p=Math.min((now-t0)/1400,1);el.textContent=Math.round((1-Math.pow(1-p,3))*tgt);if(p<1)requestAnimationFrame(tick);};
    requestAnimationFrame(tick);cio.unobserve(el);
  });
},{threshold:.5});
document.querySelectorAll('[data-count]').forEach(el=>cio.observe(el));

/* ── PROC DIAGRAM ── */
function initProc(){
  ['pd1','pd2','pd3'].forEach((id,i)=>{
    const el=document.getElementById(id);
    if(el)setTimeout(()=>el.classList.add('show'),i*280+100);
  });
}

/* ── UPLOAD PANEL ── */
function initUpload(){
  const status=document.getElementById('upStatus');
  const tagsSec=document.getElementById('upTagsSec');
  const tags=document.getElementById('upTags');
  const acc1=document.getElementById('upAcc1');
  const acc2=document.getElementById('upAcc2');
  const compat=document.getElementById('upCompat');
  const tagList=['Square neckline','Structured tank','Flared trousers','Ivory / taupe','High-waist','Two-piece set','Smart casual','Office-ready'];

  if(status){status.textContent='Analysing…';status.style.background='rgba(192,120,32,.1)';status.style.color='var(--amber)';status.style.border='1px solid rgba(192,120,32,.22)';}
  setTimeout(()=>{
    if(status){status.textContent='Analysed ✓';status.style.background='rgba(46,140,79,.1)';status.style.color='#1c6535';status.style.border='1px solid rgba(46,140,79,.22)';}
    if(tagsSec){tagsSec.style.opacity='1';tagsSec.style.animation='cardFadeUp .4s ease both';}
    tagList.forEach((t,i)=>{
      setTimeout(()=>{
        const span=document.createElement('span');
        span.className='up-tag show';
        span.textContent=t;
        if(tags)tags.appendChild(span);
      },i*100+100);
    });
  },1600);
  setTimeout(()=>{acc1&&acc1.classList.add('show');},2800);
  setTimeout(()=>{acc2&&acc2.classList.add('show');},3200);
  setTimeout(()=>{compat&&compat.classList.add('show');},3800);
}

/* ── MODEL PANEL ── */
function initModel(){
  const sel=document.getElementById('modelSelectedBig');
  const poses=['pose1','pose2','pose3'];
  if(sel)setTimeout(()=>sel.classList.add('show'),200);
  poses.forEach((id,i)=>{
    const el=document.getElementById(id);
    if(el)setTimeout(()=>el.classList.add('show'),i*180+500);
  });
  // cycle pose highlights
  let activePose=0;
  setInterval(()=>{
    poses.forEach(id=>document.getElementById(id)?.classList.remove('active'));
    activePose=(activePose+1)%3;
    document.getElementById(poses[activePose])?.classList.add('active');
  },2600);
}

/* ── PROMPT PANEL ── */
function initPrompt(){
  const el=document.getElementById('ppTyped');
  const fill=document.getElementById('ppFill');
  const pct=document.getElementById('ppPct');
  const phrases=[
    'Rooftop terrace · golden hour · gold hoop earrings · nude heels · soft warm tones',
    'White minimal studio · clean diffused light · pearl stud earrings · catalog look',
  ];
  let pi=0,ti=null;
  function type(){
    if(!el)return;
    const phrase=phrases[pi++%phrases.length];
    let i=0;el.textContent='';
    if(fill){fill.style.transition='none';fill.style.width='0';}
    if(pct)pct.textContent='0%';
    clearInterval(ti);
    ti=setInterval(()=>{
      el.textContent=phrase.slice(0,++i);
      if(i>=phrase.length){
        clearInterval(ti);
        setTimeout(()=>{
          if(fill){fill.style.transition='width 1.8s cubic-bezier(.22,.85,.44,1)';fill.style.width='100%';}
          if(pct){let v=0;const t2=setInterval(()=>{v=Math.min(v+3,100);pct.textContent=v+'%';if(v>=100){clearInterval(t2);setTimeout(type,2200);}},55);}
        },400);
      }
    },36);
  }
  type();
  document.querySelectorAll('.pp-chip').forEach(c=>c.addEventListener('click',()=>c.classList.toggle('on')));
}

/* ── OUTPUT PANEL ── */
function initOutput(){
  const frames=['opf1','opf2','opf3','opf4'];
  const count=document.getElementById('opCount');
  const dl=document.getElementById('opDl');
  frames.forEach((id,i)=>{
    setTimeout(()=>{
      const el=document.getElementById(id);
      if(el)el.classList.add('show');
      if(count)count.textContent=(i+1)+' image'+(i>0?'s':'');
    },i*220+150);
  });
  if(dl)setTimeout(()=>dl.classList.add('show'),1400);
}

/* pose thumb click */
document.querySelectorAll('.pose-thumb').forEach(t=>{
  t.addEventListener('click',()=>{
    document.querySelectorAll('.pose-thumb').forEach(p=>p.classList.remove('active'));
    t.classList.add('active');
  });
});
</script>
</MainLayout>
