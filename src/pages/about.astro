    const mEl = document.getElementById(id); const [nId, target] = nums[i]; const nEl = document.getElementById(nId);
    if (!mEl || !nEl) return;
    setTimeout(() => { mEl.classList.add('show'); let v = 0; const step = Math.ceil(target / 30); const t = setInterval(() => { v = Math.min(v + step, target); nEl.textContent = v; if (v >= target) clearInterval(t); }, 45); }, 800 + i * 180);
  });
  setTimeout(() => ['hbar1','hbar2','hbar3','hbar4'].forEach(id => document.getElementById(id)?.classList.add('go')), 1400);
  setTimeout(() => document.getElementById('heroOutcome')?.classList.add('show'), 2600);
})();
