---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/pages/school-erp.css';
---

<MainLayout title="School ERP | Nyx Solution" description="Role-based school ERP for principals, teachers, admins, and parents with communication and classroom workflows.">
  <div class="school-erp-page">
    <!-- NAV -->
    <nav id="mainnav">
      <div class="container">
        <div class="nav-inner">
          <div style="display: flex; align-items: center; gap: 0.8rem;">
            <a href="/products" class="back-link" title="Back to Products" style="display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; background: rgba(162, 74, 42, 0.08); color: var(--rust); transition: all 0.2s ease;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            </a>
            <a href="/" class="brand">Nyx Solution</a>
          </div>
          <ul class="nav-links">
            <li><a href="#roles">Roles</a></li>
            <li><a href="#features">Features</a></li>
            <li><a href="#usage">Who uses it</a></li>
            <li><a href="#fit">Is it for you?</a></li>
          </ul>
          <div class="nav-right">
            <button class="nav-toggle" id="nav-toggle" aria-label="Toggle Menu">
              <span class="bar"></span>
              <span class="bar"></span>
            </button>
          </div>

        </div>
      </div>
    </nav>

    <!-- TICKER -->
    <div class="ticker-wrap" aria-hidden="true">
      <div class="ticker-inner">
        <span class="ti">Role-based access</span>
        <span class="ti">Attendance tracking</span>
        <span class="ti">Parent communication</span>
        <span class="ti">Homework management</span>
        <span class="ti">Leave workflows</span>
        <span class="ti">Principal oversight</span>
        <span class="ti">Multi-child dashboards</span>
        <span class="ti">Teacher-parent chat</span>
        <span class="ti">Role-based access</span>
        <span class="ti">Attendance tracking</span>
        <span class="ti">Parent communication</span>
        <span class="ti">Homework management</span>
        <span class="ti">Leave workflows</span>
        <span class="ti">Principal oversight</span>
        <span class="ti">Multi-child dashboards</span>
        <span class="ti">Teacher-parent chat</span>
        <span class="ti">Role-based access</span>
        <span class="ti">Attendance tracking</span>
        <span class="ti">Parent communication</span>
        <span class="ti">Homework management</span>
        <span class="ti">Leave workflows</span>
        <span class="ti">Principal oversight</span>
        <span class="ti">Multi-child dashboards</span>
        <span class="ti">Teacher-parent chat</span>
        <span class="ti">Role-based access</span>
        <span class="ti">Attendance tracking</span>
        <span class="ti">Parent communication</span>
        <span class="ti">Homework management</span>
        <span class="ti">Leave workflows</span>
        <span class="ti">Principal oversight</span>
        <span class="ti">Multi-child dashboards</span>
        <span class="ti">Teacher-parent chat</span>
      </div>
    </div>

    <!-- HERO -->
    <section class="hero">
      <div class="container">
        <div class="hero-grid">

          <div>
            <div class="hero-eyebrow ru">
              <span class="ey-dot"></span>
              <span class="ey-text">Education Product</span>
            </div>
            <h1 class="hero-h1 ru" style="animation-delay:.1s">School operations and<br>parent communication<br>in one <em>role-based</em> system</h1>
            <p class="hero-lead ru" style="animation-delay:.2s">A practical school platform where teaching workflows, leadership visibility, and parent updates stay connected — without the WhatsApp chaos.</p>
            <div class="cta-row ru" style="animation-delay:.3s">
              <a class="btn-g" href="#roles">See How It Works</a>
            </div>
          </div>

          <!-- HERO RIGHT: ROLE SWITCHER WINDOW -->
          <div class="rf" style="animation-delay:.45s;position:relative">
            <div class="role-window">
              <div class="rw-bar">
                <span class="rw-dot rwd-r"></span>
                <span class="rw-dot rwd-y"></span>
                <span class="rw-dot rwd-g"></span>
                <span class="rw-title">School ERP — Role Dashboard</span>
              </div>
              <div class="role-tabs" id="roleTabs">
                <div class="role-tab active" data-role="principal" id="tab-principal">
                  <span class="role-emoji">👩💼</span>Principal
                </div>
                <div class="role-tab" data-role="teacher" id="tab-teacher">
                  <span class="role-emoji">👩🏫</span>Teacher
                </div>
                <div class="role-tab" data-role="parent" id="tab-parent">
                  <span class="role-emoji">👨👧</span>Parent
                </div>
              </div>
              <div class="role-views">
                <!-- PRINCIPAL VIEW -->
                <div class="role-view active" id="view-principal">
                  <div class="pv-stats">
                    <div class="pv-stat">
                      <div class="pv-stat-n" data-target="1240">0</div>
                      <div class="pv-stat-l">Students</div>
                    </div>
                    <div class="pv-stat">
                      <div class="pv-stat-n" data-target="68">0</div>
                      <div class="pv-stat-l">Teachers</div>
                    </div>
                    <div class="pv-stat">
                      <div class="pv-stat-n" data-target="94">0</div>
                      <div class="pv-stat-l">% Attendance</div>
                    </div>
                  </div>
                  <div class="pv-alerts" id="pvAlerts">
                    <div class="pv-alert" id="pa1">
                      <div class="pv-alert-dot" style="background:rgba(46,140,79,.6)"></div>
                      <span>Class 8A attendance marked — 42/44 present</span>
                    </div>
                    <div class="pv-alert" id="pa2">
                      <div class="pv-alert-dot" style="background:rgba(192,120,32,.6)"></div>
                      <span>3 leave requests pending approval</span>
                    </div>
                    <div class="pv-alert" id="pa3">
                      <div class="pv-alert-dot" style="background:rgba(60,90,140,.6)"></div>
                      <span>Parent-teacher chat response rate: 91%</span>
                    </div>
                    <div class="pv-alert" id="pa4">
                      <div class="pv-alert-dot" style="background:rgba(162,74,42,.6)"></div>
                      <span>Annual Day notice sent to 1,240 parents</span>
                    </div>
                  </div>
                </div>

                <!-- TEACHER VIEW -->
                <div class="role-view" id="view-teacher">
                  <div class="cp-header" style="margin-bottom:.6rem">
                    <span class="cp-title">Class 8A — Today's Ops</span>
                    <span class="cp-date" id="todayDate"></span>
                  </div>
                  <div class="tv-grid" id="tvGrid"><!-- JS --></div>
                  <div class="att-summary" style="margin-bottom:.65rem">
                    <div class="att-sum-card"><div class="att-sum-n" style="color:var(--green)">38</div><div class="att-sum-l">Present</div></div>
                    <div class="att-sum-card"><div class="att-sum-n" style="color:var(--rust)">4</div><div class="att-sum-l">Absent</div></div>
                    <div class="att-sum-card"><div class="att-sum-n">2</div><div class="att-sum-l">Leave</div></div>
                  </div>
                  <div class="hw-section">
                    <div class="hw-label">Homework — Class 8A</div>
                    <div class="hw-item" id="hw1"><span>Maths Ch. 7 — Ex 3, 4</span><span class="hw-tag tag-done">Submitted 36</span></div>
                    <div class="hw-item" id="hw2"><span>Science diagrams — Cell biology</span><span class="hw-tag tag-pending">8 pending</span></div>
                    <div class="hw-item" id="hw3"><span>English — Grammar worksheet</span><span class="hw-tag tag-done">All done</span></div>
                  </div>
                </div>

                <!-- PARENT VIEW -->
                <div class="role-view" id="view-parent">
                  <div class="parv-switch">
                    <div class="parv-child-btn active" id="p-child-0">👧 Aarav</div>
                    <div class="parv-child-btn" id="p-child-1">👦 Shreya</div>
                  </div>
                  <div class="parv-info" id="childInfo">
                    <div class="parv-card">
                      <div class="parv-card-label">Attendance</div>
                      <div class="parv-card-val" id="childAtt">94% this month</div>
                    </div>
                    <div class="parv-card">
                      <div class="parv-card-label">Homework</div>
                      <div class="parv-card-val" id="childHw">2 pending</div>
                    </div>
                    <div class="parv-card">
                      <div class="parv-card-label">Class</div>
                      <div class="parv-card-val" id="childClass">8A · Roll 14</div>
                    </div>
                    <div class="parv-card">
                      <div class="parv-card-label">Teacher</div>
                      <div class="parv-card-val" id="childTeacher">Ms. Priya S.</div>
                    </div>
                  </div>
                  <div class="parv-chat">
                    <div class="parv-chat-label">Recent message</div>
                    <div class="ct-bubble t show">
                      <div class="ct-av" style="background:rgba(162,74,42,.1);color:var(--rust)">PS</div>
                      <div class="ct-text">Aarav's science project is due Friday. Please ensure he brings the chart.</div>
                      <div class="ct-time">2:14pm</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="hero-float hf1 rf" style="animation-delay:.9s">
              <svg viewBox="0 0 14 14" fill="none"><path d="M7 1C4.8 1 3 2.8 3 5c0 3 4 8 4 8s4-5 4-8c0-2.2-1.8-4-4-4z" stroke="currentColor" stroke-width="1.3"/></svg>
              4 roles, one platform
            </div>
            <div class="hero-float hf2 rf" style="animation-delay:1.2s">
              <svg viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.3"/><path d="M4.5 7l2 2 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              No WhatsApp groups needed
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- STATS -->
    <div class="stats-bar">
      <div class="stat-cell"><span class="stat-n" data-count="4">0</span><span class="stat-l">User roles in one platform</span></div>
      <div class="stat-cell"><span class="stat-n" data-count="1240">0</span><span class="stat-l">Students managed</span></div>
      <div class="stat-cell"><span class="stat-n" data-count="94">0</span><span class="stat-l">% avg attendance tracked</span></div>
      <div class="stat-cell"><span class="stat-n" data-count="0">0</span><span class="stat-l">WhatsApp groups needed</span></div>
    </div>

    <!-- OVERVIEW DARK -->
    <section class="overview">
      <div class="container">
        <div class="overview-inner">
          <div class="ov-left">
            <span style="font-family:var(--ff-m);font-size:.63rem;font-weight:700;letter-spacing:.17em;text-transform:uppercase;color:#d4906a;background:rgba(162,74,42,.18);border:1px solid rgba(162,74,42,.28);border-radius:999px;padding:.28rem .76rem;display:inline-block">Overview</span>
            <h2 class="sh2" style="color:#f0e0ca;max-width:none;margin-top:.9rem">One platform. <em>Four roles.</em><br>Everything connected.</h2>
            <p>School ERP is a role-based school operations and communication platform with access paths for Admin, Principal, Teacher, and Parent users.</p>
            <p>It connects classroom workflows and parent communication so student updates, tasks, attendance, and announcements stay synchronized — without fragmented tools or WhatsApp chains.</p>
          </div>
          <div id="archVis">
            <div class="arch-hub" id="archHub">🏫 &nbsp; School ERP Platform</div>
            <div class="arch-connector"><div class="arch-connector-line" id="archLine"></div></div>
            <div class="arch-roles">
              <div class="arch-role" id="ar1"><span class="arch-role-emoji">👩💼</span><span class="arch-role-name">Principal</span></div>
              <div class="arch-role" id="ar2"><span class="arch-role-emoji">🧑💻</span><span class="arch-role-name">Admin</span></div>
              <div class="arch-role" id="ar3"><span class="arch-role-emoji">👩🏫</span><span class="arch-role-name">Teacher</span></div>
              <div class="arch-role" id="ar4"><span class="arch-role-emoji">👨👧</span><span class="arch-role-name">Parent</span></div>
            </div>
            <div class="arch-perm-bars" style="margin-top:.65rem">
              <div class="arch-perm">
                <div class="arch-perm-label">Full access</div>
                <div class="arch-perm-bar"><div class="arch-perm-fill" id="ab1" style="background:rgba(46,140,79,.6)" data-w="100%"></div></div>
                <div class="arch-perm-val">100%</div>
              </div>
              <div class="arch-perm">
                <div class="arch-perm-label">Ops control</div>
                <div class="arch-perm-bar"><div class="arch-perm-fill" id="ab2" style="background:rgba(60,90,140,.5)" data-w="85%"></div></div>
                <div class="arch-perm-val">85%</div>
              </div>
              <div class="arch-perm">
                <div class="arch-perm-label">Class scope</div>
                <div class="arch-perm-bar"><div class="arch-perm-fill" id="ab3" style="background:rgba(162,74,42,.5)" data-w="60%"></div></div>
                <div class="arch-perm-val">60%</div>
              </div>
              <div class="arch-perm">
                <div class="arch-perm-label">Child view</div>
                <div class="arch-perm-bar"><div class="arch-perm-fill" id="ab4" style="background:rgba(107,60,140,.5)" data-w="35%"></div></div>
                <div class="arch-perm-val">35%</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FEATURE ROWS -->
    <section class="feat-section" id="roles">
      <div class="container">

        <!-- 1: Role-based access → PERMISSION MATRIX -->
        <div class="feat-row">
          <div class="fcp ru">
            <span class="eyebrow">Role-based access architecture</span>
            <h2 class="sh2">Different roles.<br><em>Different views.</em><br>One platform.</h2>
            <p>Every user sees only what they need. Principal and Admin have broader control while Teachers and Parents operate within their relevant scope — no information overload, no missed context.</p>
            <ul class="bl">
              <li>Principal sees all modules, all classes, all activity</li>
              <li>Admin controls school-wide setup and communication flow</li>
              <li>Teachers operate within their assigned classes</li>
              <li>Parents see only their children's data</li>
            </ul>
          </div>
          <div class="fil rf" style="animation-delay:.1s">
            <div class="illu perm-panel" id="permPanel">
              <div class="pp-title">Permission matrix — who accesses what</div>
              <table class="perm-table">
                <thead>
                  <tr>
                    <th>Module</th>
                    <th>Principal</th>
                    <th>Admin</th>
                    <th>Teacher</th>
                    <th>Parent</th>
                  </tr>
                </thead>
                <tbody id="permBody">
                  <!-- JS fills this -->
                </tbody>
              </table>
              <div class="perm-legend">
                <div class="perm-leg"><div class="perm-leg-dot" style="background:rgba(46,140,79,.2);border:2px solid rgba(46,140,79,.5)"></div>Full access</div>
                <div class="perm-leg"><div class="perm-leg-dot" style="background:rgba(192,120,32,.15);border:2px solid rgba(192,120,32,.45)"></div>Partial</div>
                <div class="perm-leg"><div class="perm-leg-dot" style="background:rgba(162,74,42,.08);border:2px solid rgba(162,74,42,.2)"></div>No access</div>
              </div>
            </div>
          </div>
        </div>

        <!-- 2: Teacher ops → ATTENDANCE + HOMEWORK -->
        <div class="feat-row rv">
          <div class="fcp ru">
            <span class="eyebrow">Daily classroom operations</span>
            <h2 class="sh2">Every classroom task<br>in one <em>teacher workflow</em></h2>
            <p>Attendance, homework, class notes, and announcements live in one consistent daily flow. Teachers don't need to switch between systems or chase parents on WhatsApp to communicate updates.</p>
            <ul class="bl">
              <li>Mark attendance with one tap per student</li>
              <li>Assign homework and track submission status</li>
              <li>Post class announcements visible to all parents</li>
              <li>Manage leave requests without email chains</li>
            </ul>
          </div>
          <div class="fil rf" style="animation-delay:.1s">
            <div class="illu class-panel" id="classPanel">
              <div class="cp-header">
                <span class="cp-title">Class 9B — Monday Operations</span>
                <span class="cp-date">Mon, 21 Apr 2025</span>
              </div>
              <div style="font-family:var(--ff-m);font-size:.6rem;color:var(--ink-lt);margin-bottom:.3rem;text-transform:uppercase;letter-spacing:.08em">Attendance · 36 students</div>
              <div class="att-grid" id="attGrid"><!-- JS --></div>
              <div class="att-summary" style="margin-bottom:.65rem">
                <div class="att-sum-card"><div class="att-sum-n" style="color:var(--green)">32</div><div class="att-sum-l">Present</div></div>
                <div class="att-sum-card"><div class="att-sum-n" style="color:var(--rust)">3</div><div class="att-sum-l">Absent</div></div>
                <div class="att-sum-card"><div class="att-sum-n" style="color:var(--amber)">1</div><div class="att-sum-l">Leave</div></div>
              </div>
              <div class="hw-section">
                <div class="hw-label">Today's homework</div>
                <div class="hw-item" id="chw1"><span>Maths — Ch 8, Ex 2 (Q1–5)</span><span class="hw-tag tag-done">Assigned ✓</span></div>
                <div class="hw-item" id="chw2"><span>Science — Lab report write-up</span><span class="hw-tag tag-pending">Due Friday</span></div>
              </div>
            </div>
          </div>
        </div>

        <!-- 3: Parent communication → CHAT THREAD -->
        <div class="feat-row">
          <div class="fcp ru">
            <span class="eyebrow">Parent-school communication</span>
            <h2 class="sh2">Families stay connected.<br><em>Without the noise.</em></h2>
            <p>Give families a clear, continuous window into student progress and class updates — through an organized platform, not a 500-message WhatsApp group. Every message is contextual and visible to the right people.</p>
            <ul class="bl">
              <li>Direct teacher-parent messaging per child</li>
              <li>Class-wide announcements and event notices</li>
              <li>Homework updates automatically visible to parents</li>
              <li>Attendance reports accessible anytime</li>
            </ul>
          </div>
          <div class="fil rf" style="animation-delay:.1s">
            <div class="illu chat-panel" id="chatPanel">
              <div class="cp-chat-header">
                <div class="cp-chat-avatar" style="background:rgba(162,74,42,.1);color:var(--rust)">PS</div>
                <div>
                  <div class="cp-chat-name">Ms. Priya Sharma</div>
                  <div class="cp-chat-role">Class Teacher · 9B</div>
                </div>
                <div class="cp-chat-live"><div class="cp-chat-live-dot"></div>Active now</div>
              </div>
              <div class="chat-thread" id="chatThread">
                <!-- JS fills bubbles -->
              </div>
              <div class="ct-notif" id="chatNotif">
                <span>📋</span>
                <span>Class test scheduled — Friday, 25 Apr · Science Ch. 5 &amp; 6</span>
              </div>
            </div>
          </div>
        </div>

        <!-- 4: Child-first parent UX → CHILD SWITCHER -->
        <div class="feat-row rv">
          <div class="fcp ru">
            <span class="eyebrow">Child-first parent experience</span>
            <h2 class="sh2">Two children.<br>One dashboard.<br><em>No confusion.</em></h2>
            <p>Parents with more than one child can switch between profiles instantly and see each child's attendance, homework, and messages without losing context — everything updates for the selected child.</p>
            <ul class="bl">
              <li>Switch between children with one tap</li>
              <li>Attendance, homework, and messages update per child</li>
              <li>Submit leave requests for the selected child</li>
              <li>View birthday notifications and school events</li>
            </ul>
          </div>
          <div class="fil rf" style="animation-delay:.1s">
            <div class="illu child-panel" id="childPanel">
              <div class="child-tabs">
                <div class="child-tab active" id="ctab0">
                  <span class="child-tab-emoji">👧</span>
                  <span class="child-tab-name">Aarav · 9B</span>
                </div>
                <div class="child-tab" id="ctab1">
                  <span class="child-tab-emoji">👦</span>
                  <span class="child-tab-name">Shreya · 6A</span>
                </div>
              </div>
              <div class="child-data" id="childData">
                <div class="child-stat-row">
                  <div class="child-stat"><div class="child-stat-n" id="cds-att">94%</div><div class="child-stat-l">Attendance</div></div>
                  <div class="child-stat"><div class="child-stat-n" id="cds-hw">2</div><div class="child-stat-l">Pending HW</div></div>
                  <div class="child-stat"><div class="child-stat-n" id="cds-msg">1</div><div class="child-stat-l">New msg</div></div>
                </div>
                <div class="child-hw-list">
                  <div class="child-hw-item" id="cdh1"><span>Maths — Ch 8 Ex 2</span><span class="hw-tag tag-pending">Pending</span></div>
                  <div class="child-hw-item" id="cdh2"><span>Science — Lab report</span><span class="hw-tag tag-done">Done ✓</span></div>
                </div>
                <div class="child-leave-form">
                  <div class="clf-icon">📄</div>
                  <div class="clf-text"><strong id="clf-name">Aarav</strong> — Leave request for 24 Apr</div>
                  <div class="clf-btn">Submit</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 5: Admin transparency → ADMIN DASHBOARD -->
        <div class="feat-row">
          <div class="fcp ru">
            <span class="eyebrow">Operational transparency</span>
            <h2 class="sh2">Leadership sees<br>everything. <em>In real time.</em></h2>
            <p>Principals and admins get live visibility into how classes and communication are running — attendance rates, pending leave requests, homework coverage, and parent engagement — without asking anyone for a report.</p>
            <ul class="bl">
              <li>School-wide attendance and class status at a glance</li>
              <li>Pending leave approvals with full context</li>
              <li>Teacher-parent communication health metrics</li>
              <li>Homework coverage across classes and grades</li>
            </ul>
          </div>
          <div class="fil rf" style="animation-delay:.1s">
            <div class="illu admin-panel" id="adminPanel">
              <div class="ap-header">
                <span class="ap-title">Principal Dashboard — Live</span>
                <div class="ap-live"><div class="ap-live-dot"></div>Realtime</div>
              </div>
              <div class="ap-grid">
                <div class="ap-card"><div class="ap-card-n" id="apn1">0</div><div class="ap-card-l">Students</div></div>
                <div class="ap-card"><div class="ap-card-n" id="apn2">0</div><div class="ap-card-l">Teachers active</div></div>
              </div>
              <div class="ap-bar-row" id="apBars">
                <div class="ap-bar-item"><span class="ap-bar-label">Attendance</span><div class="ap-bar-track"><div class="ap-bar-fill" id="apb1" data-w="94%"></div></div><span class="ap-bar-pct">94%</span></div>
                <div class="ap-bar-item"><span class="ap-bar-label">HW coverage</span><div class="ap-bar-track"><div class="ap-bar-fill" id="apb2" data-w="88%"></div></div><span class="ap-bar-pct">88%</span></div>
                <div class="ap-bar-item"><span class="ap-bar-label">Parent comm.</span><div class="ap-bar-track"><div class="ap-bar-fill" id="apb3" data-w="91%"></div></div><span class="ap-bar-pct">91%</span></div>
              </div>
              <div class="ap-notif-row">
                <div class="ap-notif" id="an1"><div class="ap-notif-dot" style="background:rgba(46,140,79,.6)"></div><span>32 of 34 classes have marked attendance</span></div>
