  <script is:inline>
    /* ── NAV ── */
    const nav = document.getElementById('mainnav');
    window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', scrollY > 40), { passive: true });

    /* ── HERO ROLE SWITCHER ── */
    const childData = [
      {att:'94% this month',hw:'2 pending',cls:'9B · Roll 14',teacher:'Ms. Priya S.'},
      {att:'88% this month',hw:'0 pending',cls:'6A · Roll 07',teacher:'Mr. Arjun N.'}
    ];
    let activeChild = 0;

    function switchRole(role) {
      document.querySelectorAll('.role-tab').forEach(t => t.classList.toggle('active', t.dataset.role === role));
      document.querySelectorAll('.role-view').forEach(v => v.classList.toggle('active', v.id === 'view-' + role));
      if (role === 'teacher') initTeacherView();
      if (role === 'parent') initParentView();
    }

    function switchChild(idx) {
      activeChild = idx;
      document.querySelectorAll('.parv-child-btn').forEach((b, i) => {
        if (i === idx) b.classList.add('active');
        else b.classList.remove('active');
      });
      const d = childData[idx];
      const childAtt = document.getElementById('childAtt');
      const childHw = document.getElementById('childHw');
      const childClass = document.getElementById('childClass');
      const childTeacher = document.getElementById('childTeacher');
      if (childAtt) childAtt.textContent = d.att;
      if (childHw) childHw.textContent = d.hw;
      if (childClass) childClass.textContent = d.cls;
      if (childTeacher) childTeacher.textContent = d.teacher;
    }

    // Attach events to role tabs
    document.getElementById('tab-principal')?.addEventListener('click', () => switchRole('principal'));
    document.getElementById('tab-teacher')?.addEventListener('click', () => switchRole('teacher'));
    document.getElementById('tab-parent')?.addEventListener('click', () => switchRole('parent'));

    // Attach events to child switchers in hero
    document.getElementById('p-child-0')?.addEventListener('click', () => switchChild(0));
    document.getElementById('p-child-1')?.addEventListener('click', () => switchChild(1));

    // Auto-cycle role tabs in hero
    let heroRoleIdx = 0;
    const heroRoles = ['principal','teacher','parent'];
    setInterval(() => {
      heroRoleIdx = (heroRoleIdx + 1) % heroRoles.length;
      switchRole(heroRoles[heroRoleIdx]);
    }, 4200);

    function initTeacherView() {
      const grid = document.getElementById('tvGrid');
      if (!grid || grid.dataset.built) return;
      grid.dataset.built = 'true';
      const states = Array(30).fill('p').concat(Array(4).fill('a')).sort(() => Math.random() - .5);
      states.forEach((s, i) => {
        const c = document.createElement('div');
        c.className = 'tv-cell';
        grid.appendChild(c);
        setTimeout(() => { c.classList.add(s); c.textContent = s === 'p' ? '✓' : '✗'; }, i * 40);
      });
      ['hw1','hw2','hw3'].forEach((id, i) => {
        setTimeout(() => { const el = document.getElementById(id); if (el) el.classList.add('show'); }, i * 180 + 400);
      });
    }

    function initParentView() {}

    // Set today's date
    const d = new Date();
    const dateStr = d.toLocaleDateString('en-IN',{weekday:'short',day:'numeric',month:'short',year:'numeric'});
    const dateEl = document.getElementById('todayDate'); if (dateEl) dateEl.textContent = dateStr;

    // Principal alerts
    ['pa1','pa2','pa3','pa4'].forEach((id,i) => {
      setTimeout(() => { const e = document.getElementById(id); if(e) e.classList.add('show'); }, i*220+200);
    });

    /* ── HERO STATS COUNT-UP ── */
    document.querySelectorAll('[data-target]').forEach(el => {
      const t = +el.dataset.target, t0 = performance.now();
      const tick = now => {
        const p = Math.min((now-t0)/1400,1), v = Math.round((1-Math.pow(1-p,3))*t);
        el.textContent = v; if(p<1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    });

    /* ── INTERSECTION OBSERVER ── */
    const seen = new Set();
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting || seen.has(e.target)) return;
        seen.add(e.target);
        e.target.classList.add('iv');
        const id = e.target.id;
        if (id === 'archVis') initArch();
        if (id === 'permPanel') initPerm();
        if (id === 'classPanel') initClass();
        if (id === 'chatPanel') initChat();
        if (id === 'childPanel') initChild();
        if (id === 'adminPanel') initAdmin();
        if (id === 'leavePanel') initLeave();
        if (id === 'uc1'||id==='uc2'||id==='uc3') e.target.classList.add('show');
        if (id?.startsWith('fg')) e.target.classList.add('show');
        if (id?.startsWith('fs')) e.target.classList.add('show');
        if (id === 'ctaCard') e.target.classList.add('show');
        io.unobserve(e.target);
      });
    }, {threshold:.12, rootMargin:'0px 0px -40px 0px'});

    document.querySelectorAll(
      '.hs,.fit-item,#archVis,#permPanel,#classPanel,#chatPanel,#childPanel,#adminPanel,#leavePanel,#uc1,#uc2,#uc3,#fg1,#fg2,#fg3,#fg4,#fg5,#fg6,#fs1,#fs2,#fs3,#ctaCard'
    ).forEach(el => io.observe(el));

    /* COUNT UP */
    const cio = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const el = e.target, tgt = +el.dataset.count;
        let v=0; const step=Math.ceil(tgt/40);
        const t = setInterval(() => { v=Math.min(v+step,tgt); el.textContent=v; if(v>=tgt) clearInterval(t); }, 35);
        cio.unobserve(el);
      });
    },{threshold:.5});
    document.querySelectorAll('[data-count]').forEach(el => cio.observe(el));

    /* ── ARCH OVERVIEW ── */
    function initArch() {
      const hub = document.getElementById('archHub'); if(hub) setTimeout(()=>hub.classList.add('show'),100);
      const line = document.getElementById('archLine'); if(line) setTimeout(()=>line.classList.add('show'),450);
      ['ar1','ar2','ar3','ar4'].forEach((id,i) => {
        const el = document.getElementById(id);
        if(el) setTimeout(()=>el.classList.add('show'), 600+i*140);
      });
      ['ab1','ab2','ab3','ab4'].forEach((id,i) => {
        const el = document.getElementById(id);
        if(el) setTimeout(()=>{ el.style.width=el.dataset.w; }, 900+i*120);
      });
    }

    /* ── PERMISSION MATRIX ── */
    function initPerm() {
      const modules = ['Attendance','Homework','Leave approval','Announcements','Parent chat','Reports'];
      const perms = [
        ['full','full','full','full'],
        ['full','full','full','part'],
        ['full','full','part','none'],
        ['full','full','full','part'],
        ['full','full','full','full'],
        ['full','full','none','none'],
      ];
      const tbody = document.getElementById('permBody');
      if (!tbody) return;
      modules.forEach((mod, ri) => {
        const tr = document.createElement('tr');
        tr.innerHTML = `<td>${mod}</td>` + perms[ri].map(p =>
          `<td><div class="perm-dot ${p}"></div></td>`
        ).join('');
        tbody.appendChild(tr);
      });
      setTimeout(() => {
        document.querySelectorAll('.perm-dot').forEach((d,i) => {
          setTimeout(() => d.classList.add('show'), i * 55);
        });
      }, 200);
    }

    /* ── CLASS PANEL ── */
    function initClass() {
      const g = document.getElementById('attGrid'); if(!g||g.dataset.b) return; g.dataset.b='1';
      const s = Array(28).fill('p').concat(Array(3).fill('a')).concat(['a']).sort(()=>Math.random()-.5);
      s.forEach((st,i)=>{
        const c=document.createElement('div'); c.className='att-cell'; g.appendChild(c);
        setTimeout(()=>{ c.classList.add(st); c.textContent=st==='p'?'✓':'✗'; },i*45+100);
      });
      ['chw1','chw2'].forEach((id,i)=>{ setTimeout(()=>{ const e=document.getElementById(id); if(e)e.classList.add('show'); },1200+i*200); });
    }

    /* ── CHAT PANEL ── */
    function initChat() {
      const thread = document.getElementById('chatThread');
      if (!thread || thread.dataset.b) return; thread.dataset.b = '1';
      const messages = [
        {role:'t',text:"Good morning! Aarav submitted yesterday's science project. Well done 👍",time:"9:02 AM"},
        {role:'par',text:"Thank you, Ms. Priya! He worked on it all weekend.",time:"9:18 AM"},
        {role:'t',text:"There's a class test on Friday — Chapters 5 & 6. Please ensure he revises.",time:"9:20 AM"},
        {role:'par',text:"Will do! Can I submit a leave for Thursday? Family function.",time:"10:05 AM"},
      ];
      messages.forEach((m, i) => {
        setTimeout(() => {
          const div = document.createElement('div');
          div.className = `ct-bubble ${m.role==='t'?'t':'par'} show`;
          if (m.role === 't') {
            div.innerHTML = `<div class="ct-av" style="background:rgba(162,74,42,.1);color:var(--rust)">PS</div><div class="ct-text">${m.text}</div><div class="ct-time">${m.time}</div>`;
          } else {
            div.innerHTML = `<div class="ct-time">${m.time}</div><div class="ct-text">${m.text}</div><div class="ct-av" style="background:rgba(60,90,140,.12);color:var(--blue)">AM</div>`;
          }
          thread.appendChild(div);
        }, i * 600 + 200);
      });
      setTimeout(() => {
        const n = document.getElementById('chatNotif'); if(n) n.classList.add('show');
      }, 3200);
    }

    /* ── CHILD PANEL ── */
    const panelChildData = [
      {att:'94%',hw:'2',msg:'1',h1:'Maths — Ch 8 Ex 2',h2:'Science — Lab report',h1tag:'tag-pending',h2tag:'tag-done',name:'Aarav'},
      {att:'88%',hw:'0',msg:'3',h1:'English — Ch 4 summary',h2:'Maths — Fractions worksheet',h1tag:'tag-done',h2tag:'tag-pending',name:'Shreya'}
    ];
    let currentPanelChild = 0;

    function switchChildPanel(idx) {
      if (currentPanelChild === idx) return;
      currentPanelChild = idx;
      document.querySelectorAll('.child-tab').forEach((t,i)=>t.classList.toggle('active',i===idx));
      const data = document.getElementById('childData');
      if (data) data.classList.add('switching');
      setTimeout(() => {
        const d = panelChildData[idx];
        const att = document.getElementById('cds-att'); if(att) att.textContent = d.att;
        const hw = document.getElementById('cds-hw'); if(hw) hw.textContent = d.hw;
        const msg = document.getElementById('cds-msg'); if(msg) msg.textContent = d.msg;
        const h1 = document.getElementById('cdh1'); if(h1) h1.querySelector('span').textContent = d.h1;
        const h2 = document.getElementById('cdh2'); if(h2) h2.querySelector('span').textContent = d.h2;
        const tag1 = document.querySelector('#cdh1 .hw-tag'); if(tag1){ tag1.className='hw-tag '+d.h1tag; tag1.textContent=d.h1tag==='tag-done'?'Done ✓':'Pending'; }
        const tag2 = document.querySelector('#cdh2 .hw-tag'); if(tag2){ tag2.className='hw-tag '+d.h2tag; tag2.textContent=d.h2tag==='tag-done'?'Done ✓':'Pending'; }
        const name = document.getElementById('clf-name'); if(name) name.textContent = d.name;
        if (data) data.classList.remove('switching');
      }, 220);
    }

    function initChild() {
      // Attach events to child tabs in features section
      document.getElementById('ctab0')?.addEventListener('click', () => switchChildPanel(0));
      document.getElementById('ctab1')?.addEventListener('click', () => switchChildPanel(1));

      // auto-cycle children every 3s
      setInterval(() => {
        currentPanelChild = (currentPanelChild + 1) % 2;
        switchChildPanel(currentPanelChild);
      }, 3000);
    }

    /* ── ADMIN PANEL ── */
    function initAdmin() {
      let n1=0,n2=0;
      const t1=setInterval(()=>{ n1=Math.min(n1+32,1240); const e=document.getElementById('apn1'); if(e)e.textContent=n1; if(n1>=1240)clearInterval(t1); },30);
      const t2=setInterval(()=>{ n2=Math.min(n2+2,68); const e=document.getElementById('apn2'); if(e)e.textContent=n2; if(n2>=68)clearInterval(t2); },45);
      setTimeout(()=>{
        ['apb1','apb2','apb3'].forEach(id=>{ const el=document.getElementById(id); if(el) el.style.width=el.dataset.w; });
      }, 400);
      ['an1','an2','an3'].forEach((id,i)=>{
        setTimeout(()=>{ const el=document.getElementById(id); if(el)el.classList.add('show'); }, 600+i*220);
      });
    }

    /* ── LEAVE PANEL ── */
    function initLeave() {
      const form = document.getElementById('leaveForm');
      const track = document.getElementById('leaveTrack');
      if (form) setTimeout(()=>form.classList.add('show'), 200);
      if (track) setTimeout(()=>track.classList.add('show'), 500);
      // animate stages
      const stages = ['ls1','ls2','ls3','ls4'];
      const statusEl = document.getElementById('leaveStatus');
      const lt2 = document.getElementById('lt2');
      const lt3 = document.getElementById('lt3');
      const statusTexts = ['Submitted','Teacher reviewing…','Principal approval…','Approved ✓'];
      const statusColors = ['var(--rust)','var(--amber)','var(--blue)','var(--green)'];

      let step = 0;
      function advanceLeave() {
        stages.forEach((id,i) => {
          const el = document.getElementById(id);
          if (!el) return;
          if (i < step) {
            el.classList.add('done');
            el.classList.remove('active');
          } else if (i === step) {
            el.classList.remove('done');
            el.classList.add('active');
          } else {
            el.classList.remove('done','active');
          }
        });
        if (statusEl) { statusEl.textContent = statusTexts[step]; statusEl.style.color = statusColors[step]; }
        if (lt2) lt2.style.opacity = step >= 1 ? '1' : '.3';
        if (lt3) lt3.style.opacity = step >= 2 ? '1' : '.15';
        step = (step + 1) % 4;
        setTimeout(advanceLeave, 1800);
      }
      setTimeout(advanceLeave, 800);
    }
  </script>
</MainLayout>
