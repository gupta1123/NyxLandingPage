---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/pages/sales-tracking.css';
---

<MainLayout title="Sales Tracking | Nyx Solutions" description="Field sales tracking built for on-ground execution visibility.">
  <div class="sales-page">

    <!-- NAV -->
    <nav id="mainnav">
      <div class="nav-left">
        <a class="nav-back" href="/products" aria-label="Back to products">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        </a>
        <span class="nav-logo">Nyx Solutions</span>
      </div>
      <ul class="nav-links">
        <li><a href="#tracking">Tracking</a></li>
        <li><a href="#attendance">Attendance</a></li>
        <li><a href="#expenses">Expenses</a></li>
        <li><a href="#reporting">Reporting</a></li>
      </ul>

    </nav>

    <!-- TICKER -->
    <div class="ticker-wrap" aria-hidden="true">
      <div class="ticker">
        <span class="ticker-item">Visit tracking</span><span class="ticker-item">Attendance accountability</span><span class="ticker-item">Expense workflows</span><span class="ticker-item">Location trails</span><span class="ticker-item">Operational reporting</span><span class="ticker-item">Manager oversight</span><span class="ticker-item">Mobile-first inputs</span><span class="ticker-item">Route coverage</span><span class="ticker-item">Visit tracking</span><span class="ticker-item">Attendance accountability</span><span class="ticker-item">Expense workflows</span><span class="ticker-item">Location trails</span><span class="ticker-item">Operational reporting</span><span class="ticker-item">Manager oversight</span><span class="ticker-item">Mobile-first inputs</span><span class="ticker-item">Route coverage</span>
      </div>
    </div>

    <!-- ═══ HERO ═══ -->
    <section class="bd-hero">
      <div class="container">
        <div class="bd-hero__grid">
          <div>
            <div class="bd-hero__eyebrow reveal-up">
              <span class="eyebrow-dot"></span>
              <span class="eyebrow-text">Field Operations Product</span>
            </div>
            <h1 class="bd-hero__h1 reveal-up" style="animation-delay:.1s">
              Field sales tracking built for<br /><em>on-ground execution</em> visibility.
            </h1>
            <p class="bd-hero__lead reveal-up" style="animation-delay:.2s">
              A web and mobile system for organizations that need to monitor visits, attendance, movement, and expenses with operational clarity — not just monthly reports.
            </p>
            <div class="cta-row reveal-up" style="animation-delay:.3s">
              <a class="btn ghost" href="#tracking">See Platform</a>
            </div>
          </div>

          <!-- HERO MAP -->
          <div class="hero-map-wrap reveal-fade" style="animation-delay:.45s">
            <div class="hero-map">
              <svg viewBox="0 0 420 300" xmlns="http://www.w3.org/2000/svg">
                <!-- road grid -->
                <rect width="420" height="300" fill="#f7f1e8" />
                <!-- horizontal roads -->
                <line x1="0" y1="75" x2="420" y2="75" stroke="#e2d5c4" stroke-width="8" />
                <line x1="0" y1="150" x2="420" y2="150" stroke="#e2d5c4" stroke-width="8" />
                <line x1="0" y1="225" x2="420" y2="225" stroke="#e2d5c4" stroke-width="8" />
                <!-- vertical roads -->
                <line x1="90" y1="0" x2="90" y2="300" stroke="#e2d5c4" stroke-width="8" />
                <line x1="210" y1="0" x2="210" y2="300" stroke="#e2d5c4" stroke-width="8" />
                <line x1="330" y1="0" x2="330" y2="300" stroke="#e2d5c4" stroke-width="8" />
                <!-- blocks shading -->
                <rect x="10" y="10" width="68" height="53" rx="3" fill="#ede6d8" opacity=".7" />
                <rect x="100" y="10" width="98" height="53" rx="3" fill="#ede6d8" opacity=".7" />
                <rect x="220" y="10" width="98" height="53" rx="3" fill="#ede6d8" opacity=".7" />
                <rect x="340" y="10" width="70" height="53" rx="3" fill="#ede6d8" opacity=".5" />
                <rect x="10" y="85" width="68" height="53" rx="3" fill="#ede6d8" opacity=".5" />
                <rect x="100" y="85" width="98" height="53" rx="3" fill="#ede6d8" opacity=".7" />
                <rect x="220" y="85" width="98" height="53" rx="3" fill="#ede6d8" opacity=".5" />
                <rect x="340" y="85" width="70" height="53" rx="3" fill="#ede6d8" opacity=".7" />
                <rect x="10" y="160" width="68" height="53" rx="3" fill="#ede6d8" opacity=".7" />
                <rect x="100" y="160" width="98" height="53" rx="3" fill="#ede6d8" opacity=".5" />
                <rect x="220" y="160" width="98" height="53" rx="3" fill="#ede6d8" opacity=".7" />
                <rect x="340" y="160" width="70" height="53" rx="3" fill="#ede6d8" opacity=".5" />
                <rect x="10" y="235" width="68" height="55" rx="3" fill="#ede6d8" opacity=".5" />
                <rect x="100" y="235" width="98" height="55" rx="3" fill="#ede6d8" opacity=".7" />
                <rect x="220" y="235" width="98" height="55" rx="3" fill="#ede6d8" opacity=".5" />
                <rect x="340" y="235" width="70" height="55" rx="3" fill="#ede6d8" opacity=".7" />
                <!-- route trail -->
                <polyline points="44,112 44,75 150,75 150,37 265,37 265,75 375,75 375,112 375,150 265,150 265,187 150,187 150,225 265,225" fill="none" stroke="#c0521f" stroke-width="2.5" stroke-dasharray="200" stroke-linecap="round" stroke-linejoin="round" style="stroke-dashoffset:200;animation:trailDraw 2.2s cubic-bezier(.4,0,.2,1) .6s forwards" />
                <!-- ripple rings -->
                <circle cx="44" cy="112" r="9" fill="none" stroke="#c0521f" stroke-width="1.5" style="animation:ripple 2s ease-out .3s infinite" />
                <circle cx="150" cy="37" r="9" fill="none" stroke="#c0521f" stroke-width="1.5" style="animation:ripple 2s ease-out .9s infinite" />
                <circle cx="265" cy="75" r="9" fill="none" stroke="#c0521f" stroke-width="1.5" style="animation:ripple 2s ease-out 1.5s infinite" />
                <circle cx="375" cy="150" r="9" fill="none" stroke="#c0521f" stroke-width="1.5" style="animation:ripple 2s ease-out 2.1s infinite" />
                <circle cx="265" cy="225" r="9" fill="none" stroke="#c0521f" stroke-width="1.5" style="animation:ripple 2s ease-out 2.7s infinite" />
                <!-- pins -->
                <g style="opacity:0;animation:pinDrop .5s cubic-bezier(.34,1.56,.64,1) .8s forwards">
                  <circle cx="44" cy="112" r="7" fill="#c0521f" />
                  <circle cx="44" cy="112" r="3.5" fill="#fff" />
                </g>
                <g style="opacity:0;animation:pinDrop .5s cubic-bezier(.34,1.56,.64,1) 1.2s forwards">
                  <circle cx="150" cy="37" r="7" fill="#c0521f" />
                  <circle cx="150" cy="37" r="3.5" fill="#fff" />
                </g>
                <g style="opacity:0;animation:pinDrop .5s cubic-bezier(.34,1.56,.64,1) 1.6s forwards">
                  <circle cx="265" cy="75" r="7" fill="#2e8c4f" />
                  <circle cx="265" cy="75" r="3.5" fill="#fff" />
                </g>
                <g style="opacity:0;animation:pinDrop .5s cubic-bezier(.34,1.56,.64,1) 2.0s forwards">
                  <circle cx="375" cy="150" r="7" fill="#c0521f" />
                  <circle cx="375" cy="150" r="3.5" fill="#fff" />
                </g>
                <g style="opacity:0;animation:pinDrop .5s cubic-bezier(.34,1.56,.64,1) 2.4s forwards">
                  <circle cx="265" cy="225" r="8" fill="#c07820" />
                  <circle cx="265" cy="225" r="3.5" fill="#fff" />
                  <!-- active rep dot -->
                  <circle cx="265" cy="225" r="13" fill="none" stroke="#c07820" stroke-width="1.5" style="animation:ripple 2s ease-out infinite" />
                </g>
                <!-- label chips -->
                <g style="opacity:0;animation:pinDrop .4s ease 1.8s forwards">
                  <rect x="274" y="66" width="56" height="16" rx="8" fill="rgba(46,140,79,.9)" />
                  <text x="302" y="77.5" text-anchor="middle" font-size="8" font-family="Sora,sans-serif" fill="#fff" font-weight="600">Visited</text>
                </g>
                <g style="opacity:0;animation:pinDrop .4s ease 2.6s forwards">
                  <rect x="274" y="216" width="62" height="16" rx="8" fill="rgba(192,120,32,.9)" />
                  <text x="305" y="227.5" text-anchor="middle" font-size="8" font-family="Sora,sans-serif" fill="#fff" font-weight="600">En route</text>
                </g>
              </svg>
            </div>
            <div class="h-badge h-badge--1 reveal-fade" style="animation-delay:.9s">
              <svg viewBox="0 0 14 14" fill="none"><path d="M7 1C4.8 1 3 2.8 3 5c0 3 4 8 4 8s4-5 4-8c0-2.2-1.8-4-4-4z" stroke="currentColor" stroke-width="1.3" fill="rgba(192,82,31,.15)" /></svg>
              Live route tracking
            </div>
            <div class="h-badge h-badge--2 reveal-fade" style="animation-delay:1.1s">
              <svg viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.2" /><path d="M4.5 7l2 2 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" /></svg>
              5 reps · 84% done
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- STATS -->
    <div class="stats-strip">
      <div class="stat-item"><span class="stat-num" data-count="100">0</span><span class="stat-label">% field execution visibility</span></div>
      <div class="stat-item"><span class="stat-num" data-count="2">0</span><span class="stat-label">platforms — web + mobile</span></div>
      <div class="stat-item"><span class="stat-num" data-count="6">0</span><span class="stat-label">core capability modules</span></div>
      <div class="stat-item"><span class="stat-num" data-count="5">0</span><span class="stat-label">industry verticals served</span></div>
    </div>

    <!-- ═══ FEATURES — alternating rows ═══ -->
    <section style="padding:4rem 0 2rem">
      <div class="container">

        <!-- 1 · VISIT & ROUTE TRACKING -->
        <div class="feat-row" id="tracking">
          <div class="feat-copy reveal-up">
            <span class="eyebrow">Visit &amp; route tracking</span>
            <h2 class="sh2">Know exactly where your team goes — <em>and what they complete</em></h2>
            <p>Capture where field teams go, what they complete, and how consistently routes are covered. Every store visit is logged with timestamp, location, and outcome — no manual updates needed.</p>
            <ul class="bullet-list">
              <li>View visit history for each salesperson</li>
              <li>Monitor location trails and coverage by day</li>
              <li>Compare planned versus completed visits in real time</li>
            </ul>
          </div>
          <div class="feat-illu reveal-fade" style="animation-delay:.1s">
            <div class="illu-panel map-panel" id="routeMap">
              <svg viewBox="0 0 380 260" xmlns="http://www.w3.org/2000/svg">
                <rect width="380" height="260" fill="#f7f1e8" />
                <!-- roads -->
                <line x1="0" y1="65" x2="380" y2="65" stroke="#e2d5c4" stroke-width="7" />
                <line x1="0" y1="130" x2="380" y2="130" stroke="#e2d5c4" stroke-width="7" />
                <line x1="0" y1="195" x2="380" y2="195" stroke="#e2d5c4" stroke-width="7" />
                <line x1="75" y1="0" x2="75" y2="260" stroke="#e2d5c4" stroke-width="7" />
                <line x1="190" y1="0" x2="190" y2="260" stroke="#e2d5c4" stroke-width="7" />
                <line x1="305" y1="0" x2="305" y2="260" stroke="#e2d5c4" stroke-width="7" />
                <!-- blocks -->
                <rect x="8" y="8" width="55" height="45" rx="3" fill="#ede6d8" opacity=".7" />
                <rect x="83" y="8" width="95" height="45" rx="3" fill="#ede6d8" opacity=".6" />
                <rect x="197" y="8" width="95" height="45" rx="3" fill="#ede6d8" opacity=".7" />
                <rect x="312" y="8" width="60" height="45" rx="3" fill="#ede6d8" opacity=".5" />
                <rect x="8" y="73" width="55" height="45" rx="3" fill="#ede6d8" opacity=".5" />
                <rect x="83" y="73" width="95" height="45" rx="3" fill="#ede6d8" opacity=".7" />
                <rect x="197" y="73" width="95" height="45" rx="3" fill="#ede6d8" opacity=".6" />
                <rect x="312" y="73" width="60" height="45" rx="3" fill="#ede6d8" opacity=".7" />
                <rect x="8" y="138" width="55" height="45" rx="3" fill="#ede6d8" opacity=".7" />
                <rect x="83" y="138" width="95" height="45" rx="3" fill="#ede6d8" opacity=".5" />
                <rect x="197" y="138" width="95" height="45" rx="3" fill="#ede6d8" opacity=".7" />
                <rect x="312" y="138" width="60" height="45" rx="3" fill="#ede6d8" opacity=".6" />
                <rect x="8" y="203" width="55" height="50" rx="3" fill="#ede6d8" opacity=".5" />
                <rect x="83" y="203" width="95" height="50" rx="3" fill="#ede6d8" opacity=".7" />
                <rect x="197" y="203" width="95" height="50" rx="3" fill="#ede6d8" opacity=".6" />
                <rect x="312" y="203" width="60" height="50" rx="3" fill="#ede6d8" opacity=".7" />
                <!-- route trail -->
                <polyline points="35,95 35,65 130,65 130,30 247,30 247,65 340,65 340,95 340,130 247,130 247,160 130,160 130,195 247,195" fill="none" stroke="#c0521f" stroke-width="2.5" stroke-dasharray="300" stroke-linecap="round" stroke-linejoin="round" class="map-trail" style="stroke-dashoffset:300;animation:trailDraw 2s cubic-bezier(.4,0,.2,1) .4s forwards" />
                <!-- ripples -->
                <circle cx="35" cy="95" r="10" fill="none" stroke="#c0521f" stroke-width="1.5" style="animation:ripple 2.2s ease-out .5s infinite" />
                <circle cx="130" cy="30" r="10" fill="none" stroke="#c0521f" stroke-width="1.5" style="animation:ripple 2.2s ease-out 1s infinite" />
                <circle cx="247" cy="65" r="10" fill="none" stroke="#2e8c4f" stroke-width="1.5" style="animation:ripple 2.2s ease-out 1.5s infinite" />
                <circle cx="340" cy="130" r="10" fill="none" stroke="#c0521f" stroke-width="1.5" style="animation:ripple 2.2s ease-out 2s infinite" />
                <circle cx="247" cy="195" r="10" fill="none" stroke="#c07820" stroke-width="1.5" style="animation:ripple 2.2s ease-out 2.5s infinite" />
                <!-- pins (visited) -->
                <g style="opacity:0;animation:pinDrop .5s cubic-bezier(.34,1.56,.64,1) .8s forwards">
                  <circle cx="35" cy="95" r="7" fill="#c0521f" /><circle cx="35" cy="95" r="3" fill="#fff" />
                </g>
                <g style="opacity:0;animation:pinDrop .5s cubic-bezier(.34,1.56,.64,1) 1.1s forwards">
                  <circle cx="130" cy="30" r="7" fill="#c0521f" /><circle cx="130" cy="30" r="3" fill="#fff" />
                </g>
                <g style="opacity:0;animation:pinDrop .5s cubic-bezier(.34,1.56,.64,1) 1.4s forwards">
                  <circle cx="247" cy="65" r="7" fill="#2e8c4f" /><circle cx="247" cy="65" r="3" fill="#fff" />
                </g>
                <g style="opacity:0;animation:pinDrop .5s cubic-bezier(.34,1.56,.64,1) 1.7s forwards">
                  <circle cx="340" cy="130" r="7" fill="#c0521f" /><circle cx="340" cy="130" r="3" fill="#fff" />
                </g>
                <!-- current pin (en route) -->
                <g style="opacity:0;animation:pinDrop .5s cubic-bezier(.34,1.56,.64,1) 2.0s forwards">
                  <circle cx="247" cy="195" r="9" fill="#c07820" /><circle cx="247" cy="195" r="3.5" fill="#fff" />
                  <circle cx="247" cy="195" r="15" fill="none" stroke="#c07820" stroke-width="1.5" style="animation:ripple 1.8s ease-out infinite" />
                </g>
                <!-- label chips -->
                <g style="opacity:0;animation:pinDrop .35s ease 1.5s forwards">
                  <rect x="254" y="56" width="50" height="14" rx="7" fill="rgba(46,140,79,.9)" />
                  <text x="279" y="66" text-anchor="middle" font-size="7.5" font-family="Sora,sans-serif" fill="#fff" font-weight="600">Visited ✓</text>
                </g>
                <g style="opacity:0;animation:pinDrop .35s ease 2.2s forwards">
                  <rect x="255" y="185" width="56" height="14" rx="7" fill="rgba(192,120,32,.92)" />
                  <text x="283" y="195" text-anchor="middle" font-size="7.5" font-family="Sora,sans-serif" fill="#fff" font-weight="600">En route…</text>
                </g>
                <!-- coverage label -->
                <g style="opacity:0;animation:pinDrop .4s ease 2.5s forwards">
                  <rect x="6" y="238" width="130" height="16" rx="8" fill="rgba(192,82,31,.12)" stroke="rgba(192,82,31,.3)" stroke-width=".8" />
                  <text x="71" y="249" text-anchor="middle" font-size="7.5" font-family="Sora,sans-serif" fill="#732e0c" font-weight="600">4 of 5 stops completed</text>
                </g>
              </svg>
            </div>
          </div>
        </div>

        <!-- 2 · ATTENDANCE -->
        <div class="feat-row reverse" id="attendance">
          <div class="feat-copy reveal-up">
            <span class="eyebrow">Attendance with accountability</span>
            <h2 class="sh2">Track presence <em>linked to real</em> field activity</h2>
            <p>Attendance linked to real field activity so managers can distinguish presence from execution. No more marking present without actually being in the field.</p>
            <ul class="bullet-list">
              <li>Track employee attendance and login activity</li>
              <li>Check-in tied to GPS location verification</li>
              <li>Distinguish office logins from field activity</li>
            </ul>
          </div>
          <div class="feat-illu reveal-fade" style="animation-delay:.1s">
            <div class="illu-panel mobile-panel" id="mobileCheckin">
              <div class="mobile-screen">
                <div class="mobile-topbar">
                  <span class="mobile-topbar-title">Sales Tracking</span>
                  <span class="mobile-topbar-time">9:14 AM</span>
                </div>
                <div class="mobile-body">
                  <div class="mobile-avatar-row">
                    <div class="mobile-avatar">RM</div>
                    <div>
                      <div class="mobile-name">Rahul Mehta</div>
                      <div class="mobile-role">Senior Field Rep · Zone 3</div>
                    </div>
                  </div>
                  <div class="mobile-checkin-btn" id="checkinBtn">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1C4.8 1 3 2.8 3 5c0 3 4 8 4 8s4-5 4-8c0-2.2-1.8-4-4-4z" stroke="currentColor" stroke-width="1.4" fill="rgba(255,255,255,.25)" /></svg>
                    <span id="checkinText">Check in to field</span>
                  </div>
                  <div class="mobile-notif" id="checkinNotif" style="margin-top:.5rem">
                    <span class="mobile-notif-dot"></span>
                    <span>Checked in · Andheri North · 9:14 AM</span>
                  </div>
                </div>
              </div>
              <!-- second rep -->
              <div class="mobile-screen">
                <div class="mobile-topbar" style="background:var(--rust-700)">
                  <span class="mobile-topbar-title">Sales Tracking</span>
                  <span class="mobile-topbar-time">9:22 AM</span>
                </div>
                <div class="mobile-body">
                  <div class="mobile-avatar-row">
                    <div class="mobile-avatar" style="background:rgba(46,140,79,.12);color:#1c6535">PS</div>
                    <div>
                      <div class="mobile-name">Priya Sharma</div>
                      <div class="mobile-role">Field Rep · Zone 1</div>
                    </div>
                  </div>
                  <div class="mobile-notif show" style="opacity:0">
                    <span class="mobile-notif-dot"></span>
                    <span>Checked in · Bandra West · 9:22 AM</span>
                  </div>
                  <div style="margin-top:.55rem;font-size:.76rem;color:var(--ink-muted);font-weight:400">2 of 4 visits completed today</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 3 · EXPENSE WORKFLOWS -->
        <div class="feat-row" id="expenses">
          <div class="feat-copy reveal-up">
            <span class="eyebrow">Expense workflows</span>
            <h2 class="sh2">Collect, verify, approve — <em>no spreadsheets</em></h2>
            <p>Collect, verify, and approve field expenses in one place without spreadsheet back-and-forth. Reps submit from the field, managers approve from the web dashboard.</p>
            <ul class="bullet-list">
              <li>Submit expenses directly from the field</li>
              <li>Upload photos or proof of execution</li>
              <li>Review and approve field expenses in one place</li>
            </ul>
          </div>
          <div class="feat-illu reveal-fade" style="animation-delay:.1s">
            <div class="illu-panel expense-panel" id="expensePanel">
              <div class="exp-receipt" id="er1">
                <div class="exp-receipt-row">
                  <span class="exp-receipt-label">Auto rickshaw — Andheri to Bandra</span>
                  <span class="exp-receipt-amount">₹ 220</span>
                </div>
                <div class="exp-receipt-meta">Rahul M. · Today 9:45 AM · Photo attached</div>
                <span class="exp-status approved">✓ Approved</span>
              </div>
              <div class="exp-receipt" id="er2">
                <div class="exp-receipt-row">
                  <span class="exp-receipt-label">Client lunch — Bandra outlet visit</span>
                  <span class="exp-receipt-amount">₹ 680</span>
                </div>
                <div class="exp-receipt-meta">Priya S. · Today 1:12 PM · Receipt uploaded</div>
                <span class="exp-status pending">⏳ Pending review</span>
              </div>
              <div class="exp-receipt" id="er3">
                <div class="exp-receipt-row">
                  <span class="exp-receipt-label">Metro pass — weekly zone 3</span>
                  <span class="exp-receipt-amount">₹ 340</span>
                </div>
                <div class="exp-receipt-meta">Vikram T. · Yesterday · Card payment</div>
                <span class="exp-status approved">✓ Approved</span>
              </div>
              <div class="exp-total">
                <span class="exp-total-label">This week total</span>
                <span class="exp-total-val">₹ 4,820</span>
              </div>
            </div>
          </div>
        </div>

        <!-- 4 · REPORTING -->
        <div class="feat-row reverse" id="reporting">
          <div class="feat-copy reveal-up">
            <span class="eyebrow">Operational reporting</span>
            <h2 class="sh2">Performance snapshots that <em>drive decisions</em></h2>
            <p>Clear performance snapshots by employee, region, day, and manager to improve decision-making. Get planned vs completed side by side — not in separate exports.</p>
            <ul class="bullet-list">
              <li>Audit productivity, conversion, and follow-ups</li>
              <li>Compare planned versus completed by region</li>
              <li>Track team-level activity in real time</li>
            </ul>
          </div>
          <div class="feat-illu reveal-fade" style="animation-delay:.1s">
            <div class="illu-panel chart-panel" id="chartPanel">
              <div class="chart-header">
                <div>
                  <div class="chart-title">Visit completion — this week</div>
                  <div class="chart-sub">Planned vs completed by day</div>
                </div>
                <div class="chart-legend">
