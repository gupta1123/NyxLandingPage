  <script is:inline>
    /* NAV */
    const nav = document.getElementById('mainnav');
    window.addEventListener('scroll', () => nav.classList.toggle('scrolled', scrollY > 40), { passive: true });

    /* INTERSECTION OBSERVER — single shared instance */
    const seenSet = new Set();
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting || seenSet.has(e.target)) return;
        seenSet.add(e.target);
        e.target.classList.add('in-view');
        if (e.target.id === 'expensePanel') triggerExpenses();
        if (e.target.id === 'oversightPanel') triggerOversight();
        if (e.target.id === 'chartPanel') triggerChart();
        if (e.target.id === 'mobileCheckin') triggerMobile();
        io.unobserve(e.target);
      });
    }, { threshold: .18, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll(
      '.reveal-up, .reveal-fade, .bd-step, .bd-audience__item, .bd-cta__card, #expensePanel, #oversightPanel, #chartPanel, #mobileCheckin'
    ).forEach(el => io.observe(el));

    /* COUNT-UP */
    const cobs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const el = e.target, target = +el.dataset.count;
        let v = 0; const step = Math.ceil(target / 38);
        const t = setInterval(() => { v = Math.min(v + step, target); el.textContent = v; if (v >= target) clearInterval(t); }, 35);
        cobs.unobserve(el);
      });
    }, { threshold: .5 });
    document.querySelectorAll('[data-count]').forEach(el => cobs.observe(el));

    /* MOBILE CHECK-IN ANIMATION */
    function triggerMobile() {
      const btn = document.getElementById('checkinBtn');
      const txt = document.getElementById('checkinText');
      const notif = document.getElementById('checkinNotif');
      if (!btn) return;
      setTimeout(() => {
        btn.classList.add('checked');
        txt.textContent = '✓ Checked in';
        notif.classList.add('show');
      }, 800);
    }

    /* EXPENSE ANIMATION */
    function triggerExpenses() {
      ['er1', 'er2', 'er3'].forEach((id, i) => {
        const el = document.getElementById(id);
        if (el) setTimeout(() => el.classList.add('show'), i * 200 + 100);
      });
    }

    /* OVERSIGHT ANIMATION */
    function triggerOversight() {
      ['rr1', 'rr2', 'rr3', 'rr4'].forEach((id, i) => {
        const el = document.getElementById(id);
        if (!el) return;
        setTimeout(() => {
          el.classList.add('show');
          setTimeout(() => {
            const bar = el.querySelector('.rep-bar');
            if (bar) bar.style.width = bar.dataset.w + '%';
          }, 300);
        }, i * 130 + 200);
      });
    }

    /* CHART ANIMATION */
    function triggerChart() {
      const wrap = document.getElementById('chartBars');
      if (!wrap) return;
      const days = [
        { label: 'Mon', plan: 80, done: 72 },
        { label: 'Tue', plan: 90, done: 85 },
        { label: 'Wed', plan: 75, done: 60 },
        { label: 'Thu', plan: 85, done: 80 },
        { label: 'Fri', plan: 90, done: 84 },
        { label: 'Sat', plan: 50, done: 48 }
      ];
      const maxVal = 90;
      const barH = 90;
      days.forEach((d, i) => {
        const bw = document.createElement('div');
        bw.className = 'chart-bar-wrap';
        const planH = Math.round((d.plan / maxVal) * barH);
        const doneH = Math.round((d.done / maxVal) * barH);
        bw.innerHTML = `
          <div class="chart-bar-pair">
            <div class="chart-bar plan" style="--h:${planH}px;animation-delay:${.05 + i * .1}s"></div>
            <div class="chart-bar done" style="--h:${doneH}px;animation-delay:${.1 + i * .1}s"></div>
          </div>
          <div class="chart-label">${d.label}</div>`;
        wrap.appendChild(bw);
      });
    }
  </script>
