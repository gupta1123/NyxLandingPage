  <script is:inline>
    /* ── NAV ── */
    window.addEventListener('scroll',()=>document.getElementById('mainnav')?.classList.toggle('scrolled',scrollY>40),{passive:true});

    /* ── HERO STEP SWITCHER ── */
    const hPills=['hs1','hs2','hs3','hs4'],hPanels=['hp1','hp2','hp3','hp4'];
    let hCur=0;
    function heroStep(idx){
      hPills.forEach((id,i)=>{const el=document.getElementById(id);if(!el)return;el.classList.remove('active','done');if(i<idx)el.classList.add('done');if(i===idx)el.classList.add('active');});
      hPanels.forEach((id,i)=>{const el=document.getElementById(id);if(el)el.classList.toggle('active',i===idx);});
      hCur=idx;
    }
    document.querySelectorAll('.demo-step-pill').forEach((p,i)=>p.onclick=()=>heroStep(i));
    setInterval(()=>heroStep((hCur+1)%4),4200);

    /* hero panel 1: caption typewriter */
    (()=>{
      const el=document.getElementById('heroTypedCaption');
      const cur=document.getElementById('heroCursor');
      const pp=document.getElementById('heroPp');
      const tags=document.getElementById('heroPpTags');
      const phrase='the Summer Midi Collection — 20% off for 3 days only.';
      if(!el)return;
      setTimeout(()=>{
        pp.classList.add('show');
        let i=0;
        const iv=setInterval(()=>{
          el.textContent=phrase.slice(0,++i);
          if(i>=phrase.length){clearInterval(iv);if(cur)cur.style.display='none';if(tags)tags.classList.add('show');}
        },28);
      },600);
    })();

    /* hero template switcher */
    const heroTmplData=[
      {name:'Launch post template',badge:'Instagram',img:'Hero image slot'},
      {name:'Offer post template',badge:'LinkedIn',img:'Discount banner'},
      {name:'Seasonal campaign',badge:'Stories',img:'Campaign visual'},
    ];
    let htCur=0;
    function heroTmpl(idx){
      htCur=idx;
      ['tlt1','tlt2','tlt3'].forEach((id,i)=>{const el=document.getElementById(id);if(el)el.classList.toggle('active',i===idx);});
      const d=heroTmplData[idx];
      const nm=document.getElementById('heroTmplName'),bg=document.getElementById('heroTmplBadge'),img=document.getElementById('heroTmplImg');
      if(nm)nm.textContent=d.name;if(bg)bg.textContent=d.badge;if(img)img.textContent=d.img;
    }
    document.querySelectorAll('.tmpl-tab').forEach((p,i)=>p.onclick=()=>heroTmpl(i));
    setInterval(()=>heroTmpl((htCur+1)%3),3000);

    /* ── INTERSECTION OBSERVER ── */
    const seen=new Set();
    const io=new IntersectionObserver(entries=>{
      entries.forEach(e=>{
        if(!e.isIntersecting||seen.has(e.target))return;
        seen.add(e.target);e.target.classList.add('in-view');
        const id=e.target.id;
        if(id==='brandPanel') initBrand();
        if(id==='tmplPanel') initTmpl();
        if(id==='aiPanel') initAI();
        if(id==='schedPanel') initSched();
        if(id==='campaignPanel') initCampaign();
        io.unobserve(e.target);
      });
    },{threshold:.12,rootMargin:'0px 0px -40px 0px'});

    document.querySelectorAll(
      '.bd-step,.bd-audience__item,#brandPanel,#tmplPanel,#aiPanel,#schedPanel,#campaignPanel,#problemCard,#ctaCard'
    ).forEach(el=>io.observe(el));

    /* count-up */
    const cio=new IntersectionObserver(entries=>{
      entries.forEach(e=>{
        if(!e.isIntersecting)return;
        const el=e.target,tgt=+el.dataset.count,t0=performance.now();
        const tick=now=>{const p=Math.min((now-t0)/1400,1);el.textContent=Math.round((1-Math.pow(1-p,3))*tgt);if(p<1)requestAnimationFrame(tick);};
        requestAnimationFrame(tick);cio.unobserve(el);
      });
    },{threshold:.5});
    document.querySelectorAll('[data-count]').forEach(el=>cio.observe(el));

    /* ── BRAND PANEL ── */
    function initBrand(){
      ['bpr1','bpr2','bpr3','bpr4','bpr5'].forEach((id,i)=>{
        const el=document.getElementById(id);if(el)setTimeout(()=>el.classList.add('show'),i*140+150);
      });
      setTimeout(()=>{
        const post=document.getElementById('bpPost');if(post)post.classList.add('show');
        setTimeout(()=>['bpHl1','bpHl2'].forEach((id,i)=>setTimeout(()=>{const el=document.getElementById(id);if(el)el.classList.add('lit');},i*400)),300);
      },1000);
    }

    /* ── TEMPLATE PANEL ── */
    let tmplPlatform=0;
    function switchTmpl(idx){
      tmplPlatform=idx;
      ['tpt1','tpt2','tpt3'].forEach((id,i)=>{const el=document.getElementById(id);if(el)el.classList.toggle('active',i===idx);});
      ['tc1','tc2','tc3'].forEach((id,i)=>{const el=document.getElementById(id);if(el)el.classList.toggle('selected',i===idx%3);});
      const labels=['Instagram selected','LinkedIn selected','Stories selected'];
      const el=document.getElementById('tmplAdaptCount');if(el)el.textContent=labels[idx];
    }
    document.querySelectorAll('.tpt').forEach((p,i)=>p.onclick=()=>switchTmpl(i));
    function initTmpl(){
      ['tc1','tc2','tc3'].forEach((id,i)=>{const el=document.getElementById(id);if(el)setTimeout(()=>el.classList.add('show'),i*150+100);});
      setInterval(()=>switchTmpl((tmplPlatform+1)%3),2800);
    }

    /* ── AI PANEL ── */
    function initAI(){
      setTimeout(()=>{
        const after=document.getElementById('aipAfter');if(after)after.classList.add('show');
        setTimeout(()=>{const m=document.getElementById('aipMark1');if(m)m.classList.add('lit');},450);
      },900);
      setTimeout(()=>{
        ['aipFill1','aipFill2'].forEach(id=>{const el=document.getElementById(id);if(el)el.style.width=el.dataset.w;});
      },600);
    }

    /* ── SCHED PANEL ── */
    function initSched(){
      const count=document.getElementById('schedCount');
      ['spq1','spq2','spq3','spq4'].forEach((id,i)=>{
        setTimeout(()=>{
          const el=document.getElementById(id);if(el)el.classList.add('show');
          if(count)count.textContent=(i+1)+' post'+(i>0?'s':'')+' scheduled';
        },i*220+300);
      });
    }

    /* ── CAMPAIGN PANEL ── */
    function initCampaign(){
      ['kb1','kb2','kb3','kb4','kb5','kb6','kb7'].forEach((id,i)=>{
        const el=document.getElementById(id);if(el)setTimeout(()=>el.classList.add('show'),i*100+100);
      });
      setTimeout(()=>{
        const bar=document.getElementById('cpProgBar'),fill=document.getElementById('cpFill'),pct=document.getElementById('cpPct');
        if(bar)bar.style.opacity='1';
        if(fill){fill.style.transition='width 1.6s cubic-bezier(.22,.85,.44,1)';fill.style.width='57%';}
        if(pct){let v=0;const t=setInterval(()=>{v=Math.min(v+2,57);pct.textContent=v+'%';if(v>=57)clearInterval(t);},35);}
      },900);
    }
  </script>
</MainLayout>
