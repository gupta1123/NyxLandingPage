---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/pages/briefly-social.css';
---

<MainLayout title="Briefly Social | Nyx Solution">
  <nav id="mainnav">
    <div class="nav-left">
      <a class="nav-back" href="/products" aria-label="Back to products">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      </a>
      <span class="nav-logo">Nyx Solution</span>
    </div>
    <ul class="nav-links">
      <li><a href="#brand">Brand data</a></li>
      <li><a href="#templates">Templates</a></li>
      <li><a href="#ai">AI editing</a></li>
      <li><a href="#schedule">Schedule</a></li>
      <li><a href="#campaigns">Campaigns</a></li>
    </ul>
  </nav>

  <div class="ticker-wrap" aria-hidden="true">
    <div class="ticker">
      <span class="ticker-item">Brand-data grounding</span><span class="ticker-item">Template-based creation</span>
      <span class="ticker-item">AI-assisted editing</span><span class="ticker-item">Multi-channel scheduling</span>
      <span class="ticker-item">Campaign visibility</span><span class="ticker-item">Social content ops</span>
      <span class="ticker-item">Brand-data grounding</span><span class="ticker-item">Template-based creation</span>
      <span class="ticker-item">AI-assisted editing</span><span class="ticker-item">Multi-channel scheduling</span>
      <span class="ticker-item">Campaign visibility</span><span class="ticker-item">Social content ops</span>
    </div>
  </div>

  <!-- ════ HERO ════ -->
  <section class="bd-hero">
    <div class="container">
      <div class="bd-hero__grid">
        <div>
          <div class="bd-hero__eyebrow reveal-up">
            <span class="eyebrow-dot"></span>
            <span class="eyebrow-text">Social Content Ops</span>
          </div>
          <h1 class="bd-hero__h1 reveal-up" style="animation-delay:.1s">
            Social content that stays<br/><em>on-brand,</em> moves faster,<br/>and goes live on schedule.
          </h1>
          <p class="bd-hero__lead reveal-up" style="animation-delay:.2s">
            Briefly Social helps marketing teams create posts from real brand data, reuse templates, edit with AI, and schedule publishing — without breaking brand consistency or switching tools.
          </p>
          <div class="cta-row reveal-up" style="animation-delay:.3s">
            <a class="btn ghost" href="#brand">See the Platform</a>
          </div>
        </div>

        <div class="bd-hero__demo reveal-fade" style="animation-delay:.45s">
          <div class="demo-window">
            <div class="demo-bar">
              <span class="demo-dot demo-dot-r"></span>
              <span class="demo-dot demo-dot-y"></span>
              <span class="demo-dot demo-dot-g"></span>
              <span class="demo-bar-title">Briefly Social</span>
              <div class="demo-bar-live"><div class="demo-bar-live-dot"></div>Live</div>
            </div>
            <div class="demo-body">
              <div class="demo-steps-row">
                <div class="demo-step-pill active" id="hs1">Brand data</div>
                <div class="demo-step-pill" id="hs2">Template</div>
                <div class="demo-step-pill" id="hs3">AI edit</div>
                <div class="demo-step-pill" id="hs4">Schedule</div>
              </div>

              <!-- Panel 1 -->
              <div class="demo-panel active" id="hp1">
                <div class="brand-inputs">
                  <div class="bi-label">Brand inputs</div>
                  <div class="bi-row"><span class="bi-key">Product</span><span class="bi-val">Summer Midi Collection</span></div>
                  <div class="bi-row"><span class="bi-key">Offer</span><span class="bi-val">20% off · 3 days only</span></div>
                  <div class="bi-row"><span class="bi-key">Audience</span><span class="bi-val">Women 24–38 · fashion</span></div>
                  <div class="bi-row"><span class="bi-key">Channel</span><span class="bi-val">Instagram + Stories</span></div>
                </div>
                <div class="arrow-row">
                  <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M7 2v10M3 8l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Generated from brand context
                </div>
                <div class="post-preview" id="heroPp">
                  <div class="pp-platform"><span class="pp-dot"></span>Instagram</div>
                  <div class="pp-caption">☀️ Your summer upgrade is here — <span id="heroTypedCaption"></span><span class="tone-val" id="heroCursor" style="animation:blink 1s step-end infinite;font-size:.79rem">|</span></div>
                  <div class="pp-tags" id="heroPpTags">
                    <span class="pp-tag">#summerdrops</span>
                    <span class="pp-tag">#newcollection</span>
                    <span class="pp-tag">#fashiondeals</span>
                  </div>
                </div>
              </div>

              <!-- Panel 2 -->
              <div class="demo-panel" id="hp2">
                <div class="template-label">Reusable templates</div>
                <div class="template-tabs">
                  <div class="tmpl-tab active" id="tlt1">Launch</div>
                  <div class="tmpl-tab" id="tlt2">Offer</div>
                  <div class="tmpl-tab" id="tlt3">Seasonal</div>
                </div>
                <div class="template-card show" id="heroTmplCard">
                  <div class="tc-header"><div class="tc-h-dot"></div><span class="tc-h-label" id="heroTmplName">Launch post template</span><span class="tc-h-badge" id="heroTmplBadge">Instagram</span></div>
                  <div class="tc-body">
                    <div class="tc-img-ph" id="heroTmplImg">Hero image slot</div>
                    <div class="tc-line" style="width:85%"></div>
                    <div class="tc-line" style="width:70%"></div>
                    <div class="tc-cta-btn"></div>
                    <div class="tc-metrics"><span class="tc-metric">Avg reach 12k</span><span class="tc-metric">·</span><span class="tc-metric">Used 24×</span></div>
                  </div>
                </div>
              </div>

              <!-- Panel 3 -->
              <div class="demo-panel" id="hp3">
                <div class="ai-edit-header">
                  <span class="ai-edit-label">AI copy editing</span>
                  <span class="ai-badge">✦ Rewriting…</span>
                </div>
                <div class="edit-before">
                  <div class="edit-before-lbl">Original draft</div>
                  <div class="edit-before-text"><span class="strike">Big sale on summer dresses. Buy now and get 20% off.</span></div>
                </div>
                <div class="edit-arrow">
                  <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M7 2v10M3 8l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  AI · Conversational · Brand-matching
                </div>
                <div class="edit-after show" id="heroEditAfter">
                  <div class="edit-after-lbl">Rewritten ✓</div>
                  <div class="edit-after-text">Your summer wardrobe upgrade is waiting — <mark class="hl-ac lit" id="heroEditMark">exclusive 20% off across our new midi collection</mark>, this weekend only. ☀️</div>
                </div>
                <div class="tone-row">
                  <span class="tone-label">Tone: conversational</span>
                  <div class="tone-track"><div class="tone-fill" style="width:68%"></div></div>
                  <span class="tone-val">68%</span>
                </div>
              </div>

              <!-- Panel 4 -->
              <div class="demo-panel" id="hp4">
                <div class="sched-header">
                  <span class="sched-month">May 2025</span>
                  <span class="sched-count">6 posts scheduled</span>
                </div>
                <div class="cal-grid">
                  <span class="cal-dow">M</span><span class="cal-dow">T</span><span class="cal-dow">W</span><span class="cal-dow">T</span><span class="cal-dow">F</span><span class="cal-dow">S</span><span class="cal-dow">S</span>
                  <span class="cal-day"></span><span class="cal-day"></span><span class="cal-day p">1</span><span class="cal-day">2</span><span class="cal-day p">3</span><span class="cal-day">4</span><span class="cal-day">5</span>
                  <span class="cal-day">6</span><span class="cal-day p">7</span><span class="cal-day">8</span><span class="cal-day">9</span><span class="cal-day p">10</span><span class="cal-day">11</span><span class="cal-day">12</span>
                  <span class="cal-day today">13</span><span class="cal-day">14</span><span class="cal-day">15</span><span class="cal-day p">16</span><span class="cal-day">17</span><span class="cal-day p">18</span><span class="cal-day">19</span>
                </div>
                <div class="sched-queue">
                  <div class="sq-row show" id="sqr1"><span class="sq-time">9:00</span><span class="sq-name">Summer launch carousel</span><span class="sq-st st-live">Live ✓</span></div>
                  <div class="sq-row show" id="sqr2"><span class="sq-time">12:30</span><span class="sq-name">Offer story · 20% off</span><span class="sq-st st-sched">Scheduled</span></div>
                  <div class="sq-row show" id="sqr3"><span class="sq-time">18:00</span><span class="sq-name">New arrival reel</span><span class="sq-st st-draft">Draft</span></div>
                </div>
              </div>
            </div>
          </div>
          <div class="demo-float demo-float-1 reveal-fade" style="animation-delay:.9s">
            <svg viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.3"/><path d="M4.5 7l2 2 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Always on-brand
          </div>
          <div class="demo-float demo-float-2 reveal-fade" style="animation-delay:1.2s">
            <svg viewBox="0 0 14 14" fill="none"><path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Publish in minutes
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ STATS ════ -->
  <div class="stats-strip">
    <div class="stat-item"><span class="stat-num" data-count="5">0</span><span class="stat-label">workflow stages unified</span></div>
    <div class="stat-item"><span class="stat-num" data-count="80">0</span><span class="stat-label">% less rewriting from scratch</span></div>
    <div class="stat-item"><span class="stat-num" data-count="4">0</span><span class="stat-label">channels from one brief</span></div>
    <div class="stat-item"><span class="stat-num" data-count="3">0</span><span class="stat-label">× faster post production</span></div>
  </div>

  <!-- ════ PROBLEM ════ -->
  <section class="bd-problem">
    <div class="narrow">
      <div class="bd-problem__card" id="problemCard">
        <div class="bd-problem-icon">
          <svg width="52" height="52" viewBox="0 0 48 48" fill="none"><rect x="4" y="6" width="18" height="22" rx="2.5" stroke="currentColor" stroke-width="1.8" stroke-dasharray="4 3"/><rect x="14" y="14" width="18" height="22" rx="2.5" fill="rgba(162,74,42,.06)" stroke="currentColor" stroke-width="1.8" stroke-dasharray="4 3"/><rect x="24" y="22" width="18" height="22" rx="2.5" fill="rgba(162,74,42,.06)" stroke="currentColor" stroke-width="1.8"/><circle cx="38" cy="38" r="7" fill="var(--sand-50)" stroke="currentColor" stroke-width="1.8"/><path d="M35.5 38h5M38 35.5v5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        </div>
        <div class="bd-problem__text">
          <h2>Most social workflows are fragmented. That's where the inconsistency starts.</h2>
          <p>Copy lives in one tool, visuals in another, calendars in spreadsheets, approvals in chat, and publishing in separate platform dashboards. That creates delay, inconsistency, and avoidable manual work every single week.</p>
          <p>Briefly Social brings creation, editing, scheduling, and campaign visibility into one system — so your team can work faster without losing control of brand voice and execution.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ FEATURE ROWS ════ -->
  <section class="feat-section">
    <div class="container">

      <!-- 1: Brand data → post -->
      <div class="feat-row" id="brand">
        <div class="feat-copy reveal-up">
          <span class="eyebrow">Create posts from real brand context</span>
          <h2 class="sh2">Not a blank page.<br/><em>A grounded starting point.</em></h2>
          <p>Build content using information that already matters to your brand — product names, campaign offers, launch dates, approved messaging, and channel priorities. Post drafts start from real inputs, not disconnected brainstorms.</p>
          <ul class="bullet-list">
            <li>Captions and variants generated from actual brand data</li>
            <li>Less rewriting from scratch for every platform and launch</li>
            <li>Brand voice preserved because the inputs are controlled</li>
            <li>Generate multiple post variants from the same brief</li>
          </ul>
        </div>
        <div class="feat-illu reveal-fade" style="animation-delay:.1s">
          <div class="illu-panel brand-panel" id="brandPanel">
            <div class="bp-title">Brand inputs → campaign post</div>
            <div class="bp-inputs">
              <div class="bp-inputs-label">Brand inputs</div>
              <div class="bp-row" id="bpr1"><span class="bp-key">Product</span><span class="bp-val">Summer Midi Collection</span></div>
              <div class="bp-row" id="bpr2"><span class="bp-key">Offer</span><span class="bp-val">20% off · limited 3 days</span></div>
              <div class="bp-row" id="bpr3"><span class="bp-key">Audience</span><span class="bp-val">Women 24–38 · fashion-first</span></div>
              <div class="bp-row" id="bpr4"><span class="bp-key">Tone</span><span class="bp-val">Conversational, warm</span></div>
              <div class="bp-row" id="bpr5"><span class="bp-key">Channel</span><span class="bp-val">Instagram + Stories</span></div>
            </div>
            <div class="bp-arrow">
              <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M7 2v10M3 8l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Generated from brand context
            </div>
            <div class="bp-post" id="bpPost">
              <div class="bp-post-head">
                <div class="bp-post-platform">Instagram — Brand-matched ✓</div>
                <span class="bp-post-badge">Source verified</span>
              </div>
              <div class="bp-caption-text">☀️ Your summer upgrade is here. <span class="hl-warm" id="bpHl1">The Summer Midi Collection</span> just dropped — and for the next 3 days, <span class="hl-warm" id="bpHl2">20% off everything</span>. Scroll, tap, treat yourself.</div>
              <div class="bp-hashtags">
                <span class="bp-hashtag">#summercollection</span><span class="bp-hashtag">#newdrop</span><span class="bp-hashtag">#fashionsale</span><span class="bp-hashtag">#styletips</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 2: Templates -->
      <div class="feat-row reverse" id="templates">
        <div class="feat-copy reveal-up">
          <span class="eyebrow">Use templates without becoming repetitive</span>
          <h2 class="sh2">Templates that <em>speed you up</em><br/>without boxing you in.</h2>
          <p>Templates speed up execution, but they only work when teams can adapt them quickly for different launches, channels, and audiences. Briefly Social makes that practical — structured formats for Instagram, LinkedIn, stories, and more, all adaptable per campaign.</p>
          <ul class="bullet-list">
            <li>Reusable layouts for launches, offers, reminders, and seasonal content</li>
            <li>Faster adaptation across Instagram, LinkedIn, and other channels</li>
            <li>Consistent structure without losing campaign-specific messaging</li>
            <li>Templates track performance so you know what's working</li>
          </ul>
        </div>
        <div class="feat-illu reveal-fade" style="animation-delay:.1s">
          <div class="illu-panel tmpl-panel" id="tmplPanel">
            <div class="tp-header">
              <span class="tp-title">Template library</span>
              <div class="tp-platform-tabs">
                <div class="tpt active" id="tpt1">Instagram</div>
                <div class="tpt" id="tpt2">LinkedIn</div>
                <div class="tpt" id="tpt3">Stories</div>
              </div>
            </div>
            <div class="tp-cards">
              <div class="tp-card selected" id="tc1">
                <div class="tp-card-head"><div class="tp-card-dot"></div><span class="tp-card-name">Launch</span></div>
                <div class="tp-card-body"><div class="tp-card-img">Hero image</div><div class="tp-card-line" style="width:90%"></div><div class="tp-card-line" style="width:70%"></div><div class="tp-card-cta"></div></div>
              </div>
              <div class="tp-card" id="tc2">
                <div class="tp-card-head"><div class="tp-card-dot"></div><span class="tp-card-name">Offer</span></div>
                <div class="tp-card-body"><div class="tp-card-line" style="width:80%"></div><div class="tp-card-line" style="width:65%"></div><div class="tp-card-img" style="height:28px">Badge</div><div class="tp-card-cta"></div></div>
              </div>
              <div class="tp-card" id="tc3">
                <div class="tp-card-head"><div class="tp-card-dot"></div><span class="tp-card-name">Seasonal</span></div>
                <div class="tp-card-body"><div class="tp-card-img" style="height:44px">Campaign</div><div class="tp-card-line" style="width:85%"></div><div class="tp-card-cta"></div></div>
              </div>
            </div>
            <div class="tp-adapt-bar">
              <span class="tp-adapt-label">Templates adapt copy for selected channel automatically</span>
              <span class="tp-adapt-count" id="tmplAdaptCount">Instagram selected</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 3: AI editing -->
      <div class="feat-row" id="ai">
        <div class="feat-copy reveal-up">
          <span class="eyebrow">Edit with AI and keep brand control</span>
          <h2 class="sh2">AI that improves execution<br/><em>without losing your voice.</em></h2>
          <p>AI editing is useful when it improves execution without drifting away from brand standards. Briefly Social uses AI as a working layer, not a replacement for judgment — rewrite captions, adapt tone for different audiences, iterate faster while keeping approval in the loop.</p>
          <ul class="bullet-list">
            <li>Rewrite captions to fit tone, format, or target audience</li>
            <li>Adapt creative direction for different platforms and placements</li>
            <li>Speed up iteration while keeping human approval in the loop</li>
            <li>Tone and formality controls per brand and channel</li>
          </ul>
        </div>
        <div class="feat-illu reveal-fade" style="animation-delay:.1s">
          <div class="illu-panel ai-panel" id="aiPanel">
            <div class="aip-header">
              <span class="aip-title">AI copy editing — live</span>
              <div class="aip-live"><div class="aip-live-dot"></div>Processing</div>
            </div>
            <div class="aip-before">
              <div class="aip-before-lbl">
                <svg width="11" height="11" viewBox="0 0 12 12" fill="none"><rect x="2" y="1" width="8" height="10" rx="1.2" stroke="currentColor" stroke-width="1.1"/><path d="M4 4h4M4 6h3" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>
                Original draft
              </div>
              <div class="aip-before-text"><span class="strike" id="aipStrike">Big sale on summer dresses. Buy now and get 20% off. Limited time only.</span></div>
            </div>
            <div class="aip-arrow">
              <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M7 2v10M3 8l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              AI · Conversational · Warmth +68% · Brand voice matched
            </div>
            <div class="aip-after" id="aipAfter">
              <div class="aip-after-lbl">
                <svg width="11" height="11" viewBox="0 0 12 12" fill="none"><path d="M2 6l2.5 2.5L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Rewritten ✓
              </div>
              <div class="aip-after-text">Your summer wardrobe upgrade is waiting — <mark class="hl-ac" id="aipMark1">exclusive 20% off across our new midi collection</mark>, this weekend only. Don't sleep on it. ☀️</div>
            </div>
            <div class="aip-controls">
              <div class="aip-ctrl">
                <div class="aip-ctrl-label">Warmth <span id="aipToneVal">68%</span></div>
                <div class="aip-track"><div class="aip-fill" id="aipFill1" data-w="68%"></div></div>
              </div>
              <div class="aip-ctrl">
                <div class="aip-ctrl-label">Conciseness <span id="aipConVal">54%</span></div>
                <div class="aip-track"><div class="aip-fill" id="aipFill2" data-w="54%"></div></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 4: Scheduling -->
      <div class="feat-row reverse" id="schedule">
        <div class="feat-copy reveal-up">
          <span class="eyebrow">Schedule publishing across connected accounts</span>
          <h2 class="sh2">One calendar.<br/><em>Every channel.</em><br/>No manual posting.</h2>
          <p>Once social accounts are connected, teams can schedule content from the same workflow where it was created and approved. That removes another handoff and makes publishing calendars easier to manage, trust, and plan around.</p>
          <ul class="bullet-list">
            <li>Schedule posting directly to connected social channels</li>
            <li>Plan weekly and campaign-based publishing calendars</li>
            <li>Reduce last-minute manual posting work</li>
            <li>See what's live, scheduled, and in draft at a glance</li>
          </ul>
        </div>
        <div class="feat-illu reveal-fade" style="animation-delay:.1s">
          <div class="illu-panel sched-panel" id="schedPanel">
            <div class="sp-header">
              <span class="sp-title">Publishing calendar · May 2025</span>
              <div class="sp-live"><div class="sp-live-dot"></div>Synced</div>
            </div>
            <div class="sp-cal">
              <div class="sp-cal-head">
                <span class="sp-cal-month">May 2025</span>
                <span class="sp-cal-count" id="schedCount">0 posts scheduled</span>
              </div>
              <div class="sp-cal-grid">
                <span class="sp-dow">M</span><span class="sp-dow">T</span><span class="sp-dow">W</span><span class="sp-dow">T</span><span class="sp-dow">F</span><span class="sp-dow">S</span><span class="sp-dow">S</span>
                <span class="sp-day"></span><span class="sp-day"></span><span class="sp-day p">1</span><span class="sp-day">2</span><span class="sp-day p">3</span><span class="sp-day">4</span><span class="sp-day">5</span>
                <span class="sp-day">6</span><span class="sp-day p">7</span><span class="sp-day">8</span><span class="sp-day">9</span><span class="sp-day p">10</span><span class="sp-day">11</span><span class="sp-day">12</span>
                <span class="sp-day today">13</span><span class="sp-day">14</span><span class="sp-day">15</span><span class="sp-day p">16</span><span class="sp-day">17</span><span class="sp-day p">18</span><span class="sp-day">19</span>
              </div>
            </div>
            <span class="sp-queue-label">Today's queue</span>
            <div class="sp-queue">
              <div class="sp-q-row" id="spq1"><span class="sp-q-time">9:00</span><span class="sp-q-channel">Instagram</span><span class="sp-q-name">Summer launch carousel</span><span class="sq-st st-live">Live ✓</span></div>
              <div class="sp-q-row" id="spq2"><span class="sp-q-time">12:30</span><span class="sp-q-channel">Stories</span><span class="sp-q-name">20% off drop reminder</span><span class="sq-st st-sched">Scheduled</span></div>
              <div class="sp-q-row" id="spq3"><span class="sp-q-time">18:00</span><span class="sp-q-channel">LinkedIn</span><span class="sp-q-name">Brand story post</span><span class="sq-st st-sched">Scheduled</span></div>
