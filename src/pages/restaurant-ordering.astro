---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Restaurant Ordering | Nyx Solutions" description="Live restaurant ordering system connecting customers, waiters, and kitchen operations in real time.">
  <!-- NAV -->
  <nav id="mainnav">
    <div class="nav-left">
      <a class="nav-back" href="/products" aria-label="Back to products">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
      </a>
      <span class="nav-logo">Nyx Solutions</span>
    </div>
    <ul class="nav-links">
      <li><a href="#customer">Customer</a></li>
      <li><a href="#waiter">Waiter</a></li>
      <li><a href="#kitchen">Kitchen</a></li>
      <li><a href="#pipeline">Pipeline</a></li>
    </ul>
  </nav>

  <!-- TICKER -->
  <div class="ticker-wrap" aria-hidden="true">
    <div class="ticker">
      <span class="ticker-item">Digital ordering</span>
      <span class="ticker-item">Live kitchen queue</span>
      <span class="ticker-item">Waiter dashboard</span>
      <span class="ticker-item">Table management</span>
      <span class="ticker-item">Real-time sync</span>
      <span class="ticker-item">Order dispatch</span>
      <span class="ticker-item">Fewer errors</span>
      <span class="ticker-item">Faster turnaround</span>
      <span class="ticker-item">Digital ordering</span>
      <span class="ticker-item">Live kitchen queue</span>
      <span class="ticker-item">Waiter dashboard</span>
      <span class="ticker-item">Table management</span>
      <span class="ticker-item">Real-time sync</span>
      <span class="ticker-item">Order dispatch</span>
      <span class="ticker-item">Fewer errors</span>
      <span class="ticker-item">Faster turnaround</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="bd-hero">
    <div class="container">
      <div class="bd-hero__grid">

        <div>
          <div class="bd-hero__eyebrow reveal-up">
            <span class="eyebrow-dot"></span>
            <span class="eyebrow-text">Food and Beverage Product</span>
          </div>
          <h1 class="bd-hero__h1 reveal-up" style="animation-delay:.1s">
            Ordering that connects<br />
            every part of your <em>restaurant.</em>
          </h1>
          <p class="bd-hero__lead reveal-up" style="animation-delay:.2s">
            A live order flow system that links customer ordering, waiter operations, and kitchen execution in real time — replacing paper handoffs with a digital workflow that never falls behind.
          </p>
          <div class="cta-row reveal-up" style="animation-delay:.3s">
            <a class="btn ghost" href="#customer">See Platform</a>
          </div>
        </div>

        <!-- HERO DEMO WINDOW -->
        <div class="bd-hero__demo reveal-fade" style="animation-delay:.45s">
          <div class="demo-window">
            <div class="demo-bar">
              <span class="demo-dot demo-dot-r"></span>
              <span class="demo-dot demo-dot-y"></span>
              <span class="demo-dot demo-dot-g"></span>
              <span class="demo-bar-title">Restaurant Ordering — Table 7</span>
            </div>
            <div class="demo-body">

              <!-- Table selector -->
              <div class="demo-table-row">
                <div class="demo-table-btn occupied">T3</div>
                <div class="demo-table-btn occupied">T5</div>
                <div class="demo-table-btn active">T7 ●</div>
                <div class="demo-table-btn">T9</div>
                <div class="demo-table-btn">T11</div>
              </div>

              <!-- Order items animate in -->
              <div class="demo-order-list" id="heroOrderList">
                <div class="demo-order-item" id="hoi1">
                  <span style="font-size:1rem">🥗</span>
                  <span class="doi-name">Caesar Salad</span>
                  <span class="doi-qty">×2</span>
                  <span class="doi-status ready">Ready ✓</span>
                </div>
                <div class="demo-order-item" id="hoi2">
                  <span style="font-size:1rem">🍝</span>
                  <span class="doi-name">Pasta Arrabbiata</span>
                  <span class="doi-qty">×1</span>
                  <span class="doi-status prep" id="hoiPrepStatus">In kitchen…</span>
                </div>
                <div class="demo-order-item" id="hoi3">
                  <span style="font-size:1rem">🍷</span>
                  <span class="doi-name">House Red Wine</span>
                  <span class="doi-qty">×2</span>
                  <span class="doi-status pending">Pending</span>
                </div>
              </div>

              <!-- Dispatch notification -->
              <div class="demo-dispatch" id="heroDispatch">
                <svg class="demo-dispatch-icon" width="18" height="18" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.4"></circle><path d="M6.5 10l2.5 2.5 4.5-4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                <div>
                  <div class="demo-dispatch-text">Pasta Arrabbiata — ready for service</div>
                  <div class="demo-dispatch-sub">Kitchen dispatch · Table 7 · 12 min prep</div>
                </div>
              </div>

            </div>
          </div>

          <!-- Floating badges -->
          <div class="demo-float demo-float-1 reveal-fade" style="animation-delay:.9s">
            <svg viewBox="0 0 16 16" fill="none" width="13" height="13"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3"></circle><path d="M5.5 8l2 2 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            Zero missed orders
          </div>
          <div class="demo-float demo-float-2 reveal-fade" style="animation-delay:1.1s">
            <svg viewBox="0 0 16 16" fill="none" width="13" height="13"><path d="M8 2v4l3 1.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"></path><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3"></circle></svg>
            Live sync
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- STATS -->
  <div class="stats-strip">
    <div class="stat-item"><span class="stat-num" data-count="3">0</span><span class="stat-label">teams connected in real time</span></div>
    <div class="stat-item"><span class="stat-num" data-count="40">0</span><span class="stat-label">% fewer order errors</span></div>
    <div class="stat-item"><span class="stat-num" data-count="2">0</span><span class="stat-label">× faster kitchen response</span></div>
    <div class="stat-item"><span class="stat-num" data-count="0">0</span><span class="stat-label">paper handoffs needed</span></div>
  </div>

  <!-- PROBLEM -->
  <section class="bd-problem">
    <div class="narrow">
      <div class="bd-problem__card" id="problemCard">
        <div class="bd-problem-icon">
          <svg width="52" height="52" viewBox="0 0 48 48" fill="none">
            <rect x="6" y="8" width="20" height="28" rx="3" stroke="currentColor" stroke-width="1.8" stroke-dasharray="4 3"></rect>
            <rect x="16" y="14" width="20" height="26" rx="3" fill="rgba(162,74,42,.06)" stroke="currentColor" stroke-width="1.8" stroke-dasharray="4 3"></rect>
            <circle cx="38" cy="38" r="7" fill="var(--rust-50)" stroke="currentColor" stroke-width="1.8"></circle>
            <path d="M35 38h6M38 35v6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
          </svg>
        </div>
        <div class="bd-problem__text">
          <h2>Restaurants don't struggle because of missing technology. They struggle because the handoffs break down.</h2>
          <p>Paper tickets get lost, orders are mis-heard, kitchen teams work from memory, and floor staff spend more time chasing updates than serving guests. The inefficiency compounds at peak hours when it hurts the most.</p>
          <p>Restaurant Ordering is built to close those gaps — connecting every stage of service into a single, live digital flow.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURE ROWS -->
  <section class="feat-section">
    <div class="container">

      <!-- 1 · CUSTOMER ORDERING -->
      <div class="feat-row" id="customer">
        <div class="feat-copy reveal-up">
          <span class="eyebrow">Customer ordering experience</span>
          <h2 class="sh2">A faster, cleaner way for customers to <em>place their order</em></h2>
          <p>Customers browse a digital menu and submit their order instantly — no waiting for a waiter to take a note, no miscommunication about modifiers, no lost tickets.</p>
          <ul class="bullet-list">
            <li>Digital menu browsing and item selection</li>
            <li>Clear modifier and note options per item</li>
            <li>Reduced dependency on manual order-taking</li>
            <li>Fewer missed orders during peak service</li>
          </ul>
        </div>
        <div class="feat-illu reveal-fade" style="animation-delay:.1s">
          <div class="illu-panel customer-panel" id="customerPanel">
            <div class="cp-header">
              <div class="cp-title">Menu — Table 5</div>
              <div style="display:flex;gap:.45rem;align-items:center">
                <div class="cp-table-tag">Dine-in</div>
                <div class="cp-live"><div class="cp-live-dot"></div>Live</div>
              </div>
            </div>
            <div class="cp-menu-items">
              <div class="cp-menu-item" id="cmi1">
                <span class="cmi-icon">🥗</span>
                <span class="cmi-name">Caesar Salad</span>
                <span class="cmi-price">₹320</span>
                <span class="cmi-add added" id="cmiAdd1">✓</span>
              </div>
              <div class="cp-menu-item" id="cmi2">
                <span class="cmi-icon">🍝</span>
                <span class="cmi-name">Pasta Arrabbiata</span>
                <span class="cmi-price">₹480</span>
                <span class="cmi-add" id="cmiAdd2">+</span>
              </div>
              <div class="cp-menu-item" id="cmi3">
                <span class="cmi-icon">🍗</span>
                <span class="cmi-name">Grilled Chicken</span>
                <span class="cmi-price">₹620</span>
                <span class="cmi-add" id="cmiAdd3">+</span>
              </div>
              <div class="cp-menu-item" id="cmi4">
                <span class="cmi-icon">🍷</span>
                <span class="cmi-name">House Red Wine (glass)</span>
                <span class="cmi-price">₹380</span>
                <span class="cmi-add" id="cmiAdd4">+</span>
              </div>
            </div>
            <div class="cp-order-btn" id="cpOrderBtn">Place order — 1 item · ₹320</div>
          </div>
        </div>
      </div>

      <!-- 2 · WAITER DASHBOARD -->
      <div class="feat-row reverse" id="waiter">
        <div class="feat-copy reveal-up">
          <span class="eyebrow">Waiter and floor operations</span>
          <h2 class="sh2">Real-time visibility for every table <em>on the floor</em></h2>
          <p>Wait staff see every order, its current preparation stage, and which tables need attention — all in one view, updated live as the kitchen works through the queue.</p>
          <ul class="bullet-list">
            <li>Instant order visibility by table number</li>
            <li>Track prep and service status per item</li>
            <li>Manage table assignments and updates</li>
            <li>Coordinate service during rush periods without radios</li>
          </ul>
        </div>
        <div class="feat-illu reveal-fade" style="animation-delay:.1s">
          <div class="illu-panel waiter-panel" id="waiterPanel">
            <div class="wp-header">
              <div class="wp-title">Floor Dashboard</div>
              <div class="wp-badge">8 tables active</div>
            </div>
            <div class="wp-table-grid">
              <div class="wp-table-card" id="wt1"><div class="wp-table-num">T1</div><div class="wp-table-status">Idle</div></div>
              <div class="wp-table-card active" id="wt2"><div class="wp-table-num">T3</div><div class="wp-table-status">Ordering</div></div>
              <div class="wp-table-card serving" id="wt3"><div class="wp-table-num">T5</div><div class="wp-table-status">Serving</div></div>
              <div class="wp-table-card active" id="wt4"><div class="wp-table-num">T7</div><div class="wp-table-status">In kitchen</div></div>
              <div class="wp-table-card" id="wt5"><div class="wp-table-num">T9</div><div class="wp-table-status">Idle</div></div>
              <div class="wp-table-card serving" id="wt6"><div class="wp-table-num">T11</div><div class="wp-table-status">Serving</div></div>
              <div class="wp-table-card active" id="wt7"><div class="wp-table-num">T13</div><div class="wp-table-status">Ordering</div></div>
              <div class="wp-table-card" id="wt8"><div class="wp-table-num">T15</div><div class="wp-table-status">Idle</div></div>
            </div>
            <div class="wp-order-detail" id="wpOrderDetail">
              <div class="wp-od-header">
                <span class="wp-od-table">Table 7 — Active order</span>
                <span class="wp-od-time">Placed 8 min ago</span>
              </div>
              <div class="wp-od-items">
                <div class="wp-od-item"><span class="wp-od-item-dot"></span><span class="wp-od-item-name">Caesar Salad ×2</span><span class="wp-od-item-tag ready">Ready ✓</span></div>
                <div class="wp-od-item"><span class="wp-od-item-dot"></span><span class="wp-od-item-name">Pasta Arrabbiata ×1</span><span class="wp-od-item-tag in-kitchen">In kitchen</span></div>
                <div class="wp-od-item"><span class="wp-od-item-dot"></span><span class="wp-od-item-name">House Red Wine ×2</span><span class="wp-od-item-tag in-kitchen">Pending</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 3 · KITCHEN DISPLAY -->
      <div class="feat-row" id="kitchen">
        <div class="feat-copy reveal-up">
          <span class="eyebrow">Kitchen display and dispatch</span>
          <h2 class="sh2">A structured queue so the kitchen always knows <em>what's next</em></h2>
          <p>Kitchen teams get a live, prioritized order queue — no more shouted tickets or manual relays. Every order arrives digitally, sequenced by table and urgency, so prep flows without bottlenecks.</p>
          <ul class="bullet-list">
            <li>Real-time kitchen queue by order stage</li>
            <li>Zero manual relay from floor staff</li>
            <li>Better batching and prep sequencing</li>
            <li>Clear dispatch status back to service teams</li>
          </ul>
        </div>
        <div class="feat-illu reveal-fade" style="animation-delay:.1s">
          <div class="illu-panel kitchen-panel" id="kitchenPanel">
            <div class="kp-topbar">
              <span class="kp-topbar-title">Kitchen Display — 6 active tickets</span>
              <div style="display:flex;align-items:center;gap:.4rem">
                <div class="kp-live-dot"></div>
                <span style="font-family:var(--ff-m);font-size:.62rem;color:rgba(255,255,255,.35)">Live</span>
              </div>
            </div>
            <div class="kp-queue">
              <div class="kp-ticket new" id="kt1">
                <span class="kp-ticket-num">T3</span>
                <div class="kp-ticket-body">
                  <div class="kp-ticket-table">Table 3 · 2 min ago</div>
                  <div class="kp-ticket-items">Grilled Chicken ×2, Caesar Salad ×1</div>
                  <div class="kp-ticket-meta">
                    <span class="kp-ticket-time">Priority: High</span>
                    <span class="kp-ticket-status">New order</span>
                  </div>
                </div>
              </div>
              <div class="kp-ticket in-progress" id="kt2">
                <span class="kp-ticket-num">T7</span>
                <div class="kp-ticket-body">
                  <div class="kp-ticket-table">Table 7 · 8 min ago</div>
                  <div class="kp-ticket-items">Pasta Arrabbiata ×1</div>
                  <div class="kp-ticket-meta">
                    <span class="kp-ticket-time">~4 min remaining</span>
                    <span class="kp-ticket-status">In progress</span>
                  </div>
                </div>
              </div>
              <div class="kp-ticket done" id="kt3">
                <span class="kp-ticket-num">T5</span>
                <div class="kp-ticket-body">
                  <div class="kp-ticket-table">Table 5 · 14 min ago</div>
                  <div class="kp-ticket-items">Margherita Pizza ×2, Tiramisu ×1</div>
                  <div class="kp-ticket-meta">
                    <span class="kp-ticket-time">Ready · awaiting pickup</span>
                    <span class="kp-ticket-status">Dispatch ✓</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 4 · ORDER PIPELINE -->
      <div class="feat-row reverse" id="pipeline">
        <div class="feat-copy reveal-up">
          <span class="eyebrow">Order pipeline</span>
          <h2 class="sh2">One seamless flow from <em>menu tap to table service</em></h2>
          <p>Restaurant Ordering ties together every stage of an order's journey — placement, confirmation, kitchen prep, dispatch, and service — into a single, transparent pipeline every team can see.</p>
          <ul class="bullet-list">
            <li>Live order status visible to customers, waiters, and kitchen</li>
            <li>Instant notifications at every stage transition</li>
            <li>Shared view eliminates status-chasing conversations</li>
          </ul>
        </div>
        <div class="feat-illu reveal-fade" style="animation-delay:.1s">
          <div class="illu-panel pipeline-panel" id="pipelinePanel">
            <div class="pp-header">Order Flow — Table 9</div>
            <div class="pp-step" id="ps1">
              <div class="pp-step-num">1</div>
              <span class="pp-step-label">Customer places order via digital menu</span>
              <span class="pp-step-tag" style="background:rgba(46,140,79,.1);color:#1c6535;border:1px solid rgba(46,140,79,.2)">Done ✓</span>
            </div>
            <div class="pp-conn"><div class="pp-conn-line"></div></div>
            <div class="pp-step" id="ps2">
              <div class="pp-step-num">2</div>
              <span class="pp-step-label">Order confirmed and sent to kitchen display</span>
              <span class="pp-step-tag" style="background:rgba(46,140,79,.1);color:#1c6535;border:1px solid rgba(46,140,79,.2)">Done ✓</span>
            </div>
            <div class="pp-conn"><div class="pp-conn-line"></div></div>
            <div class="pp-step" id="ps3">
              <div class="pp-step-num">3</div>
              <span class="pp-step-label">Kitchen prepares — status visible to floor</span>
              <span class="pp-step-tag" style="background:rgba(192,120,32,.12);color:var(--amber);border:1px solid rgba(192,120,32,.2)">Live</span>
            </div>
            <div class="pp-conn"><div class="pp-conn-line"></div></div>
            <div class="pp-step" id="ps4">
              <div class="pp-step-num">4</div>
              <span class="pp-step-label">Kitchen dispatches — waiter notified instantly</span>
              <span class="pp-step-tag" style="background:rgba(122,92,76,.08);color:var(--ink-muted);border:1px solid var(--line)">Pending</span>
            </div>
            <div class="pp-outcome" id="ppOutcome">
              <div class="pp-outcome-label">Result</div>
              <div class="pp-outcome-text">Every team knows order status without a single radio call, paper ticket, or shouted update.</div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="bd-how">
    <div class="container">
      <div class="bd-how__header">
        <span class="eyebrow">How it works</span>
        <h2 class="sh2">From tap to table — <em>fully connected</em></h2>
      </div>
      <div class="bd-how__steps">
        <div class="bd-step"><div class="bd-step__number">01</div><div class="bd-step__connector"></div><div class="bd-step__card"><h3>Customer orders digitally</h3><p>Guests browse the digital menu and place their order directly — no waiting, no miscommunication.</p></div></div>
        <div class="bd-step"><div class="bd-step__number">02</div><div class="bd-step__connector"></div><div class="bd-step__card"><h3>Order reaches kitchen instantly</h3><p>The confirmed order appears on the kitchen display immediately, structured and prioritised.</p></div></div>
        <div class="bd-step"><div class="bd-step__number">03</div><div class="bd-step__connector"></div><div class="bd-step__card"><h3>Waiters track every stage</h3><p>Floor staff see prep status, ready items, and table context in real time — no chasing.</p></div></div>
        <div class="bd-step"><div class="bd-step__number">04</div><div class="bd-step__card"><h3>Dispatch and serve</h3><p>When the kitchen dispatches, the right waiter is notified and service completes the loop.</p></div></div>
      </div>
    </div>
  </section>

  <!-- AUDIENCE -->
  <section class="bd-audience">
    <div class="container">
      <div class="bd-audience__grid">
        <div>
          <span class="eyebrow">Who it is for</span>
          <h2 class="sh2">Outlets where <em>coordination and speed</em> determine service quality</h2>
          <p class="bd-audience__sub">If any of these describe your operation, Restaurant Ordering was built for you.</p>
        </div>
        <ul class="bd-audience__list">
          <li class="bd-audience__item" style="animation-delay:.0s"><span class="bd-audience__check"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>Restaurants with high dine-in volume</li>
          <li class="bd-audience__item" style="animation-delay:.08s"><span class="bd-audience__check"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>Cafes and quick-service outlets</li>
          <li class="bd-audience__item" style="animation-delay:.16s"><span class="bd-audience__check"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>Hospitality teams modernising floor operations</li>
          <li class="bd-audience__item" style="animation-delay:.24s"><span class="bd-audience__check"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>Businesses needing tighter waiter-kitchen coordination</li>
          <li class="bd-audience__item" style="animation-delay:.32s"><span class="bd-audience__check"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>Outlets looking to eliminate manual order processing</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bd-cta" id="cta">
    <div class="narrow">
      <div class="bd-cta__card" id="ctaCard">
        <div class="bd-cta__glow" aria-hidden="true"></div>
        <span class="eyebrow">Get started</span>
        <h2>Need faster, cleaner order flow in your outlet?</h2>
        <p class="bd-cta__sub">We can help you set up a system that improves speed, clarity, and service reliability from day one.</p>
        <div class="cta-row center" style="margin-top:1.8rem">
        <a class="btn ghost" href="#customer">See the platform</a>
      </div>
      </div>
    </div>
  </section>

  <footer><p>&copy; 2026 <strong>Nyx Solutions</strong> · Restaurant Ordering — Food and Beverage Product</p></footer>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Sora:wght@300;400;500;600;700&family=DM+Mono:wght@300;400;500&display=swap');

    :root {
      --rust-50:#fdf8ef; --rust-100:#f5ebda; --rust-200:#e9c9a8;
      --rust-300:#da956a; --rust-400:#c56f45; --rust-500:#a24a2a;
      --rust-600:#85361c; --rust-700:#6b2a14;
      --sand-50:#fff8ed; --sand-100:#f5e8d4; --sand-200:#d8c8b3;
      --ink:#1f1a16; --ink-soft:#5f5148; --ink-muted:#7a5c4c;
      --surface:#fdf8ef; --line:rgba(216,200,179,.78); --line-mid:rgba(196,160,126,.45);
      --green:#2e8c4f; --amber:#c07820; --dark-bg:#2e1f19;
      --ff-d:'Instrument Serif',Georgia,serif; --ff-b:'Sora',sans-serif; --ff-m:'DM Mono',monospace;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{
      background:
        radial-gradient(circle at 92% 4%,rgba(162,74,42,.13) 0,rgba(162,74,42,0) 40%),
        radial-gradient(circle at 6% 18%,rgba(255,226,171,.26) 0,rgba(255,226,171,0) 38%),
        var(--surface);
      color:var(--ink);font-family:var(--ff-b);font-size:16px;line-height:1.7;overflow-x:hidden;
    }

    @keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:none}}
    @keyframes fadeScale{from{opacity:0;transform:scale(.93)}to{opacity:1;transform:scale(1)}}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
    @keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-7px)}}
    @keyframes ping{0%{box-shadow:0 0 0 0 rgba(162,74,42,.55)}70%{box-shadow:0 0 0 10px rgba(162,74,42,0)}100%{box-shadow:0 0 0 0 rgba(162,74,42,0)}}
    @keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    @keyframes glowPulse{0%,100%{opacity:.5;transform:scale(1)}50%{opacity:.8;transform:scale(1.07)}}
    @keyframes scanPulse{0%{box-shadow:0 0 0 0 rgba(162,74,42,.35)}70%{box-shadow:0 0 0 8px rgba(162,74,42,0)}100%{box-shadow:0 0 0 0 rgba(162,74,42,0)}}
    @keyframes resultSlide{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}
    @keyframes badgeIn{from{opacity:0;transform:scale(.8) translateY(6px)}to{opacity:1;transform:scale(1) translateY(0)}}
    @keyframes connGrow{from{transform:scaleX(0)}to{transform:scaleX(1)}}
    @keyframes stepIn{from{opacity:0;transform:translateX(-20px)}to{opacity:1;transform:none}}
    @keyframes listIn{from{opacity:0;transform:translateX(16px)}to{opacity:1;transform:none}}
    @keyframes cardFadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:none}}
    @keyframes docSlide{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:none}}
    @keyframes highlightGrow{from{background-size:0% 85%}to{background-size:100% 85%}}
    @keyframes barRise{from{height:0}to{height:var(--bh)}}
    @keyframes notifSlide{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}
    @keyframes pulseRing{0%{transform:scale(1);opacity:.6}100%{transform:scale(1.7);opacity:0}}
    @keyframes orderIn{from{opacity:0;transform:translateY(14px) scale(.97)}to{opacity:1;transform:none}}
    @keyframes kitchenTick{0%{background:rgba(46,140,79,.06)}50%{background:rgba(46,140,79,.18)}100%{background:rgba(46,140,79,.06)}}
    @keyframes statusFlip{0%,40%{opacity:1}50%{opacity:0}60%,100%{opacity:1}}
    @keyframes tableActive{0%,100%{border-color:var(--line)}50%{border-color:var(--rust-400)}}

    .reveal-up{animation:fadeUp .75s cubic-bezier(.22,.85,.44,1) both}
    .reveal-fade{animation:fadeScale .7s cubic-bezier(.22,.85,.44,1) both}

    nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:.9rem 2.8rem;background:rgba(253,248,239,.93);backdrop-filter:blur(16px);border-bottom:1px solid var(--line);transition:padding .3s}
    nav.scrolled{padding-top:.6rem;padding-bottom:.6rem}
    .nav-left{display:flex;align-items:center;gap:.7rem}
    .nav-back{width:34px;height:34px;border-radius:8px;border:1px solid var(--line);background:rgba(255,252,244,.7);color:var(--rust-600);text-decoration:none;display:inline-flex;align-items:center;justify-content:center;transition:background .2s,border-color .2s,transform .15s,color .2s}
    .nav-back:hover{background:var(--rust-50);border-color:var(--rust-300);color:var(--rust-500);transform:translateY(-1px)}
    .nav-back svg{width:14px;height:14px}
    .nav-logo{font-family:var(--ff-d);font-size:1.3rem;font-style:italic;color:var(--rust-600)}
    .nav-links{display:flex;gap:2rem;list-style:none}
    .nav-links a{font-size:.83rem;font-weight:400;color:var(--ink-soft);text-decoration:none;transition:color .2s}
    .nav-links a:hover{color:var(--rust-500)}
    .nav-cta{font-size:.83rem;font-weight:600;padding:.46rem 1.15rem;border-radius:8px;background:var(--rust-500);color:#fff;text-decoration:none;transition:background .2s,transform .15s}
    .nav-cta:hover{background:var(--rust-600);transform:translateY(-1px)}

    .ticker-wrap{margin-top:63px;overflow:hidden;background:linear-gradient(90deg,#f3e6cf,#ecd8b8);border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:.5rem 0}
    .ticker{display:flex;white-space:nowrap;animation:ticker 32s linear infinite}
    .ticker-item{font-size:.7rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--rust-600);padding:0 2.2rem;flex-shrink:0}
    .ticker-item::after{content:'·';margin-left:2.2rem;color:var(--rust-400)}

    .container{max-width:1160px;margin:0 auto;padding:0 2.4rem}
    .narrow{max-width:820px;margin:0 auto;padding:0 2.4rem}
    .eyebrow{font-size:.7rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--rust-500);display:block;margin-bottom:.55rem}
    .sh2{font-family:var(--ff-d);font-size:clamp(1.8rem,3.2vw,2.6rem);font-weight:400;line-height:1.18;letter-spacing:-.01em;color:var(--ink)}
    .sh2 em{font-style:italic;color:var(--rust-500)}
    .btn{display:inline-block;font-size:.88rem;font-weight:600;border-radius:8px;text-decoration:none;padding:.66rem 1.5rem;transition:background .2s,transform .15s,box-shadow .2s}
    .btn.primary{background:var(--rust-500);color:#fff;box-shadow:0 4px 18px rgba(162,74,42,.28)}
    .btn.primary:hover{background:var(--rust-600);transform:translateY(-2px)}
    .btn.ghost{border:1.5px solid var(--line-mid);color:var(--rust-600)}
    .btn.ghost:hover{background:var(--rust-50);transform:translateY(-2px)}
    .cta-row{display:flex;gap:.85rem;flex-wrap:wrap}
    .cta-row.center{justify-content:center}

    .bd-hero{padding:5.5rem 0 4.5rem;position:relative;overflow:hidden}
    .bd-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 55% at 80% 10%,rgba(162,74,42,.11),transparent),radial-gradient(ellipse 45% 55% at 5% 90%,rgba(255,215,140,.18),transparent);pointer-events:none}
    .bd-hero::after{content:'';position:absolute;inset:0;background-image:linear-gradient(var(--line) 1px,transparent 1px),linear-gradient(90deg,var(--line) 1px,transparent 1px);background-size:48px 48px;mask-image:radial-gradient(ellipse 75% 75% at 68% 38%,black 0%,transparent 100%);pointer-events:none}
    .bd-hero__grid{display:grid;grid-template-columns:1fr 1.1fr;gap:3.5rem;align-items:center}
    .bd-hero__eyebrow{display:inline-flex;align-items:center;gap:.55rem;margin-bottom:.9rem}
    .eyebrow-dot{width:8px;height:8px;border-radius:50%;background:var(--rust-500);animation:ping 2.2s ease-in-out infinite}
    .eyebrow-text{font-size:.7rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--rust-600)}
    .bd-hero__h1{font-family:var(--ff-d);font-size:clamp(2.4rem,4.8vw,4rem);line-height:1.1;letter-spacing:-.01em;color:var(--ink);margin-bottom:1.2rem}
    .bd-hero__h1 em{font-style:italic;color:var(--rust-500);position:relative}
    .bd-hero__h1 em::after{content:'';position:absolute;left:0;right:0;bottom:-3px;height:2px;border-radius:2px;background:var(--rust-400);opacity:.4}
    .bd-hero__lead{font-size:1.04rem;font-weight:300;color:var(--ink-soft);line-height:1.75;max-width:50ch;margin-bottom:1.9rem}

    .bd-hero__demo{position:relative}
    .demo-window{border:1.5px solid var(--line-mid);border-radius:20px;background:rgba(255,252,242,.97);box-shadow:0 28px 72px rgba(75,42,21,.13),0 4px 18px rgba(75,42,21,.06);overflow:hidden}
    .demo-bar{display:flex;align-items:center;gap:.45rem;padding:.7rem 1rem;background:rgba(245,235,218,.7);border-bottom:1px solid var(--line)}
    .demo-dot{width:10px;height:10px;border-radius:50%}
    .demo-dot-r{background:#f06257}.demo-dot-y{background:#f5a623}.demo-dot-g{background:#57c257}
    .demo-bar-title{margin-left:.4rem;font-size:.78rem;font-weight:600;color:var(--ink-soft);letter-spacing:.04em;font-family:var(--ff-m)}
    .demo-body{padding:1.1rem;display:flex;flex-direction:column;gap:.85rem}

    .demo-table-row{display:flex;gap:.45rem;flex-wrap:wrap}
    .demo-table-btn{font-family:var(--ff-m);font-size:.7rem;font-weight:600;border:1.5px solid var(--line);border-radius:8px;padding:.32rem .65rem;cursor:default;transition:all .25s;color:var(--ink-muted)}
    .demo-table-btn.active{border-color:var(--rust-400);background:rgba(162,74,42,.08);color:var(--rust-600)}
    .demo-table-btn.occupied{border-color:var(--rust-300);background:rgba(162,74,42,.05);color:var(--rust-500)}

    .demo-order-list{display:flex;flex-direction:column;gap:.38rem}
    .demo-order-item{display:flex;align-items:center;gap:.55rem;padding:.45rem .7rem;border-radius:9px;background:#fff;border:1px solid var(--line);opacity:0}
    .demo-order-item.show{animation:orderIn .4s cubic-bezier(.22,.85,.44,1) forwards}
    .doi-name{font-size:.82rem;font-weight:500;color:var(--ink);flex:1}
    .doi-qty{font-family:var(--ff-m);font-size:.72rem;color:var(--ink-muted)}
    .doi-status{font-family:var(--ff-m);font-size:.62rem;font-weight:600;letter-spacing:.05em;border-radius:999px;padding:.14rem .48rem;flex-shrink:0}
    .doi-status.pending{background:rgba(192,120,32,.1);color:var(--amber);border:1px solid rgba(192,120,32,.2)}
    .doi-status.prep{background:rgba(162,74,42,.1);color:var(--rust-600);border:1px solid rgba(162,74,42,.2);animation:scanPulse 1.4s ease infinite}
    .doi-status.ready{background:rgba(46,140,79,.1);color:#1c6535;border:1px solid rgba(46,140,79,.2)}

    .demo-dispatch{display:flex;align-items:center;gap:.55rem;border-radius:11px;padding:.7rem .85rem;background:linear-gradient(145deg,rgba(240,255,245,.95),rgba(228,248,235,.85));border:1.5px solid #c8e6d0;opacity:0;animation:resultSlide .5s cubic-bezier(.22,.85,.44,1) both;animation-play-state:paused}
    .demo-dispatch.show{animation-play-state:running}
    .demo-dispatch-icon{color:var(--green);flex-shrink:0}
    .demo-dispatch-text{font-size:.82rem;font-weight:500;color:var(--ink)}
    .demo-dispatch-sub{font-family:var(--ff-m);font-size:.68rem;color:#3a7a4a}

    .demo-float{position:absolute;display:flex;align-items:center;gap:.4rem;font-size:.74rem;font-weight:600;color:#5a3d2e;background:rgba(255,248,232,.95);border:1.5px solid var(--line);border-radius:999px;padding:.42rem .82rem;box-shadow:0 6px 20px rgba(75,42,21,.12);white-space:nowrap;animation:floatY 3s ease-in-out infinite}
    .demo-float svg{width:13px;height:13px;flex-shrink:0}
    .demo-float-1{bottom:-1rem;left:-1.8rem;animation-delay:0s}
    .demo-float-2{top:1.2rem;right:-1.8rem;animation-delay:1.4s}

    .stats-strip{background:var(--dark-bg);display:grid;grid-template-columns:repeat(4,1fr);gap:1px;overflow:hidden}
    .stat-item{text-align:center;padding:2.2rem 1rem;position:relative}
    .stat-item:not(:last-child)::after{content:'';position:absolute;right:0;top:25%;bottom:25%;width:1px;background:rgba(255,255,255,.07)}
    .stat-num{font-family:var(--ff-d);font-size:2.6rem;font-style:italic;color:var(--rust-300);display:block;line-height:1;margin-bottom:.35rem}
    .stat-label{font-size:.72rem;font-weight:400;color:rgba(255,255,255,.38);letter-spacing:.06em;text-transform:uppercase}

    .bd-problem{padding:4rem 0}
    .bd-problem__card{display:grid;grid-template-columns:auto 1fr;gap:2.4rem;align-items:start;border:1.5px solid var(--line);border-radius:26px;padding:2.8rem 2.4rem;background:linear-gradient(148deg,rgba(255,245,228,.98),rgba(250,232,198,.9));box-shadow:0 16px 48px rgba(75,42,21,.09);opacity:0}
    .bd-problem__card.in-view{animation:fadeUp .8s cubic-bezier(.22,.85,.44,1) forwards}
    .bd-problem-icon{color:var(--rust-500);flex-shrink:0}
    .bd-problem__text h2{font-family:var(--ff-d);font-size:clamp(1.6rem,2.8vw,2.3rem);letter-spacing:-.02em;line-height:1.2;color:var(--ink);margin-bottom:1rem}
    .bd-problem__text p{color:var(--ink-soft);line-height:1.72;max-width:66ch}
    .bd-problem__text p+p{margin-top:.7rem}

    .feat-section{padding:4rem 0 2rem}
    .feat-row{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;padding:5rem 0;border-bottom:1px solid var(--line)}
    .feat-row:last-child{border-bottom:none}
    .feat-row.reverse .feat-copy{order:2}
    .feat-row.reverse .feat-illu{order:1}
    .feat-copy .sh2{margin-bottom:1rem}
    .feat-copy p{font-size:.97rem;font-weight:300;color:var(--ink-soft);line-height:1.75;margin-bottom:1rem}
    .feat-copy .bullet-list{list-style:none;display:grid;gap:.55rem}
    .feat-copy .bullet-list li{position:relative;padding-left:1.1rem;font-size:.9rem;color:var(--ink-soft)}
    .feat-copy .bullet-list li::before{content:'';position:absolute;left:0;top:.6em;width:6px;height:6px;border-radius:50%;background:var(--rust-400)}

    .illu-panel{border:1.5px solid var(--line-mid);border-radius:18px;background:var(--sand-50);overflow:hidden;position:relative}

    .customer-panel{padding:1.4rem;min-height:340px;display:flex;flex-direction:column;gap:.7rem}
    .cp-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:.2rem}
    .cp-title{font-family:var(--ff-m);font-size:.72rem;font-weight:600;color:var(--ink)}
    .cp-live{display:flex;align-items:center;gap:.35rem;font-family:var(--ff-m);font-size:.65rem;color:var(--green)}
    .cp-live-dot{width:5px;height:5px;border-radius:50%;background:var(--green);animation:ping 2s ease-in-out infinite}
    .cp-table-tag{font-family:var(--ff-m);font-size:.7rem;font-weight:600;color:var(--rust-600);background:rgba(162,74,42,.08);border:1px solid rgba(162,74,42,.18);border-radius:999px;padding:.2rem .55rem}

    .cp-menu-items{display:flex;flex-direction:column;gap:.4rem}
    .cp-menu-item{display:flex;align-items:center;gap:.6rem;padding:.52rem .75rem;border-radius:10px;background:#fff;border:1px solid var(--line);opacity:0;cursor:default;transition:border-color .2s,box-shadow .2s}
    .cp-menu-item.show{animation:docSlide .4s cubic-bezier(.22,.85,.44,1) forwards}
    .cp-menu-item.selected{border-color:var(--rust-400);background:rgba(162,74,42,.04)}
    .cmi-icon{font-size:1.1rem;flex-shrink:0}
    .cmi-name{font-size:.82rem;font-weight:500;color:var(--ink);flex:1}
    .cmi-price{font-family:var(--ff-m);font-size:.72rem;color:var(--ink-muted)}
    .cmi-add{width:22px;height:22px;border-radius:6px;background:var(--rust-500);color:#fff;display:flex;align-items:center;justify-content:center;font-size:.9rem;font-weight:700;flex-shrink:0;transition:transform .15s}
    .cmi-add.added{background:var(--green)}

    .cp-order-btn{margin-top:.4rem;width:100%;padding:.6rem;border-radius:10px;background:linear-gradient(135deg,var(--rust-500),var(--rust-700));color:#fff;font-size:.82rem;font-weight:600;text-align:center;border:none;cursor:default;box-shadow:0 4px 14px rgba(162,74,42,.28);opacity:0;animation:fadeUp .4s ease both;animation-play-state:paused}
    .cp-order-btn.show{animation-play-state:running}

    .waiter-panel{padding:1.4rem;min-height:340px;display:flex;flex-direction:column;gap:.65rem}
    .wp-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:.2rem}
    .wp-title{font-family:var(--ff-m);font-size:.72rem;font-weight:600;color:var(--ink)}
    .wp-badge{font-family:var(--ff-m);font-size:.64rem;font-weight:600;color:var(--rust-600);background:rgba(162,74,42,.1);border:1px solid rgba(162,74,42,.2);border-radius:999px;padding:.15rem .5rem}

    .wp-table-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.45rem}
    .wp-table-card{border-radius:10px;border:1.5px solid var(--line);padding:.6rem .5rem;text-align:center;background:#fff;cursor:default;transition:all .25s;opacity:0}
    .wp-table-card.show{animation:cardFadeUp .38s ease forwards}
    .wp-table-card.active{border-color:var(--rust-400);background:rgba(162,74,42,.05)}
    .wp-table-card.serving{border-color:var(--green);background:rgba(46,140,79,.05)}
    .wp-table-num{font-family:var(--ff-m);font-size:.75rem;font-weight:700;color:var(--ink-soft)}
    .wp-table-status{font-family:var(--ff-m);font-size:.58rem;font-weight:500;margin-top:.15rem}
    .wp-table-card.active .wp-table-status{color:var(--rust-600)}
    .wp-table-card.serving .wp-table-status{color:var(--green)}
    .wp-table-card .wp-table-status{color:var(--ink-muted)}

    .wp-order-detail{background:#fff;border:1px solid var(--line);border-radius:12px;padding:.85rem;opacity:0}
    .wp-order-detail.show{animation:resultSlide .5s ease .4s forwards}
    .wp-od-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:.6rem}
    .wp-od-table{font-family:var(--ff-m);font-size:.72rem;font-weight:600;color:var(--ink)}
    .wp-od-time{font-family:var(--ff-m);font-size:.64rem;color:var(--ink-muted)}
    .wp-od-items{display:flex;flex-direction:column;gap:.32rem}
    .wp-od-item{display:flex;align-items:center;gap:.5rem;font-size:.8rem}
    .wp-od-item-dot{width:5px;height:5px;border-radius:50%;background:var(--rust-400);flex-shrink:0}
    .wp-od-item-name{flex:1;color:var(--ink-soft)}
    .wp-od-item-tag{font-family:var(--ff-m);font-size:.6rem;font-weight:600;border-radius:999px;padding:.1rem .42rem}
    .wp-od-item-tag.in-kitchen{background:rgba(192,120,32,.12);color:var(--amber);border:1px solid rgba(192,120,32,.2)}
    .wp-od-item-tag.ready{background:rgba(46,140,79,.1);color:#1c6535;border:1px solid rgba(46,140,79,.2)}

    .kitchen-panel{padding:0;background:#2a1e14;min-height:340px;overflow:hidden}
    .kp-topbar{display:flex;align-items:center;justify-content:space-between;padding:.8rem 1.2rem;border-bottom:1px solid rgba(255,255,255,.08)}
    .kp-topbar-title{font-family:var(--ff-m);font-size:.72rem;font-weight:600;color:rgba(255,255,255,.6)}
    .kp-live-dot{width:6px;height:6px;border-radius:50%;background:#57c257;animation:ping 2s ease-in-out infinite;box-shadow:0 0 0 0 rgba(87,194,87,.4)}

    .kp-queue{display:flex;flex-direction:column;gap:.5rem;padding:1rem 1.2rem}
    .kp-ticket{border-radius:10px;padding:.65rem .85rem;display:flex;align-items:flex-start;gap:.7rem;border:1px solid rgba(255,255,255,.06);opacity:0}
    .kp-ticket.show{animation:orderIn .4s ease forwards}
    .kp-ticket.new{background:rgba(162,74,42,.25);border-color:rgba(162,74,42,.4)}
    .kp-ticket.in-progress{background:rgba(192,120,32,.18);border-color:rgba(192,120,32,.35)}
    .kp-ticket.done{background:rgba(46,140,79,.15);border-color:rgba(46,140,79,.3)}
    .kp-ticket-num{font-family:var(--ff-m);font-size:.62rem;font-weight:700;border-radius:6px;padding:.2rem .45rem;flex-shrink:0;margin-top:.05rem}
    .kp-ticket.new .kp-ticket-num{background:rgba(162,74,42,.4);color:#f5c09e}
    .kp-ticket.in-progress .kp-ticket-num{background:rgba(192,120,32,.4);color:#f5d08e}
    .kp-ticket.done .kp-ticket-num{background:rgba(46,140,79,.4);color:#9edcb2}
    .kp-ticket-body{flex:1}
    .kp-ticket-table{font-family:var(--ff-m);font-size:.64rem;color:rgba(255,255,255,.38);margin-bottom:.22rem}
    .kp-ticket-items{font-size:.8rem;color:rgba(255,255,255,.75);line-height:1.5}
    .kp-ticket-meta{display:flex;align-items:center;justify-content:space-between;margin-top:.35rem}
    .kp-ticket-time{font-family:var(--ff-m);font-size:.6rem;color:rgba(255,255,255,.3)}
    .kp-ticket-status{font-family:var(--ff-m);font-size:.6rem;font-weight:600;border-radius:999px;padding:.12rem .42rem}
    .kp-ticket.new .kp-ticket-status{background:rgba(162,74,42,.3);color:#f5c09e}
    .kp-ticket.in-progress .kp-ticket-status{background:rgba(192,120,32,.3);color:#f5d08e}
    .kp-ticket.done .kp-ticket-status{background:rgba(46,140,79,.25);color:#9edcb2}

    .pipeline-panel{padding:1.4rem;min-height:340px;display:flex;flex-direction:column;gap:.6rem}
    .pp-header{font-family:var(--ff-m);font-size:.72rem;font-weight:600;color:var(--ink);margin-bottom:.2rem}
    .pp-step{display:flex;align-items:center;gap:.75rem;padding:.65rem .85rem;border-radius:10px;background:#fff;border:1px solid var(--line);opacity:0}
    .pp-step.show{animation:cardFadeUp .45s ease forwards}
    .pp-step-num{width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,var(--rust-500),var(--rust-700));color:#fff8ee;font-size:.68rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 3px 10px rgba(162,74,42,.28)}
    .pp-step-label{font-size:.82rem;font-weight:500;color:var(--ink);flex:1}
    .pp-step-tag{font-family:var(--ff-m);font-size:.62rem;font-weight:600;border-radius:999px;padding:.14rem .5rem;flex-shrink:0}
    .pp-conn{padding:0 .85rem;height:14px;display:flex;align-items:center}
    .pp-conn-line{width:1px;height:14px;background:var(--line);margin-left:12px}

    .pp-outcome{margin-top:.3rem;border-radius:12px;background:linear-gradient(145deg,rgba(240,255,245,.9),rgba(228,248,235,.8));border:1.5px solid #c8e6d0;padding:.85rem;opacity:0}
    .pp-outcome.show{animation:cardFadeUp .45s ease .8s forwards}
    .pp-outcome-label{font-family:var(--ff-m);font-size:.65rem;font-weight:600;color:#3a5c42;text-transform:uppercase;letter-spacing:.08em;margin-bottom:.3rem}
    .pp-outcome-text{font-size:.84rem;color:var(--ink);line-height:1.6}

    .bd-how{padding:5rem 0;background:linear-gradient(180deg,transparent,rgba(250,240,224,.45) 40%,transparent)}
    .bd-how__header{margin-bottom:2.5rem}
    .bd-how__steps{display:grid;grid-template-columns:repeat(4,1fr);gap:0;position:relative}
    .bd-step{position:relative;opacity:0;animation:stepIn .6s cubic-bezier(.22,.85,.44,1) both;animation-play-state:paused}
    .bd-step.in-view{animation-play-state:running}
    .bd-step:nth-child(1){animation-delay:0s}
    .bd-step:nth-child(2){animation-delay:.13s}
    .bd-step:nth-child(3){animation-delay:.26s}
    .bd-step:nth-child(4){animation-delay:.39s}
    .bd-step__number{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--rust-500),var(--rust-700));color:#fff8ee;font-size:.74rem;font-weight:700;letter-spacing:.05em;display:flex;align-items:center;justify-content:center;margin-bottom:1rem;position:relative;z-index:2;box-shadow:0 4px 16px rgba(162,74,42,.3)}
    .bd-step__connector{position:absolute;top:21px;left:calc(42px + 1rem);right:-1rem;height:1.5px;background:var(--line);transform-origin:left;animation:connGrow .55s ease both;animation-play-state:paused}
    .bd-step.in-view .bd-step__connector{animation-play-state:running}
    .bd-step:last-child .bd-step__connector{display:none}
    .bd-step__card{padding-right:1.4rem}
    .bd-step__card h3{font-size:.97rem;font-weight:600;color:var(--ink);margin-bottom:.42rem}
    .bd-step__card p{font-size:.86rem;font-weight:300;color:var(--ink-soft);line-height:1.68}

    .bd-audience{padding:5rem 0;background:linear-gradient(to bottom,rgba(250,240,225,.4),transparent)}
    .bd-audience__grid{display:grid;grid-template-columns:1fr 1fr;gap:4.5rem;align-items:start}
    .bd-audience__list{display:grid;gap:.7rem;margin-top:1.2rem}
    .bd-audience__item{display:flex;align-items:center;gap:.85rem;font-size:.96rem;font-weight:500;color:var(--ink);opacity:0;animation:listIn .5s ease both;animation-play-state:paused}
    .bd-audience__item.in-view{animation-play-state:running}
    .bd-audience__check{width:28px;height:28px;border-radius:50%;background:rgba(162,74,42,.1);border:1.5px solid rgba(162,74,42,.22);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--rust-500)}
    .bd-audience__check svg{width:13px;height:13px}
    .bd-audience__sub{font-size:.95rem;font-weight:300;color:var(--ink-soft);line-height:1.72;margin-top:.9rem}

    .bd-cta{padding:3rem 0 5.5rem}
    .bd-cta__card{position:relative;border:1.5px solid var(--line);border-radius:26px;padding:3.8rem 3.2rem;background:linear-gradient(148deg,rgba(255,246,230,.98),rgba(252,233,200,.9));box-shadow:0 24px 64px rgba(75,42,21,.1);text-align:center;overflow:hidden;opacity:0}
    .bd-cta__card.in-view{animation:fadeUp .8s cubic-bezier(.22,.85,.44,1) forwards}
    .bd-cta__glow{position:absolute;top:-60px;right:-60px;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(162,74,42,.13),transparent 70%);animation:glowPulse 4s ease-in-out infinite;pointer-events:none}
    .bd-cta__card h2{font-family:var(--ff-d);font-size:clamp(1.5rem,2.8vw,2.2rem);letter-spacing:-.02em;line-height:1.22;color:var(--ink);max-width:56ch;margin:.6rem auto 0}
    .bd-cta__sub{margin-top:.9rem;color:var(--ink-soft);font-size:1rem;font-weight:300}

    footer{background:var(--dark-bg);color:rgba(255,255,255,.35);text-align:center;padding:2rem 2.4rem;font-size:.82rem;font-weight:300}
    footer strong{color:var(--rust-300);font-weight:500}

    @media(max-width:980px){
      nav{padding:.9rem 1.5rem}.nav-links{display:none}
      .bd-hero__grid,.feat-row,.bd-audience__grid,.bd-problem__card{grid-template-columns:1fr}
      .feat-row.reverse .feat-copy,.feat-row.reverse .feat-illu{order:unset}
      .bd-how__steps{grid-template-columns:1fr 1fr;gap:1.4rem}.bd-step__connector{display:none}
      .stats-strip{grid-template-columns:repeat(2,1fr)}
      .demo-float-1,.demo-float-2{display:none}
    }
    @media(max-width:600px){
      .bd-how__steps{grid-template-columns:1fr}.bd-cta__card{padding:2.2rem 1.4rem}
      .wp-table-grid{grid-template-columns:repeat(2,1fr)}
    }
  </style>

  <script is:inline>
    const nav = document.getElementById('mainnav');
    window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', scrollY > 40), { passive: true });

    const seen = new Set();
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting || seen.has(e.target)) return;
        seen.add(e.target);
        e.target.classList.add('in-view');
        const id = e.target.id;
        if (id === 'customerPanel') triggerCustomerPanel();
        if (id === 'waiterPanel') triggerWaiterPanel();
        if (id === 'kitchenPanel') triggerKitchenPanel();
        if (id === 'pipelinePanel') triggerPipelinePanel();
        io.unobserve(e.target);
      });
    }, { threshold: .15, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll(
      '.reveal-up, .reveal-fade, .bd-step, .bd-audience__item, #customerPanel, #waiterPanel, #kitchenPanel, #pipelinePanel, #problemCard, #ctaCard'
    ).forEach(el => io.observe(el));

    const cio = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const el = e.target;
        const target = +el.dataset.count;
        if (target === 0) { el.textContent = '0'; cio.unobserve(el); return; }
        let v = 0;
        const step = Math.ceil(target / 40);
        const t = setInterval(() => { v = Math.min(v + step, target); el.textContent = v; if (v >= target) clearInterval(t); }, 35);
        cio.unobserve(el);
      });
    }, { threshold: .5 });
    document.querySelectorAll('[data-count]').forEach(el => cio.observe(el));

    function runHeroDemo() {
      const items = ['hoi1','hoi2','hoi3'];
      items.forEach((id, i) => {
        const el = document.getElementById(id);
        if (el) setTimeout(() => el.classList.add('show'), i * 200 + 400);
      });
      setTimeout(() => {
        const status = document.getElementById('hoiPrepStatus');
        if (status) {
          status.textContent = 'Ready ✓';
          status.className = 'doi-status ready';
        }
        const dispatch = document.getElementById('heroDispatch');
        if (dispatch) dispatch.classList.add('show');
      }, 3200);
      setTimeout(() => {
        items.forEach(id => {
          const el = document.getElementById(id);
          if (el) el.classList.remove('show');
        });
        const dispatch = document.getElementById('heroDispatch');
        if (dispatch) dispatch.classList.remove('show');
        const status = document.getElementById('hoiPrepStatus');
        if (status) {
          status.textContent = 'In kitchen…';
          status.className = 'doi-status prep';
        }
        setTimeout(runHeroDemo, 400);
      }, 7000);
    }
    setTimeout(runHeroDemo, 700);

    function triggerCustomerPanel() {
      ['cmi1','cmi2','cmi3','cmi4'].forEach((id, i) => {
        const el = document.getElementById(id);
        if (el) setTimeout(() => el.classList.add('show'), i * 120 + 100);
      });
      setTimeout(() => {
        const item2 = document.getElementById('cmi2');
        const add2 = document.getElementById('cmiAdd2');
        item2?.classList.add('selected');
        if (add2) { add2.textContent = '✓'; add2.classList.add('added'); }
        const btn = document.getElementById('cpOrderBtn');
        if (btn) {
          btn.textContent = 'Place order — 2 items · ₹800';
          btn.classList.add('show');
        }
      }, 1200);
      setTimeout(() => {
        const item4 = document.getElementById('cmi4');
        const add4 = document.getElementById('cmiAdd4');
        item4?.classList.add('selected');
        if (add4) { add4.textContent = '✓'; add4.classList.add('added'); }
        const btn = document.getElementById('cpOrderBtn');
        if (btn) btn.textContent = 'Place order — 3 items · ₹1180';
      }, 2400);
    }

    function triggerWaiterPanel() {
      ['wt1','wt2','wt3','wt4','wt5','wt6','wt7','wt8'].forEach((id, i) => {
        const el = document.getElementById(id);
        if (el) setTimeout(() => el.classList.add('show'), i * 80 + 100);
      });
      setTimeout(() => {
        const od = document.getElementById('wpOrderDetail');
        od?.classList.add('show');
      }, 900);
    }

    function triggerKitchenPanel() {
      ['kt1','kt2','kt3'].forEach((id, i) => {
        const el = document.getElementById(id);
        if (el) setTimeout(() => el.classList.add('show'), i * 200 + 150);
      });
    }

    function triggerPipelinePanel() {
      ['ps1','ps2','ps3','ps4'].forEach((id, i) => {
        const el = document.getElementById(id);
        if (el) setTimeout(() => el.classList.add('show'), i * 200 + 100);
      });
      setTimeout(() => {
        const out = document.getElementById('ppOutcome');
        out?.classList.add('show');
      }, 1200);
      setTimeout(() => {
        const ps4 = document.getElementById('ps4');
        const tag = ps4?.querySelector('.pp-step-tag');
        if (tag) {
          tag.style.background = 'rgba(46,140,79,.1)';
          tag.style.color = '#1c6535';
          tag.style.borderColor = 'rgba(46,140,79,.2)';
          tag.textContent = 'Done ✓';
        }
      }, 3500);
    }
  </script>
</MainLayout>
