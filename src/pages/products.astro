<script>
/* ─── INTERSECTION OBSERVER ─── */
const seen = new Set();
const io = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (!e.isIntersecting || seen.has(e.target)) return;
    seen.add(e.target);
    e.target.classList.add('iv');
    const id = e.target.id;
    if (id === 'briefly-docs')  setTimeout(initBriefly, 400);
    if (id === 'sales-tracking') setTimeout(initSales, 400);
    if (id === 'school-erp')    setTimeout(initSchool, 400);
    if (id === 'mobility')       setTimeout(initCarpool, 400);
    if (id === 'creative-ai')   setTimeout(initPhoto, 400);
    if (id === 'hotel')         setTimeout(initHotel, 400);
    if (id === 'restaurant')    setTimeout(initRest, 400);
    if (id === 'ctaCard')       e.target.classList.add('iv');
    io.unobserve(e.target);
  });
}, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

document.querySelectorAll('.prod, #ctaCard').forEach(el => io.observe(el));

/* ─── 01: BRIEFLY DOCS ─── */
function initBriefly() {
  const phrases = [
    'How many annual leave days?',
    'What is our notice period?',
    'Which SOP covers travel claims?',
  ];
  const typedEl = document.getElementById('briefly-typed');
  const hl1 = document.getElementById('hl1');
  const hl2 = document.getElementById('hl2');
  const result = document.getElementById('briefly-result');
  if (!typedEl) return;
  let pi = 0;

  function cycle() {
    const phrase = phrases[pi++ % phrases.length];
    typedEl.textContent = '';
    hl1.classList.remove('lit'); hl2.classList.remove('lit');
    result.style.opacity = '0';
    let i = 0;
    const iv = setInterval(() => {
      typedEl.textContent = phrase.slice(0, ++i);
      if (i >= phrase.length) {
        clearInterval(iv);
        setTimeout(() => { hl1.classList.add('lit'); }, 400);
        setTimeout(() => { hl2.classList.add('lit'); }, 700);
        setTimeout(() => { result.style.opacity = '1'; result.style.animation = 'resultIn .4s ease both'; }, 1100);
        setTimeout(cycle, 4200);
      }
    }, 45);
  }
  cycle();
}

/* ─── 02: SALES TRACKING ─── */
function initSales() {
  const trail = document.getElementById('sales-trail');
  if (trail) {
    trail.style.transition = 'stroke-dashoffset 2.2s cubic-bezier(.4,0,.2,1)';
    trail.style.strokeDashoffset = '0';
  }
  const pins = ['sp1','sp2','sp3','sp4','sp5'];
  const rings = ['sr1','sr2','sr3','sr4','sr5'];
  pins.forEach((id, i) => {
    setTimeout(() => {
      const el = document.getElementById(id);
      if (el) { el.style.transition = 'opacity .3s ease'; el.style.opacity = '1'; }
      const r = document.getElementById(rings[i]);
      if (r) {
        r.style.opacity = '1';
        r.style.animation = `ripple 2s ease-out ${i*0.3}s infinite`;
      }
    }, 400 + i * 350);
  });
  setTimeout(() => {
    ['sl1','sl2','sl3'].forEach(id => {
      const el = document.getElementById(id);
      if (el) { el.style.transition = 'opacity .4s ease'; el.style.opacity = '1'; }
    });
  }, 2800);
}

/* ─── 03: SCHOOL ERP ─── */
function initSchool() {
  const grid = document.getElementById('vs-grid');
  if (!grid) return;
  // 28 students: 22 present, 3 absent, 3 holiday
  const states = Array(22).fill('p').concat(Array(3).fill('a')).concat(Array(3).fill('h'));
  states.sort(() => Math.random() - .5);
  states.forEach((s, i) => {
    const cell = document.createElement('div');
    cell.className = 'vs-cell';
    cell.dataset.state = s;
    grid.appendChild(cell);
    setTimeout(() => {
      cell.classList.add(s);
      cell.textContent = s === 'p' ? '✓' : s === 'a' ? '✗' : '—';
    }, i * 55 + 100);
  });
  // rows
  ['vsr1','vsr2','vsr3'].forEach((id, i) => {
    setTimeout(() => {
      const el = document.getElementById(id);
      if (el) el.classList.add('show');
    }, 1600 + i * 180);
  });
}

/* ─── 04: CARPOOLING ─── */
function initCarpool() {
  const car1 = document.getElementById('car1');
  const car2 = document.getElementById('car2');
  const status = document.getElementById('cstatus');
  if (!car1) return;

  function moveCars() {
    // car1 moves right toward center
    car1.style.transition = 'transform 2.2s cubic-bezier(.4,0,.2,1)';
    car1.style.transform = 'translateX(100px)';
    // car2 moves left toward center
    car2.style.transition = 'transform 2.2s cubic-bezier(.4,0,.2,1)';
    car2.style.transform = 'translateX(-100px)';
    setTimeout(() => {
      if (status) { status.style.transition = 'opacity .4s'; status.style.opacity = '1'; }
    }, 1800);
    // reset
    setTimeout(() => {
      car1.style.transition = 'none'; car1.style.transform = '';
      car2.style.transition = 'none'; car2.style.transform = '';
      if (status) status.style.opacity = '0';
      setTimeout(moveCars, 600);
    }, 4000);
  }
  moveCars();
}

/* ─── 05: AI PHOTOSHOOTS ─── */
function initPhoto() {
  const pills = [1,2,3].map(n => document.getElementById('pa-pill-'+n));
  const panels = [1,2,3].map(n => document.getElementById('pa-p'+n));
  const tags = document.querySelectorAll('.pa-tag');

  function setPill(idx) {
    pills.forEach((p, i) => {
      if (!p) return;
      p.classList.remove('active','done');
      if (i < idx) p.classList.add('done');
      if (i === idx) p.classList.add('active');
      p.style.color = i === idx ? '#a24a2a' : i < idx ? '#1c6535' : '#8a7060';
      p.style.background = i === idx ? 'rgba(162,74,42,.08)' : i < idx ? 'rgba(46,140,79,.08)' : 'transparent';
    });
  }

  function showPanel(idx) {
    panels.forEach((p, i) => {
      if (!p) return;
      p.style.display = i === idx ? 'flex' : 'none';
    });
  }

  async function delay(ms) { return new Promise(r => setTimeout(r, ms)); }

  async function runCycle() {
    setPill(0); showPanel(0);
    tags.forEach((t, i) => {
      t.classList.remove('show');
      setTimeout(() => t.classList.add('show'), i * 120 + 300);
    });
    await delay(3600);

    setPill(1); showPanel(1);
    await delay(3400);

    setPill(2); showPanel(2);
    const frames = [1,2,3].map(n => document.getElementById('paf'+n));
    const countEl = document.getElementById('pa-result-count');
    const dlRow = document.getElementById('pa-dl-row');
    frames.forEach(f => {
      if (f) {
        f.classList.remove('show');
        f.style.opacity = '0';
        f.style.transform = 'scale(.88)';
      }
    });
    if (dlRow) dlRow.style.opacity = '0';
    frames.forEach((f, i) => {
      setTimeout(() => {
        if (f) f.classList.add('show');
        if (countEl) countEl.textContent = (i + 1) + ' image' + (i > 0 ? 's' : '');
      }, i * 260 + 200);
    });
    setTimeout(() => {
      if (dlRow) {
        dlRow.style.opacity = '1';
        dlRow.style.transition = 'opacity .4s ease';
      }
    }, 1200);
    await delay(4200);

    runCycle();
  }

  runCycle();
}

/* ─── 06: HOTEL MANAGEMENT ─── */
function initHotel() {
  const floor1 = document.getElementById('floor1');
  const floor2 = document.getElementById('floor2');
  const occEl = document.getElementById('vh-occ');
  const freeEl = document.getElementById('vh-free');
  const revEl = document.getElementById('vh-rev');

  const f1States = ['occ','occ','free','occ','clean','free'];
  const f2States = ['free','occ','occ','free','occ','clean'];

  function buildFloor(container, states, nums) {
    if (!container) return;
    container.innerHTML = '';
    states.forEach((s, i) => {
      const cell = document.createElement('div');
      cell.className = 'vh-room';
      cell.dataset.target = s;
      container.appendChild(cell);
      setTimeout(() => {
        cell.classList.add(s);
        cell.textContent = nums[i];
      }, i * 120 + 100);
    });
  }

  buildFloor(floor1, f1States, ['101','102','103','104','105','106']);
  buildFloor(floor2, f2States, ['201','202','203','204','205','206']);

  // animate stats
  setTimeout(() => {
    const occ = f1States.concat(f2States).filter(s => s === 'occ').length;
    const free = f1States.concat(f2States).filter(s => s === 'free').length;
    let v = 0;
    const t1 = setInterval(() => { if (++v >= occ) clearInterval(t1); if (occEl) occEl.textContent = v; }, 60);
    let v2 = 0;
    const t2 = setInterval(() => { if (++v2 >= free) clearInterval(t2); if (freeEl) freeEl.textContent = v2; }, 60);
    if (revEl) {
      let r = 0; const target = 42;
      const t3 = setInterval(() => { r++; revEl.textContent = '₹' + r + 'k'; if (r >= target) clearInterval(t3); }, 50);
    }
  }, 900);

  // cycle room states periodically
  function cyclRooms() {
    const allRooms = [...(floor1?.querySelectorAll('.vh-room') || []), ...(floor2?.querySelectorAll('.vh-room') || [])];
    const rand = allRooms[Math.floor(Math.random() * allRooms.length)];
    if (rand) {
      rand.classList.remove('occ','free','clean');
      const newState = ['occ','free','clean'][Math.floor(Math.random()*3)];
      rand.classList.add(newState);
    }
  }
  setInterval(cyclRooms, 1600);
}

/* ─── 07: RESTAURANT ─── */
function initRest() {
  const orders = ['vro1','vro2','vro3'];
  const nodes = ['vn-customer','vn-waiter','vn-kitchen'];
  const countEl = document.getElementById('vr-count');

  orders.forEach((id, i) => {
    const el = document.getElementById(id);
    if (el) setTimeout(() => el.classList.add('show'), i * 280 + 200);
  });

  // animate active node cycling
  let activeNode = 0;
  setInterval(() => {
    nodes.forEach(id => {
      const el = document.getElementById(id);
      if (el) el.classList.remove('active');
    });
    activeNode = (activeNode + 1) % 3;
    const target = document.getElementById(nodes[activeNode]);
    if (target) target.classList.add('active');
  }, 1800);

  // count up
  if (countEl) {
    let c = 0;
    const t = setInterval(() => {
      c++;
      countEl.textContent = c + (c >= 48 ? ' orders today' : ' orders today');
      if (c >= 48) clearInterval(t);
    }, 28);
  }

  // cycle order statuses
  const statuses = [
    {cls:'st-ready',text:'Ready'},
    {cls:'st-cooking',text:'Cooking'},
    {cls:'st-new',text:'New'},
  ];
  setInterval(() => {
    const orderEls = document.querySelectorAll('.vr-order-status');
    orderEls.forEach(el => {
      if (Math.random() > .65) {
        const s = statuses[Math.floor(Math.random()*3)];
        el.className = 'vr-order-status ' + s.cls;
        el.textContent = s.text;
      }
    });
  }, 2200);
}

