---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/pages/products.css';

// No dynamic products array needed as the user provided hardcoded HTML with specific IDs for animations.
---

<MainLayout title="Products | Nyx Solution" description="Software shaped around real operational work.">
  <div class="products-page">
    
    <!-- NAV -->
    <nav id="site-nav">
      <div class="container">
        <div class="nav-inner">
          <div style="display: flex; align-items: center; gap: 0.8rem;">
            <a href="/" class="back-link" title="Back to Home" style="display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; background: rgba(162, 74, 42, 0.08); color: var(--rust); transition: all 0.2s ease;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            </a>
            <a href="/" class="brand">Nyx Solution</a>
          </div>
          <ul class="nav-links">
            <li><a href="#briefly-docs">Briefly Docs</a></li>
            <li><a href="#briefly-social">Briefly Social</a></li>
            <li><a href="#creative-ai">Shoots</a></li>
            <li><a href="#school-erp">School</a></li>
            <li><a href="#mobility">Carpool</a></li>
            <li><a href="#sales-tracking">Sales</a></li>
            <li><a href="#restaurant">Restaurant</a></li>
            <li><a href="#hotel">Hotel</a></li>
          </ul>
        </div>
      </div>
    </nav>

    <!-- TICKER -->
    <div class="ticker-wrap">
      <div class="ticker-inner">
        <span class="ti">Document Intelligence</span>
        <span class="ti">Social Publishing</span>
        <span class="ti">AI Photoshoots</span>
        <span class="ti">School ERP</span>
        <span class="ti">Carpooling Platform</span>
        <span class="ti">Field Sales Tracking</span>
        <span class="ti">Restaurant Ordering</span>
        <span class="ti">Hotel Management</span>
        <span class="ti">Document Intelligence</span>
        <span class="ti">Social Publishing</span>
        <span class="ti">AI Photoshoots</span>
        <span class="ti">School ERP</span>
        <span class="ti">Carpooling Platform</span>
        <span class="ti">Field Sales Tracking</span>
        <span class="ti">Restaurant Ordering</span>
        <span class="ti">Hotel Management</span>
      </div>
    </div>

    <!-- HERO -->
    <section class="hero">
      <div class="container">
        <div class="hero-inner">
          <div>
            <div class="hero-eyebrow" style="opacity:0;animation:fadeUp .7s .1s both">
              <span class="ey-dot"></span>
              <span class="ey-text">Products</span>
            </div>
            <h1 class="hero-h1" style="opacity:0;animation:fadeUp .85s .2s both">
              Software shaped around<br><em>real operational</em> work
            </h1>
            <p class="hero-lead" style="opacity:0;animation:fadeUp .75s .35s both">
              Each product is purpose-built around a specific workflow — not a feature list. From documents and social publishing to field sales, education, mobility, hospitality, and food service.
            </p>
          </div>
          <div class="hero-scroll" style="opacity:0;animation:fadeIn .7s .55s both">
            <span class="hs-label">Scroll to explore</span>
            <div class="hs-track"><div class="hs-thumb"></div></div>
          </div>
        </div>
        <div class="hero-badge" style="opacity:0;animation:fadeIn .7s .6s both">
          <span class="badge-n">08</span>
          <span class="badge-l">products</span>
        </div>
      </div>
    </section>

    <!-- PRODUCTS -->
    <section class="products">
      <div class="container">

        <!-- ══ 01: BRIEFLY DOCS  ══ -->
        <article class="prod" id="briefly-docs">
          <div class="num-col">
            <span class="num-label">01</span>
            <div class="num-line"></div>
          </div>
          <div class="body">
            <div class="prod-header">
              <div class="prod-icon"><svg viewBox="0 0 32 32" fill="none"><rect x="4" y="3" width="18" height="23" rx="2.5" stroke="currentColor" stroke-width="1.6"/><path d="M8 9h10M8 13h10M8 17h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="24" cy="24" r="5" fill="rgba(253,248,239,.9)" stroke="currentColor" stroke-width="1.6"/><path d="M22.5 24h3M24 22.5v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>
              <span class="prod-tag">Document Intelligence</span>
            </div>
            <h2 class="prod-name">Briefly Docs</h2>
            <p class="prod-sub">Answers with proof, grounded in your documents</p>
            <p class="prod-body">Briefly Docs helps teams search across business documents, get answers grounded in source material, and handle document-heavy workflows with more confidence and speed.</p>
            <a href="/briefly-docs" class="prod-cta">
              <span>Learn More</span>
              <svg viewBox="0 0 20 20" fill="none"><path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <div class="vis">
            <div class="vis-card">
              <div class="vis-briefly" id="briefly-anim">
                <div class="vb-bar">
                  <div class="vb-dot" style="background:#f06257"></div>
                  <div class="vb-dot" style="background:#f5a623"></div>
                  <div class="vb-dot" style="background:#57c257"></div>
                  <span class="vb-title">Briefly Docs</span>
                </div>
                <div class="vb-search">
                  <svg width="12" height="12" viewBox="0 0 20 20" fill="none"><circle cx="9" cy="9" r="5.5" stroke="#a24a2a" stroke-width="1.5"/><path d="M13 13l3.5 3.5" stroke="#a24a2a" stroke-width="1.7" stroke-linecap="round"/></svg>
                  <span class="vb-search-text" id="briefly-typed"></span>
                  <span class="vb-cursor">|</span>
                </div>
                <div class="vb-doc" id="briefly-doc">
                  <div class="vb-line" style="width:85%"></div>
                  <div class="vb-line hl" id="hl1" style="width:90%"></div>
                  <div class="vb-line" style="width:70%"></div>
                  <div class="vb-line hl" id="hl2" style="width:75%"></div>
                  <div class="vb-line" style="width:60%"></div>
                  <div class="vb-line" style="width:80%"></div>
                  <div class="vb-line" style="width:50%"></div>
                  <div class="vb-beam"></div>
                </div>
                <div class="vb-result" id="briefly-result">
                  <div class="vb-result-label">Answer found · Page 3</div>
                  <div class="vb-result-text">Employees are entitled to 18 days annual leave, accrued monthly.</div>
                </div>
              </div>
            </div>
          </div>
        </article>

        <!-- ══ 02: BRIEFLY SOCIAL ══ -->
        <article class="prod alt" id="briefly-social">
          <div class="num-col">
            <span class="num-label">02</span>
            <div class="num-line"></div>
          </div>
          <div class="body">
            <div class="prod-header">
              <div class="prod-icon"><svg viewBox="0 0 32 32" fill="none"><rect x="4" y="6" width="24" height="18" rx="3" stroke="currentColor" stroke-width="1.6"></rect><path d="M9 12h14M9 16h10M9 20h7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path><circle cx="25" cy="9" r="2.3" fill="currentColor"></circle></svg></div>
              <span class="prod-tag">Social Content Ops</span>
            </div>
            <h2 class="prod-name">Briefly Social</h2>
            <p class="prod-sub">Create, edit, schedule, and publish social content from one workflow</p>
            <p class="prod-body">Briefly Social helps teams create posts from real brand data, reuse templates, apply AI-assisted editing, schedule publishing across connected accounts, and organize campaigns without splitting work across separate tools.</p>
            <a href="/briefly-social" class="prod-cta">
              <span>Learn More</span>
              <svg viewBox="0 0 20 20" fill="none"><path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <div class="vis">
            <div class="vis-card">
              <div class="vis-social">
                <div class="bs-head">
                  <span class="bs-title">Briefly Social</span>
                  <span class="bs-sync"><span class="bs-sync-dot"></span>Brand synced</span>
                </div>
                <div class="bs-composer">
                  <div class="bs-chip-row">
                    <span class="bs-chip bs-chip-strong">Template · Product launch</span>
                    <span class="bs-chip">Instagram</span>
                    <span class="bs-chip">LinkedIn</span>
                  </div>
                  <div class="bs-post-title">Summer campaign — launch sequence</div>
                  <p class="bs-post-copy">Generate post drafts from approved product names, campaign details, offer timelines, and brand tone instead of rewriting every caption manually.</p>
                  <div class="bs-copy-lines">
                    <span style="width:92%"></span>
                    <span style="width:84%"></span>
                    <span style="width:68%"></span>
                  </div>
                </div>
                <div class="bs-grid">
                  <div class="bs-panel">
                    <div class="bs-panel-label">AI editing</div>
                    <div class="bs-panel-value">Rewrite copy, adapt visuals, keep brand voice</div>
                  </div>
                  <div class="bs-panel">
                    <div class="bs-panel-label">Scheduled</div>
                    <div class="bs-panel-value">Thu · 7:30 PM · Auto-post to connected channels</div>
                  </div>
                  <div class="bs-panel bs-panel-wide">
                    <div class="bs-panel-label">Campaign board</div>
                    <div class="bs-campaign-row">
                      <span class="bs-mini ok">12 posts planned</span>
                      <span class="bs-mini">4 approved</span>
                      <span class="bs-mini">2 live</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </article>

        <!-- ══ 03: AI PHOTOSHOOTS ══ -->
        <article class="prod" id="creative-ai">
          <div class="num-col">
            <span class="num-label">03</span>
            <div class="num-line"></div>
          </div>
          <div class="body">
            <div class="prod-header">
              <div class="prod-icon"><svg viewBox="0 0 32 32" fill="none"><rect x="3" y="8" width="26" height="18" rx="3" stroke="currentColor" stroke-width="1.6"/><circle cx="16" cy="17" r="4.5" stroke="currentColor" stroke-width="1.6"/><path d="M11 8l2-3h6l2 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><circle cx="25" cy="13" r="1.5" fill="currentColor"/></svg></div>
              <span class="prod-tag">Creative AI</span>
            </div>
            <h2 class="prod-name">AI-Powered Photoshoots</h2>
            <p class="prod-sub">Creative production reimagined for modern brands</p>
            <p class="prod-body">Generate campaign-style brand visuals and social content with faster iteration, more flexibility, and lower production friction than traditional photoshoots — from brief to final asset in hours.</p>
            <a href="/ai-powered-photoshoots" class="prod-cta">
              <span>Learn More</span>
              <svg viewBox="0 0 20 20" fill="none"><path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <div class="vis">
            <div class="vis-card" style="overflow:hidden;padding:0">
              <div id="photo-anim" style="width:100%;height:100%;display:flex;flex-direction:column">

                <div style="display:flex;border-bottom:1px solid rgba(216,200,179,.4);background:rgba(245,235,218,.6)">
                  <div class="pa-pill active" id="pa-pill-1" style="flex:1;padding:.35rem .3rem;text-align:center;font-family:'DM Mono',monospace;font-size:.55rem;font-weight:700;color:#a24a2a;background:rgba(162,74,42,.08)">01 Upload</div>
                  <div class="pa-pill" id="pa-pill-2" style="flex:1;padding:.35rem .3rem;text-align:center;font-family:'DM Mono',monospace;font-size:.55rem;font-weight:700;color:#8a7060;border-left:1px solid rgba(216,200,179,.4)">02 Model</div>
                  <div class="pa-pill" id="pa-pill-3" style="flex:1;padding:.35rem .3rem;text-align:center;font-family:'DM Mono',monospace;font-size:.55rem;font-weight:700;color:#8a7060;border-left:1px solid rgba(216,200,179,.4)">03 Result</div>
                </div>

                <div class="pa-panel" id="pa-p1" style="flex:1;padding:.75rem;display:flex;flex-direction:column;gap:.45rem">
                  <div style="display:flex;align-items:center;gap:.55rem;background:#fff;border:1px solid rgba(216,200,179,.78);border-radius:8px;padding:.5rem .65rem;position:relative;overflow:hidden">
                    <img src="/assets/images/Dress.png" alt="Outfit" style="width:36px;height:46px;border-radius:5px;object-fit:cover;flex-shrink:0">
                    <div>
                      <div style="font-family:'DM Mono',monospace;font-size:.65rem;font-weight:600;color:#1f1a16">ivory_tank_trousers.jpg</div>
                      <div style="font-family:'DM Mono',monospace;font-size:.56rem;color:#8a7060;margin-top:.1rem">Analysed ✓</div>
                    </div>
                    <div id="pa-scan-beam" style="position:absolute;left:0;right:0;top:0;height:2px;background:linear-gradient(90deg,transparent,rgba(162,74,42,.7),transparent);box-shadow:0 0 8px rgba(162,74,42,.4);animation:scanLine 2.8s ease-in-out infinite"></div>
                  </div>
                  <div style="display:flex;flex-wrap:wrap;gap:.25rem" id="pa-tags">
                    <span class="pa-tag">Square neckline</span>
                    <span class="pa-tag">Flared trousers</span>
                    <span class="pa-tag">Ivory / taupe</span>
                    <span class="pa-tag">Smart casual</span>
                  </div>
                  <div style="display:flex;gap:.3rem;align-items:center;background:rgba(255,255,255,.5);border:1px solid rgba(216,200,179,.78);border-radius:7px;padding:.4rem .6rem">
                    <img src="/assets/images/Accessories1.png" alt="Heels" style="width:28px;height:28px;border-radius:4px;object-fit:cover;flex-shrink:0">
                    <img src="/assets/images/Accesories2.png" alt="Watch" style="width:28px;height:28px;border-radius:4px;object-fit:cover;flex-shrink:0">
                    <span style="font-family:'DM Mono',monospace;font-size:.6rem;color:#5f5148;flex:1">2 accessories added</span>
                    <span style="font-family:'DM Mono',monospace;font-size:.58rem;font-weight:600;background:rgba(46,140,79,.1);color:#1c6535;border:1px solid rgba(46,140,79,.2);border-radius:999px;padding:.1rem .4rem">Ready</span>
                  </div>
                </div>

                <div class="pa-panel" id="pa-p2" style="flex:1;padding:.75rem;display:none;flex-direction:column;gap:.45rem">
                  <div style="font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;color:#8a7060;margin-bottom:.1rem">Selected model</div>
                  <div style="display:flex;align-items:center;gap:.6rem;background:#fff;border:1.5px solid #a24a2a;border-radius:8px;padding:.55rem .7rem;box-shadow:0 0 0 3px rgba(162,74,42,.08)">
                    <img src="/assets/images/Model.png" alt="Model" style="width:40px;height:52px;border-radius:7px;object-fit:cover;object-position:top;flex-shrink:0">
                    <div>
                      <div style="font-size:.78rem;font-weight:700;color:#1f1a16">Priya · Selected ✓</div>
                      <div style="font-family:'DM Mono',monospace;font-size:.58rem;color:#8a7060;margin-top:.1rem;line-height:1.45">Indian skin tone · 5'7"<br>Compatible with outfit</div>
                    </div>
                  </div>
                  <div style="font-family:'DM Mono',monospace;font-size:.58rem;letter-spacing:.08em;text-transform:uppercase;color:#8a7060">Available poses</div>
                  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:.32rem;flex:1">
                    <div style="border-radius:7px;overflow:hidden;border:1.5px solid #a24a2a;box-shadow:0 0 0 2px rgba(162,74,42,.12)"><img src="/assets/images/Pose1.png" alt="Pose 1" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block"></div>
                    <div style="border-radius:7px;overflow:hidden;border:1px solid rgba(216,200,179,.78)"><img src="/assets/images/Pose2.png" alt="Pose 2" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block"></div>
                    <div style="border-radius:7px;overflow:hidden;border:1px solid rgba(216,200,179,.78)"><img src="/assets/images/Pose3.png" alt="Pose 3" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block"></div>
                  </div>
                </div>

                <div class="pa-panel" id="pa-p3" style="flex:1;padding:.75rem;display:none;flex-direction:column;gap:.45rem">
                  <div style="display:flex;align-items:center;justify-content:space-between">
                    <span style="font-family:'DM Mono',monospace;font-size:.65rem;font-weight:600;color:#1f1a16">Campaign output</span>
                    <span id="pa-result-count" style="font-family:'DM Mono',monospace;font-size:.58rem;color:#a24a2a">0 images</span>
                  </div>
                  <div style="display:grid;grid-template-columns:1.4fr 1fr;grid-template-rows:1fr 1fr;gap:.32rem;flex:1;min-height:140px">
                    <div class="pa-frame" id="paf1" style="grid-row:span 2;border-radius:7px;overflow:hidden;opacity:0;position:relative">
                      <img src="/assets/images/Final.png" alt="Hero shot" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block">
                      <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(20,8,2,.55),transparent 50%)"></div>
                      <div style="position:absolute;bottom:.38rem;left:.4rem;font-family:'DM Mono',monospace;font-size:.48rem;font-weight:600;color:rgba(255,245,228,.9)">Hero · Final</div>
                      <div style="position:absolute;top:.38rem;right:.38rem;font-family:'DM Mono',monospace;font-size:.48rem;font-weight:700;background:rgba(46,140,79,.85);color:#fff;border-radius:3px;padding:.08rem .32rem">✓</div>
                    </div>
                    <div class="pa-frame" id="paf2" style="border-radius:7px;overflow:hidden;opacity:0;position:relative">
                      <img src="/assets/images/Pose1.png" alt="Pose 1" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block">
                      <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(20,8,2,.5),transparent 50%)"></div>
                      <div style="position:absolute;bottom:.3rem;left:.38rem;font-family:'DM Mono',monospace;font-size:.46rem;font-weight:600;color:rgba(255,245,228,.85)">Instagram</div>
                    </div>
                    <div class="pa-frame" id="paf3" style="border-radius:7px;overflow:hidden;opacity:0;position:relative">
                      <img src="/assets/images/Pose2.png" alt="Pose 2" style="width:100%;height:100%;object-fit:cover;object-position:top;display:block">
                      <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(20,8,2,.5),transparent 50%)"></div>
                      <div style="position:absolute;bottom:.3rem;left:.38rem;font-family:'DM Mono',monospace;font-size:.46rem;font-weight:600;color:rgba(255,245,228,.85)">Catalog</div>
                    </div>
                  </div>
                  <div id="pa-dl-row" style="display:flex;align-items:center;gap:.35rem;background:rgba(162,74,42,.04);border:1px solid rgba(162,74,42,.12);border-radius:7px;padding:.4rem .6rem;opacity:0">
                    <span style="font-family:'DM Mono',monospace;font-size:.58rem;color:#8a7060;flex:1">Export for</span>
                    <span style="font-family:'DM Mono',monospace;font-size:.56rem;font-weight:700;color:#85361c;background:rgba(162,74,42,.08);border:1px solid rgba(162,74,42,.18);border-radius:999px;padding:.08rem .38rem">Instagram</span>
                    <span style="font-family:'DM Mono',monospace;font-size:.56rem;font-weight:700;color:#85361c;background:rgba(162,74,42,.08);border:1px solid rgba(162,74,42,.18);border-radius:999px;padding:.08rem .38rem">Meta</span>
                    <span style="font-family:'DM Mono',monospace;font-size:.56rem;font-weight:700;color:#85361c;background:rgba(162,74,42,.08);border:1px solid rgba(162,74,42,.18);border-radius:999px;padding:.08rem .38rem">Catalog</span>
                  </div>
                </div>

              </div>
            </div>
          </div>
        </article>

        <!-- ══ 04: SCHOOL ERP  ══ -->
        <article class="prod alt" id="school-erp">
          <div class="num-col">
            <span class="num-label">04</span>
            <div class="num-line"></div>
          </div>
          <div class="body">
            <div class="prod-header">
              <div class="prod-icon"><svg viewBox="0 0 32 32" fill="none"><path d="M16 4L3 10l13 6 13-6-13-6z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M6 13v7c0 2 4.5 5 10 5s10-3 10-5v-7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M27 10v8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></div>
              <span class="prod-tag">Education</span>
            </div>
            <h2 class="prod-name">School ERP</h2>
            <p class="prod-sub">A better operating system for schools</p>
            <p class="prod-body">Manage academic, administrative, and communication workflows through a platform designed to simplify day-to-day school operations from top to bottom — attendance, fees, notices, and more.</p>
            <a href="/school-erp" class="prod-cta">
              <span>Learn More</span>
              <svg viewBox="0 0 20 20" fill="none"><path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <div class="vis">
            <div class="vis-card">
              <div class="vis-school" id="school-anim">
                <div class="vs-header">
                  <span class="vs-title">Class 9B — Attendance · Today</span>
                  <span class="vs-date">Mon, Apr 2025</span>
                </div>
                <div class="vs-grid" id="vs-grid">
                  <!-- 28 cells, populated by JS -->
                </div>
                <div class="vs-row" id="vsr1"><span class="vs-row-name">Rahul Mehta</span><span class="vs-row-stat">Present ✓</span></div>
                <div class="vs-row" id="vsr2"><span class="vs-row-name">Priya Sharma</span><span class="vs-row-stat">Present ✓</span></div>
                <div class="vs-row" id="vsr3" style="animation-delay:.1s"><span class="vs-row-name">Arjun Nair</span><span class="vs-row-stat" style="color:var(--rust)">Absent</span></div>
              </div>
            </div>
          </div>
        </article>

        <!-- ══ 05: CARPOOLING  ══ -->
        <article class="prod" id="mobility">
          <div class="num-col">
            <span class="num-label">05</span>
            <div class="num-line"></div>
          </div>
          <div class="body">
            <div class="prod-header">
              <div class="prod-icon"><svg viewBox="0 0 32 32" fill="none"><path d="M6 18h20M8 18l2-6h12l2 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><circle cx="10" cy="22" r="2.5" stroke="currentColor" stroke-width="1.6"/><circle cx="22" cy="22" r="2.5" stroke="currentColor" stroke-width="1.6"/><path d="M4 18v4h4M24 22h4v-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></div>
              <span class="prod-tag">Mobility</span>
