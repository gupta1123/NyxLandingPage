---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Hotel Management | Nyx Solutions" description="Hospitality operations platform for reservations, room control, housekeeping, and billing.">

  <!-- NAV -->
  <nav id="mainnav">
    <div class="nav-left">
      <a class="nav-back" href="/products" aria-label="Back to products">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
      </a>
      <span class="nav-logo">Nyx Solutions</span>
    </div>
    <ul class="nav-links">
      <li><a href="#reservations">Reservations</a></li>
      <li><a href="#housekeeping">Housekeeping</a></li>
      <li><a href="#management">Management</a></li>
      <li><a href="#how">How it works</a></li>
    </ul>
  </nav>

  <!-- TICKER -->
  <div class="ticker-wrap" aria-hidden="true">
    <div class="ticker">
      <span class="ticker-item">Reservations</span>
      <span class="ticker-item">Room lifecycle management</span>
      <span class="ticker-item">Front desk operations</span>
      <span class="ticker-item">Housekeeping coordination</span>
      <span class="ticker-item">Billing and settlement</span>
      <span class="ticker-item">Occupancy dashboards</span>
      <span class="ticker-item">Guest profiles</span>
      <span class="ticker-item">Property reporting</span>
      <span class="ticker-item">Reservations</span>
      <span class="ticker-item">Room lifecycle management</span>
      <span class="ticker-item">Front desk operations</span>
      <span class="ticker-item">Housekeeping coordination</span>
      <span class="ticker-item">Billing and settlement</span>
      <span class="ticker-item">Occupancy dashboards</span>
      <span class="ticker-item">Guest profiles</span>
      <span class="ticker-item">Property reporting</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="hm-hero">
    <div class="container">
      <div class="hm-hero__grid">

        <div class="hm-hero__copy">
          <div class="hm-hero__eyebrow reveal-up">
            <span class="eyebrow-dot"></span>
            <span class="eyebrow-text">Hospitality Operations Product</span>
          </div>
          <h1 class="hm-hero__h1 reveal-up" style="animation-delay:.1s">
            Full floor-to-front-desk<br/><em>property visibility.</em>
          </h1>
          <p class="hm-hero__lead reveal-up" style="animation-delay:.2s">
            An end-to-end hotel operations platform for reservations, room lifecycle management, housekeeping coordination, and billing — so your teams stop working around fragmented tools and start running a tighter property.
          </p>
          <div class="cta-row reveal-up" style="animation-delay:.3s">
            <a class="btn ghost" href="#reservations">See Platform</a>
          </div>
        </div>

        <!-- HERO PANEL: Live Room Grid -->
        <div class="hm-hero__demo reveal-fade" style="animation-delay:.45s">
          <div class="demo-window">
            <div class="demo-bar">
              <span class="demo-dot demo-dot-r"></span>
              <span class="demo-dot demo-dot-y"></span>
              <span class="demo-dot demo-dot-g"></span>
              <span class="demo-bar-title">Hotel Management · Floor Overview</span>
              <span class="demo-live"><span class="demo-live-dot"></span>Live</span>
            </div>
            <div class="demo-body">

              <!-- Floor selector -->
              <div class="demo-floors">
                <span class="demo-floor active" id="df1">Floor 1</span>
                <span class="demo-floor" id="df2">Floor 2</span>
                <span class="demo-floor" id="df3">Floor 3</span>
              </div>

              <!-- Room grid -->
              <div class="demo-room-grid" id="demoRoomGrid">
                <!-- JS populates these -->
              </div>

              <!-- Legend -->
              <div class="demo-legend">
                <span class="dl-item"><span class="dl-dot dl-occupied"></span>Occupied</span>
                <span class="dl-item"><span class="dl-dot dl-vacant"></span>Vacant</span>
                <span class="dl-item"><span class="dl-dot dl-cleaning"></span>Cleaning</span>
                <span class="dl-item"><span class="dl-dot dl-reserved"></span>Reserved</span>
              </div>

              <!-- Quick stat row -->
              <div class="demo-stat-row">
                <div class="demo-stat">
                  <span class="ds-num" id="heroOcc">—</span>
                  <span class="ds-lbl">Occupied</span>
                </div>
                <div class="demo-stat">
                  <span class="ds-num" id="heroVac">—</span>
                  <span class="ds-lbl">Vacant</span>
                </div>
                <div class="demo-stat">
                  <span class="ds-num" id="heroCln">—</span>
                  <span class="ds-lbl">Cleaning</span>
                </div>
                <div class="demo-stat">
                  <span class="ds-num" id="heroRes">—</span>
                  <span class="ds-lbl">Reserved</span>
                </div>
              </div>

            </div>
          </div>

          <div class="demo-float demo-float-1 reveal-fade" style="animation-delay:.9s">
            <svg viewBox="0 0 16 16" fill="none" width="13" height="13"><rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M5 8h6M5 5.5h3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
            All rooms. One view.
          </div>
          <div class="demo-float demo-float-2 reveal-fade" style="animation-delay:1.1s">
            <svg viewBox="0 0 16 16" fill="none" width="13" height="13"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3"/><path d="M5.5 8l2 2 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Real-time status
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- STATS -->
  <div class="stats-strip">
    <div class="stat-item"><span class="stat-num" data-count="100">0</span><span class="stat-label">% property coverage</span></div>
    <div class="stat-item"><span class="stat-num" data-count="3">0</span><span class="stat-label">teams on one platform</span></div>
    <div class="stat-item"><span class="stat-num" data-count="40">0</span><span class="stat-label">% faster room turnaround</span></div>
    <div class="stat-item"><span class="stat-num" data-count="0">0</span><span class="stat-label">spreadsheets needed</span></div>
  </div>

  <!-- PROBLEM -->
  <section class="hm-problem">
    <div class="narrow">
      <div class="hm-problem__card" id="problemCard">
        <div class="hm-problem-icon">
          <svg width="52" height="52" viewBox="0 0 48 48" fill="none">
            <rect x="4" y="8" width="18" height="28" rx="2" stroke="currentColor" stroke-width="1.8"/>
            <rect x="26" y="8" width="18" height="28" rx="2" stroke="currentColor" stroke-width="1.8"/>
            <path d="M4 20h18M26 20h18" stroke="currentColor" stroke-width="1.4" stroke-dasharray="3 2"/>
            <circle cx="24" cy="38" r="5" fill="var(--rust-50)" stroke="currentColor" stroke-width="1.8"/>
            <path d="M21.5 38l2 2 3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="hm-problem__text">
          <h2>Most hotels don't struggle because they lack information. They struggle because it's spread across too many places.</h2>
          <p>Front desk staff check one system for reservations, housekeeping uses a whiteboard or chat thread, management pulls reports from a third tool. The result: slower room turns, missed handoffs, and service gaps that show up as guest complaints.</p>
          <p>Hotel Management is built to close that gap — one system, every team, full property view.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURE ROWS -->
  <section class="feat-section">
    <div class="container">

      <!-- 1: RESERVATIONS -->
      <div class="feat-row" id="reservations">
        <div class="feat-copy reveal-up">
          <span class="eyebrow">Front desk and reservations</span>
          <h2 class="sh2">Every booking, check-in, and check-out — <em>from one place</em></h2>
          <p>Reception teams handle the full guest lifecycle without toggling between tools. From reservation and room assignment through check-in, stay extensions, and final billing — everything moves through a single, consistent workflow.</p>
          <ul class="bullet-list">
            <li>Reservation creation and room assignment management</li>
            <li>Fast check-in and check-out flows with guest profile access</li>
            <li>Stay extension and modification handling</li>
            <li>Billing, payment tracking, and invoice generation</li>
          </ul>
        </div>
        <div class="feat-illu reveal-fade" style="animation-delay:.1s">
          <div class="illu-panel checkin-panel" id="checkinPanel">
            <div class="cp-header">
              <span class="cp-title">Check-In · Room 214</span>
              <span class="cp-badge" id="cpBadge">In progress</span>
            </div>

            <!-- Guest card -->
            <div class="cp-guest" id="cpGuest">
              <div class="cp-guest-avatar">RK</div>
              <div class="cp-guest-info">
                <div class="cp-guest-name">Rahul Krishnamurthy</div>
                <div class="cp-guest-meta">3rd visit · Standard Double · 3 nights</div>
              </div>
              <div class="cp-guest-tag" id="cpGuestTag">Verified ✓</div>
            </div>

            <!-- Steps -->
            <div class="cp-steps" id="cpSteps">
              <div class="cp-step" id="cs1">
                <div class="cp-step-icon" data-done="false">
                  <svg viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <span>Reservation confirmed</span>
              </div>
              <div class="cp-step" id="cs2">
                <div class="cp-step-icon" data-done="false">
                  <svg viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <span>ID and payment captured</span>
              </div>
              <div class="cp-step" id="cs3">
                <div class="cp-step-icon" data-done="false">
                  <svg viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <span>Room assigned — 214</span>
              </div>
              <div class="cp-step" id="cs4">
                <div class="cp-step-icon" data-done="false">
                  <svg viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <span>Key issued · Guest checked in</span>
              </div>
            </div>

            <div class="cp-done" id="cpDone">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.4"/><path d="M5 8l2.5 2.5L11 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Check-in complete · Room 214 is now occupied
            </div>
          </div>
        </div>
      </div>

      <!-- 2: HOUSEKEEPING -->
      <div class="feat-row reverse" id="housekeeping">
        <div class="feat-copy reveal-up">
          <span class="eyebrow">Housekeeping and operations</span>
          <h2 class="sh2">Room readiness — <em>without the radio calls</em></h2>
          <p>Housekeeping teams see their task queue, update room status as work completes, and flag issues — all without calling the front desk or updating a whiteboard. Coordinators get live visibility into floor progress and turnaround timing.</p>
          <ul class="bullet-list">
            <li>Live room status across full property inventory</li>
            <li>Task assignment and closure per room</li>
            <li>Maintenance and issue logging with priority flags</li>
            <li>Turnaround time visibility to reduce delays between stays</li>
          </ul>
        </div>
        <div class="feat-illu reveal-fade" style="animation-delay:.1s">
          <div class="illu-panel hk-panel" id="hkPanel">
            <div class="hk-header">
              <div class="hk-title">Housekeeping Board — Floor 2</div>
              <div class="hk-live"><div class="hk-live-dot"></div>Live</div>
            </div>
            <div class="hk-tasks" id="hkTasks">
              <div class="hk-task" id="hkt1">
                <div class="hk-room-num">201</div>
                <div class="hk-task-info">
                  <span class="hk-task-label">Deep clean — checkout</span>
                  <span class="hk-task-assignee">Priya S.</span>
                </div>
                <span class="hk-status hks-progress" id="hkt1s">In progress</span>
              </div>
              <div class="hk-task" id="hkt2">
                <div class="hk-room-num">204</div>
                <div class="hk-task-info">
                  <span class="hk-task-label">Turndown service</span>
                  <span class="hk-task-assignee">Anand R.</span>
                </div>
                <span class="hk-status hks-queued" id="hkt2s">Queued</span>
              </div>
              <div class="hk-task" id="hkt3">
                <div class="hk-room-num">207</div>
                <div class="hk-task-info">
                  <span class="hk-task-label">Maintenance flag — AC</span>
                  <span class="hk-task-assignee">Engineering</span>
                </div>
                <span class="hk-status hks-flag" id="hkt3s">Flagged</span>
              </div>
              <div class="hk-task" id="hkt4">
                <div class="hk-room-num">212</div>
                <div class="hk-task-info">
                  <span class="hk-task-label">Standard refresh</span>
                  <span class="hk-task-assignee">Meena K.</span>
                </div>
                <span class="hk-status hks-done" id="hkt4s">Done ✓</span>
              </div>
            </div>
            <div class="hk-summary" id="hkSummary">
              <div class="hks-bar-wrap">
                <span class="hks-bar-label">Floor completion</span>
                <span class="hks-bar-pct" id="hksBarPct">0%</span>
              </div>
              <div class="hks-track"><div class="hks-fill" id="hksFill"></div></div>
            </div>
          </div>
        </div>
      </div>

      <!-- 3: MANAGEMENT -->
      <div class="feat-row" id="management">
        <div class="feat-copy reveal-up">
          <span class="eyebrow">Management control layer</span>
          <h2 class="sh2">Occupancy and operations — <em>always in view</em></h2>
          <p>Hotel leadership gets clean visibility into what is happening across the property without chasing updates from floor staff. Occupancy trends, revenue snapshots, and operational bottlenecks are available as live dashboards, not end-of-day reports.</p>
          <ul class="bullet-list">
            <li>Occupancy and utilization dashboards</li>
            <li>Revenue and booking trend snapshots</li>
            <li>Operational bottleneck identification</li>
            <li>Audit trails for all team actions</li>
          </ul>
        </div>
        <div class="feat-illu reveal-fade" style="animation-delay:.1s">
          <div class="illu-panel occ-panel" id="occPanel">
            <div class="occ-header">
              <span class="occ-title">Occupancy Dashboard</span>
              <span class="occ-period">This week</span>
            </div>
            <div class="occ-chart" id="occChart">
              <!-- bars rendered by JS -->
            </div>
            <div class="occ-kpis" id="occKpis">
              <div class="occ-kpi">
                <div class="occ-kpi-num" id="kpiOcc">—</div>
                <div class="occ-kpi-lbl">Avg occupancy</div>
              </div>
              <div class="occ-kpi">
                <div class="occ-kpi-num" id="kpiRev">—</div>
                <div class="occ-kpi-lbl">Revenue index</div>
              </div>
              <div class="occ-kpi">
                <div class="occ-kpi-num" id="kpiTurn">—</div>
                <div class="occ-kpi-lbl">Avg turnaround</div>
              </div>
            </div>
            <div class="occ-alert" id="occAlert">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M8 2l5.8 11H2.2L8 2z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><path d="M8 6.5v3M8 11.5v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
              Floor 3 — 3 rooms pending housekeeping sign-off
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="hm-how" id="how">
    <div class="container">
      <div class="hm-how__header">
        <span class="eyebrow">How it works</span>
        <h2 class="sh2">One system. Every team. <em>Zero handoff gaps.</em></h2>
      </div>
      <div class="hm-how__steps">
        <div class="hm-step">
          <div class="hm-step__number">01</div>
          <div class="hm-step__connector"></div>
          <div class="hm-step__card">
            <h3>Property is configured</h3>
            <p>Rooms, floors, room types, and team roles are set up once. The system maps your property structure from day one.</p>
          </div>
        </div>
        <div class="hm-step">
          <div class="hm-step__number">02</div>
          <div class="hm-step__connector"></div>
          <div class="hm-step__card">
            <h3>Front desk manages the booking lifecycle</h3>
            <p>Reservations flow in, rooms are assigned, guests check in and out — all within one consistent workflow, no switching tools.</p>
          </div>
        </div>
        <div class="hm-step">
          <div class="hm-step__number">03</div>
          <div class="hm-step__connector"></div>
          <div class="hm-step__card">
            <h3>Housekeeping works from a live task board</h3>
            <p>Cleaning and readiness tasks are assigned automatically on checkout. Staff update status from their device, front desk sees it instantly.</p>
          </div>
        </div>
        <div class="hm-step">
          <div class="hm-step__number">04</div>
          <div class="hm-step__card">
            <h3>Management gets the full picture</h3>
            <p>Occupancy, billing, and operational health are visible in real time — not pieced together from spreadsheets at the end of the day.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES GRID -->
  <section class="features-grid-sec">
    <div class="container">
      <span class="eyebrow">What you get</span>
      <h2 class="sh2" style="margin-top:.4rem">Everything a hotel operation needs.<br><em>In one place.</em></h2>
      <div class="feat-grid">
        <div class="feat-card reveal-up" style="animation-delay:0s">
          <div class="feat-card-num">01</div>
          <h3>Unified reservation operations</h3>
          <p>Manage online, offline, and direct bookings in a consistent workflow. No duplicate entries across systems.</p>
        </div>
        <div class="feat-card reveal-up" style="animation-delay:.07s">
          <div class="feat-card-num">02</div>
          <h3>Real-time room inventory control</h3>
          <p>Track availability and room state changes without manual reconciliation. The grid updates as status changes.</p>
        </div>
        <div class="feat-card reveal-up" style="animation-delay:.14s">
          <div class="feat-card-num">03</div>
          <h3>Guest-centric records</h3>
          <p>Structured guest profiles with stay history give front desk teams context before a guest even reaches the desk.</p>
        </div>
        <div class="feat-card reveal-up" style="animation-delay:.21s">
          <div class="feat-card-num">04</div>
          <h3>Housekeeping workflow visibility</h3>
          <p>Coordinate cleaning and room readiness with less phone-call overhead. Tasks close in the system, not on paper.</p>
        </div>
        <div class="feat-card reveal-up" style="animation-delay:.28s">
          <div class="feat-card-num">05</div>
          <h3>Billing and settlement support</h3>
          <p>Handle invoices and payment lifecycle with better accuracy. Billing pulls directly from the active stay record.</p>
        </div>
        <div class="feat-card reveal-up" style="animation-delay:.35s">
          <div class="feat-card-num">06</div>
          <h3>Property-level reporting</h3>
          <p>Use occupancy, staffing, and revenue insights to improve planning — available as a live dashboard, not a weekly export.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FIT FOR -->
  <section class="hm-fit">
    <div class="container">
      <div class="hm-fit__inner">
        <div class="hm-fit__left">
          <span class="eyebrow">Who it is for</span>
          <h2 class="sh2">For any property that needs<br><em>tighter operations.</em></h2>
          <p>If your front desk, housekeeping, and management teams are working from different tools — or no tools at all — Hotel Management is built for you.</p>
          <ul class="hm-fit__list">
            <li class="hm-fit__item reveal-up" style="animation-delay:.0s">
              <span class="hm-fit__check"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Independent hotels and boutique properties
            </li>
            <li class="hm-fit__item reveal-up" style="animation-delay:.08s">
              <span class="hm-fit__check"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Multi-property hospitality groups
            </li>
            <li class="hm-fit__item reveal-up" style="animation-delay:.16s">
              <span class="hm-fit__check"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Serviced apartment operators
            </li>
            <li class="hm-fit__item reveal-up" style="animation-delay:.24s">
              <span class="hm-fit__check"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Teams replacing spreadsheet workflows
            </li>
            <li class="hm-fit__item reveal-up" style="animation-delay:.32s">
              <span class="hm-fit__check"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              Properties needing front desk–housekeeping sync
            </li>
          </ul>
        </div>
        <div class="hm-fit__right">
          <div class="hm-stat-card reveal-up" style="animation-delay:.0s">
            <div class="hmsc-n">3</div>
            <div class="hmsc-t"><strong>Teams unified.</strong> Front desk, housekeeping, and management — one system, shared data, no fragmentation.</div>
          </div>
          <div class="hm-stat-card reveal-up" style="animation-delay:.12s">
            <div class="hmsc-n">40%</div>
            <div class="hmsc-t"><strong>Faster room turnaround.</strong> Real-time task visibility means housekeeping and front desk move in sync, not sequence.</div>
          </div>
          <div class="hm-stat-card reveal-up" style="animation-delay:.24s">
            <div class="hmsc-n">0</div>
            <div class="hmsc-t"><strong>Spreadsheets needed.</strong> Reservations, billing, and reporting all live inside the platform from day one.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="hm-cta">
    <div class="narrow">
      <div class="hm-cta__card" id="ctaCard">
        <div class="hm-cta__glow" aria-hidden="true"></div>
        <span class="eyebrow" style="display:block;text-align:center;margin-bottom:.5rem">Get started</span>
        <h2>Need a more reliable operating system<br><em>for your property?</em></h2>
        <p class="hm-cta__sub">We can tailor deployment for your front desk, housekeeping, and management workflows.</p>
        <div class="cta-row center" style="margin-top:1.8rem">
          <a class="btn ghost" href="/products">View All Products</a>
        </div>
      </div>
    </div>
  </section>

  <footer><p>&copy; 2026 <strong>Nyx Solutions</strong> · Hotel Management — Hospitality Operations Product</p></footer>

</MainLayout>

<style>
@import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Sora:wght@300;400;500;600;700&family=DM+Mono:wght@300;400;500&display=swap');

:root {
  --rust-50:#fdf8ef; --rust-100:#f5ebda; --rust-200:#e9c9a8;
  --rust-300:#da956a; --rust-400:#c56f45; --rust-500:#a24a2a;
  --rust-600:#85361c; --rust-700:#6b2a14;
  --sand-50:#fff8ed; --sand-100:#f5e8d4; --sand-200:#d8c8b3;
  --ink:#1f1a16; --ink-soft:#5f5148; --ink-muted:#7a5c4c;
  --surface:#fdf8ef; --line:rgba(216,200,179,.78); --line-mid:rgba(196,160,126,.45);
  --green:#2e8c4f; --amber:#c07820; --dark-bg:#2e1f19;
  --room-occ:#a24a2a; --room-vac:#2e8c4f; --room-cln:#c07820; --room-res:#4a6a9a;
  --ff-d:'Instrument Serif',Georgia,serif; --ff-b:'Sora',sans-serif; --ff-m:'DM Mono',monospace;
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  background:
    radial-gradient(circle at 92% 4%,rgba(162,74,42,.13) 0,rgba(162,74,42,0) 40%),
    radial-gradient(circle at 6% 18%,rgba(255,226,171,.26) 0,rgba(255,226,171,0) 38%),
    var(--surface);
  color:var(--ink);font-family:var(--ff-b);font-size:16px;line-height:1.7;overflow-x:hidden;
}

/* ── KEYFRAMES ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:none}}
@keyframes fadeScale{from{opacity:0;transform:scale(.93)}to{opacity:1;transform:scale(1)}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
@keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-7px)}}
@keyframes ping{0%{box-shadow:0 0 0 0 rgba(162,74,42,.55)}70%{box-shadow:0 0 0 10px rgba(162,74,42,0)}100%{box-shadow:0 0 0 0 rgba(162,74,42,0)}}
@keyframes pingGreen{0%{box-shadow:0 0 0 0 rgba(46,140,79,.55)}70%{box-shadow:0 0 0 8px rgba(46,140,79,0)}100%{box-shadow:0 0 0 0 rgba(46,140,79,0)}}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@keyframes glowPulse{0%,100%{opacity:.5;transform:scale(1)}50%{opacity:.8;transform:scale(1.07)}}
@keyframes resultSlide{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
@keyframes badgeIn{from{opacity:0;transform:scale(.8) translateY(6px)}to{opacity:1;transform:none}}
@keyframes connGrow{from{transform:scaleX(0)}to{transform:scaleX(1)}}
@keyframes stepIn{from{opacity:0;transform:translateX(-20px)}to{opacity:1;transform:none}}
@keyframes listIn{from{opacity:0;transform:translateX(16px)}to{opacity:1;transform:none}}
@keyframes cardFadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:none}}
@keyframes roomPop{from{opacity:0;transform:scale(.7)}to{opacity:1;transform:scale(1)}}
@keyframes roomPulse{0%{opacity:1}50%{opacity:.6}100%{opacity:1}}
@keyframes checkDraw{from{stroke-dashoffset:20}to{stroke-dashoffset:0}}
@keyframes barRise{from{height:0}to{height:var(--bh,60%)}}
@keyframes scanPulse{0%{box-shadow:0 0 0 0 rgba(192,120,32,.4)}70%{box-shadow:0 0 0 7px rgba(192,120,32,0)}100%{box-shadow:0 0 0 0 rgba(192,120,32,0)}}
@keyframes notifSlide{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}

.reveal-up{animation:fadeUp .75s cubic-bezier(.22,.85,.44,1) both}
.reveal-fade{animation:fadeScale .7s cubic-bezier(.22,.85,.44,1) both}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:.9rem 2.8rem;background:rgba(253,248,239,.93);backdrop-filter:blur(16px);border-bottom:1px solid var(--line);transition:padding .3s}
nav.scrolled{padding-top:.6rem;padding-bottom:.6rem}
.nav-left{display:flex;align-items:center;gap:.7rem}
.nav-back{width:34px;height:34px;border-radius:8px;border:1px solid var(--line);background:rgba(255,252,244,.7);color:var(--rust-600);text-decoration:none;display:inline-flex;align-items:center;justify-content:center;transition:background .2s,border-color .2s,transform .15s}
.nav-back:hover{background:var(--rust-50);border-color:var(--rust-300);transform:translateY(-1px)}
.nav-back svg{width:16px;height:16px}
.nav-logo{font-family:var(--ff-d);font-size:1.3rem;font-style:italic;color:var(--rust-600)}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{font-size:.83rem;color:var(--ink-soft);text-decoration:none;transition:color .2s}
.nav-links a:hover{color:var(--rust-500)}

/* ── TICKER ── */
.ticker-wrap{margin-top:63px;overflow:hidden;background:linear-gradient(90deg,#f3e6cf,#ecd8b8);border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:.5rem 0}
.ticker{display:flex;white-space:nowrap;animation:ticker 32s linear infinite}
.ticker-item{font-size:.7rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--rust-600);padding:0 2.2rem;flex-shrink:0}
.ticker-item::after{content:'·';margin-left:2.2rem;color:var(--rust-400)}

/* ── LAYOUT ── */
.container{max-width:1160px;margin:0 auto;padding:0 2.4rem}
.narrow{max-width:820px;margin:0 auto;padding:0 2.4rem}
.eyebrow{font-size:.7rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--rust-500);display:block;margin-bottom:.55rem}
.sh2{font-family:var(--ff-d);font-size:clamp(1.8rem,3.2vw,2.6rem);font-weight:400;line-height:1.18;letter-spacing:-.01em;color:var(--ink)}
.sh2 em{font-style:italic;color:var(--rust-500)}
.btn{display:inline-block;font-size:.88rem;font-weight:600;border-radius:8px;text-decoration:none;padding:.66rem 1.5rem;transition:background .2s,transform .15s,box-shadow .2s}
.btn.ghost{border:1.5px solid var(--line-mid);color:var(--rust-600)}
.btn.ghost:hover{background:var(--rust-50);transform:translateY(-2px)}
.cta-row{display:flex;gap:.85rem;flex-wrap:wrap}
.cta-row.center{justify-content:center}

/* ══════════════════════
   HERO
══════════════════════ */
.hm-hero{padding:5.5rem 0 4.5rem;position:relative;overflow:hidden;isolation:isolate}
.hm-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 55% at 80% 10%,rgba(162,74,42,.11),transparent),radial-gradient(ellipse 45% 55% at 5% 90%,rgba(255,215,140,.18),transparent);pointer-events:none;z-index:0}
.hm-hero .container{position:relative;z-index:1}
.hm-hero::after{content:'';position:absolute;inset:0;background-image:linear-gradient(var(--line) 1px,transparent 1px),linear-gradient(90deg,var(--line) 1px,transparent 1px);background-size:48px 48px;mask-image:radial-gradient(ellipse 75% 75% at 68% 38%,black 0%,transparent 100%);pointer-events:none;z-index:0}

.hm-hero__grid{display:grid;grid-template-columns:1fr 1.15fr;gap:3.5rem;align-items:center}
.hm-hero__eyebrow{display:inline-flex;align-items:center;gap:.55rem;margin-bottom:.9rem}
.eyebrow-dot{width:8px;height:8px;border-radius:50%;background:var(--rust-500);animation:ping 2.2s ease-in-out infinite}
.eyebrow-text{font-size:.7rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--rust-600)}
.hm-hero__h1{font-family:var(--ff-d);font-size:clamp(2.4rem,4.8vw,4rem);line-height:1.1;letter-spacing:-.01em;color:var(--ink);margin-bottom:1.2rem}
.hm-hero__h1 em{font-style:italic;color:var(--rust-500);position:relative}
.hm-hero__h1 em::after{content:'';position:absolute;left:0;right:0;bottom:-3px;height:2px;border-radius:2px;background:var(--rust-400);opacity:.4}
.hm-hero__lead{font-size:1.04rem;font-weight:300;color:var(--ink-soft);line-height:1.75;max-width:50ch;margin-bottom:1.9rem}

/* demo window */
.hm-hero__demo{position:relative;z-index:2}
.demo-window{border:1.5px solid var(--line-mid);border-radius:20px;background:rgb(255, 252, 242);box-shadow:0 28px 72px rgba(75,42,21,.13),0 4px 18px rgba(75,42,21,.06);overflow:hidden;animation:floatY 7s ease-in-out infinite}
.demo-bar{display:flex;align-items:center;gap:.45rem;padding:.7rem 1rem;background:rgba(245,235,218,.75);border-bottom:1px solid var(--line)}
.demo-dot{width:10px;height:10px;border-radius:50%}
.demo-dot-r{background:#f06257}.demo-dot-y{background:#f5a623}.demo-dot-g{background:#57c257}
.demo-bar-title{margin-left:.4rem;font-family:var(--ff-m);font-size:.7rem;font-weight:600;color:var(--ink-soft);letter-spacing:.04em;flex:1}
.demo-live{display:flex;align-items:center;gap:.3rem;font-family:var(--ff-m);font-size:.62rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--green)}
.demo-live-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pingGreen 2s ease-in-out infinite}

.demo-body{padding:1rem;display:flex;flex-direction:column;gap:.75rem}

/* floor selector */
.demo-floors{display:flex;gap:.4rem}
.demo-floor{font-family:var(--ff-m);font-size:.66rem;font-weight:600;padding:.28rem .7rem;border-radius:999px;border:1.5px solid var(--line);color:var(--ink-soft);cursor:pointer;transition:all .2s}
.demo-floor.active{background:var(--rust-500);color:#fff;border-color:var(--rust-500)}

/* room grid */
.demo-room-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:.38rem}
.room-cell{border-radius:6px;aspect-ratio:1;display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:var(--ff-m);font-size:.58rem;font-weight:700;cursor:default;transition:transform .2s,box-shadow .2s;position:relative;opacity:0}
.room-cell.pop{animation:roomPop .4s cubic-bezier(.34,1.2,.64,1) forwards}
.room-cell:hover{transform:scale(1.1);z-index:2}
.room-cell.occupied{background:rgba(162,74,42,.15);border:1.5px solid rgba(162,74,42,.35);color:var(--rust-600)}
.room-cell.vacant{background:rgba(46,140,79,.12);border:1.5px solid rgba(46,140,79,.28);color:#1c6535}
.room-cell.cleaning{background:rgba(192,120,32,.12);border:1.5px solid rgba(192,120,32,.3);color:#7a4c0e;animation:roomPulse 2s ease-in-out infinite}
.room-cell.reserved{background:rgba(74,106,154,.1);border:1.5px solid rgba(74,106,154,.28);color:#2a4a7a}

/* legend */
.demo-legend{display:flex;gap:.85rem;flex-wrap:wrap}
.dl-item{display:flex;align-items:center;gap:.3rem;font-family:var(--ff-m);font-size:.62rem;color:var(--ink-muted)}
.dl-dot{width:8px;height:8px;border-radius:2px;flex-shrink:0}
.dl-occupied{background:rgba(162,74,42,.35)}
.dl-vacant{background:rgba(46,140,79,.35)}
.dl-cleaning{background:rgba(192,120,32,.35)}
.dl-reserved{background:rgba(74,106,154,.3)}

/* stat row */
.demo-stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:.5rem}
.demo-stat{background:rgba(162,74,42,.04);border:1px solid var(--line);border-radius:8px;padding:.5rem .4rem;text-align:center}
.ds-num{font-family:var(--ff-d);font-size:1.3rem;font-style:italic;color:var(--rust-500);display:block;line-height:1;margin-bottom:.1rem}
.ds-lbl{font-family:var(--ff-m);font-size:.56rem;color:var(--ink-muted);letter-spacing:.06em;text-transform:uppercase}

/* floating badges */
.demo-float{position:absolute;display:flex;align-items:center;gap:.4rem;font-size:.74rem;font-weight:600;color:#5a3d2e;background:rgba(255,248,232,.95);border:1.5px solid var(--line);border-radius:999px;padding:.42rem .82rem;box-shadow:0 6px 20px rgba(75,42,21,.12);white-space:nowrap;animation:floatY 3s ease-in-out infinite}
.demo-float svg{width:13px;height:13px;flex-shrink:0;color:var(--rust-500)}
.demo-float-1{bottom:-1rem;left:-1.8rem;animation-delay:0s}
.demo-float-2{top:1.2rem;right:-1.8rem;animation-delay:1.4s}

/* ── STATS STRIP ── */
.stats-strip{background:var(--dark-bg);display:grid;grid-template-columns:repeat(4,1fr);gap:1px;overflow:hidden}
.stat-item{text-align:center;padding:2.2rem 1rem;position:relative}
.stat-item:not(:last-child)::after{content:'';position:absolute;right:0;top:25%;bottom:25%;width:1px;background:rgba(255,255,255,.07)}
.stat-num{font-family:var(--ff-d);font-size:2.6rem;font-style:italic;color:var(--rust-300);display:block;line-height:1;margin-bottom:.35rem}
.stat-label{font-size:.72rem;color:rgba(255,255,255,.38);letter-spacing:.06em;text-transform:uppercase}

/* ══════════════════════
   PROBLEM
══════════════════════ */
.hm-problem{padding:4rem 0}
.hm-problem__card{display:grid;grid-template-columns:auto 1fr;gap:2.4rem;align-items:start;border:1.5px solid var(--line);border-radius:26px;padding:2.8rem 2.4rem;background:linear-gradient(148deg,rgba(255,245,228,.98),rgba(250,232,198,.9));box-shadow:0 16px 48px rgba(75,42,21,.09);opacity:0}
.hm-problem__card.in-view{animation:fadeUp .8s cubic-bezier(.22,.85,.44,1) forwards}
.hm-problem-icon{color:var(--rust-500);flex-shrink:0}
.hm-problem__text h2{font-family:var(--ff-d);font-size:clamp(1.6rem,2.8vw,2.3rem);letter-spacing:-.02em;line-height:1.2;color:var(--ink);margin-bottom:1rem}
.hm-problem__text p{color:var(--ink-soft);line-height:1.72;max-width:66ch}
.hm-problem__text p+p{margin-top:.7rem}

/* ══════════════════════
   FEATURE ROWS
══════════════════════ */
.feat-section{padding:4rem 0 2rem}
.feat-row{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;padding:5rem 0;border-bottom:1px solid var(--line)}
.feat-row:last-child{border-bottom:none}
.feat-row.reverse .feat-copy{order:2}
.feat-row.reverse .feat-illu{order:1}
.feat-copy .sh2{margin-bottom:1rem}
.feat-copy p{font-size:.97rem;font-weight:300;color:var(--ink-soft);line-height:1.75;margin-bottom:1rem}
.bullet-list{list-style:none;display:grid;gap:.55rem}
.bullet-list li{position:relative;padding-left:1.1rem;font-size:.9rem;color:var(--ink-soft)}
.bullet-list li::before{content:'';position:absolute;left:0;top:.6em;width:6px;height:6px;border-radius:50%;background:var(--rust-400)}

/* ── ILLUSTRATION PANELS ── */
.illu-panel{border:1.5px solid var(--line-mid);border-radius:18px;background:var(--sand-50);overflow:hidden;position:relative}

/* ─ CHECK-IN PANEL ─ */
.checkin-panel{padding:1.4rem;min-height:310px;display:flex;flex-direction:column;gap:.75rem}
.cp-header{display:flex;align-items:center;justify-content:space-between}
.cp-title{font-family:var(--ff-m);font-size:.72rem;font-weight:600;color:var(--ink)}
.cp-badge{font-family:var(--ff-m);font-size:.64rem;font-weight:600;padding:.18rem .52rem;border-radius:999px;background:rgba(162,74,42,.1);border:1px solid rgba(162,74,42,.22);color:var(--rust-600);transition:all .4s}
.cp-badge.done{background:rgba(46,140,79,.1);border-color:rgba(46,140,79,.22);color:var(--green)}

.cp-guest{display:flex;align-items:center;gap:.75rem;background:#fff;border:1px solid var(--line);border-radius:12px;padding:.75rem .9rem}
.cp-guest-avatar{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--rust-400),var(--rust-600));color:#fff8ee;font-family:var(--ff-m);font-size:.72rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.cp-guest-name{font-size:.84rem;font-weight:600;color:var(--ink)}
.cp-guest-meta{font-family:var(--ff-m);font-size:.64rem;color:var(--ink-muted);margin-top:.1rem}
.cp-guest-tag{font-family:var(--ff-m);font-size:.62rem;font-weight:600;color:var(--green);background:rgba(46,140,79,.1);border:1px solid rgba(46,140,79,.2);border-radius:999px;padding:.14rem .48rem;flex-shrink:0;margin-left:auto}

.cp-steps{display:flex;flex-direction:column;gap:.42rem}
.cp-step{display:flex;align-items:center;gap:.65rem;padding:.52rem .72rem;border-radius:9px;background:rgba(162,74,42,.03);border:1px solid var(--line);transition:all .35s;font-size:.82rem;color:var(--ink-soft)}
.cp-step.done{background:rgba(46,140,79,.06);border-color:rgba(46,140,79,.2);color:var(--ink)}
.cp-step.active{background:rgba(162,74,42,.07);border-color:rgba(162,74,42,.22);color:var(--ink)}
.cp-step-icon{width:20px;height:20px;border-radius:50%;border:1.5px solid var(--line);background:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .35s;color:transparent}
.cp-step-icon svg{width:10px;height:10px}
.cp-step-icon svg path{stroke-dasharray:20;stroke-dashoffset:20;transition:stroke-dashoffset .4s ease}
.cp-step.done .cp-step-icon{background:var(--green);border-color:var(--green);color:#fff}
.cp-step.done .cp-step-icon svg path{stroke-dashoffset:0;stroke:currentColor}

.cp-done{display:flex;align-items:center;gap:.5rem;padding:.62rem .85rem;border-radius:10px;background:linear-gradient(145deg,rgba(240,255,245,.95),rgba(225,248,232,.9));border:1.5px solid rgba(46,140,79,.25);font-size:.82rem;font-weight:600;color:var(--green);opacity:0;transition:opacity .5s}
.cp-done.show{opacity:1;animation:badgeIn .5s cubic-bezier(.22,.85,.44,1) forwards}

/* ─ HOUSEKEEPING PANEL ─ */
.hk-panel{padding:1.4rem;min-height:310px;display:flex;flex-direction:column;gap:.7rem}
.hk-header{display:flex;align-items:center;justify-content:space-between}
.hk-title{font-family:var(--ff-m);font-size:.72rem;font-weight:600;color:var(--ink)}
.hk-live{display:flex;align-items:center;gap:.35rem;font-family:var(--ff-m);font-size:.65rem;color:var(--green)}
.hk-live-dot{width:5px;height:5px;border-radius:50%;background:var(--green);animation:pingGreen 2s ease-in-out infinite}

.hk-tasks{display:flex;flex-direction:column;gap:.42rem;flex:1}
.hk-task{display:flex;align-items:center;gap:.65rem;padding:.6rem .8rem;border-radius:10px;background:#fff;border:1px solid var(--line);opacity:0;transition:border-color .3s,background .3s}
.hk-task.show{animation:cardFadeUp .45s cubic-bezier(.22,.85,.44,1) forwards}
.hk-task.task-done{background:rgba(46,140,79,.05);border-color:rgba(46,140,79,.18)}
.hk-room-num{font-family:var(--ff-m);font-size:.7rem;font-weight:700;color:var(--rust-500);width:28px;text-align:center;flex-shrink:0}
.hk-task-info{flex:1;display:flex;flex-direction:column;gap:.08rem}
.hk-task-label{font-size:.8rem;font-weight:500;color:var(--ink)}
.hk-task-assignee{font-family:var(--ff-m);font-size:.62rem;color:var(--ink-muted)}
.hk-status{font-family:var(--ff-m);font-size:.62rem;font-weight:600;border-radius:999px;padding:.14rem .5rem;flex-shrink:0;transition:all .4s}
.hks-progress{background:rgba(162,74,42,.1);color:var(--rust-600);border:1px solid rgba(162,74,42,.2)}
.hks-queued{background:rgba(122,92,76,.08);color:var(--ink-muted);border:1px solid var(--line)}
.hks-flag{background:rgba(192,80,40,.1);color:#8b2c10;border:1px solid rgba(192,80,40,.25)}
.hks-done{background:rgba(46,140,79,.1);color:#1c6535;border:1px solid rgba(46,140,79,.2)}

.hk-summary{background:rgba(162,74,42,.04);border:1px solid var(--line);border-radius:9px;padding:.65rem .85rem}
.hks-bar-wrap{display:flex;justify-content:space-between;align-items:center;margin-bottom:.38rem}
.hks-bar-label{font-family:var(--ff-m);font-size:.65rem;color:var(--ink-soft)}
.hks-bar-pct{font-family:var(--ff-m);font-size:.65rem;font-weight:700;color:var(--rust-500)}
.hks-track{height:5px;background:rgba(162,74,42,.1);border-radius:999px;overflow:hidden}
.hks-fill{height:100%;background:linear-gradient(90deg,var(--rust-400),var(--rust-300));border-radius:999px;width:0;transition:width 1.4s cubic-bezier(.22,.85,.44,1)}

/* ─ OCCUPANCY DASHBOARD PANEL ─ */
.occ-panel{padding:1.4rem;min-height:310px;display:flex;flex-direction:column;gap:.75rem}
.occ-header{display:flex;align-items:center;justify-content:space-between}
.occ-title{font-family:var(--ff-m);font-size:.72rem;font-weight:600;color:var(--ink)}
.occ-period{font-family:var(--ff-m);font-size:.64rem;color:var(--ink-muted)}

.occ-chart{display:flex;align-items:flex-end;gap:.42rem;height:120px;background:rgba(255,255,255,.5);border:1px solid var(--line);border-radius:10px;padding:.6rem .75rem;overflow:hidden}
.occ-bar-wrap{flex:1;display:flex;flex-direction:column;align-items:center;gap:.3rem;height:100%}
.occ-bar-track{flex:1;width:100%;background:rgba(162,74,42,.08);border-radius:4px 4px 0 0;position:relative;overflow:hidden;display:flex;align-items:flex-end}
.occ-bar-fill{width:100%;border-radius:4px 4px 0 0;background:linear-gradient(to top,var(--rust-500),var(--rust-300));height:0;transition:height 1.2s cubic-bezier(.22,.85,.44,1)}
.occ-bar-day{font-family:var(--ff-m);font-size:.55rem;color:var(--ink-muted);text-align:center}
.occ-bar-pct{font-family:var(--ff-m);font-size:.56rem;font-weight:700;color:var(--rust-500);text-align:center}

.occ-kpis{display:grid;grid-template-columns:repeat(3,1fr);gap:.5rem}
.occ-kpi{background:#fff;border:1px solid var(--line);border-radius:9px;padding:.6rem .7rem;text-align:center}
.occ-kpi-num{font-family:var(--ff-d);font-size:1.5rem;font-style:italic;color:var(--rust-500);line-height:1;margin-bottom:.18rem}
.occ-kpi-lbl{font-family:var(--ff-m);font-size:.58rem;color:var(--ink-muted);text-transform:uppercase;letter-spacing:.06em}

.occ-alert{display:flex;align-items:center;gap:.45rem;padding:.55rem .75rem;border-radius:9px;background:rgba(192,120,32,.08);border:1px solid rgba(192,120,32,.22);font-family:var(--ff-m);font-size:.7rem;color:#7a4c0e;opacity:0;animation:notifSlide .4s ease 1.8s both}
.occ-alert svg{color:#c07820;flex-shrink:0}

/* ══════════════════════
   HOW IT WORKS
══════════════════════ */
.hm-how{padding:5rem 0;background:linear-gradient(180deg,transparent,rgba(250,240,224,.45) 40%,transparent)}
.hm-how__header{margin-bottom:2.5rem}
.hm-how__steps{display:grid;grid-template-columns:repeat(4,1fr);gap:0;position:relative}
.hm-step{position:relative;opacity:0;animation:stepIn .6s cubic-bezier(.22,.85,.44,1) both;animation-play-state:paused}
.hm-step.in-view{animation-play-state:running}
.hm-step:nth-child(1){animation-delay:0s}
.hm-step:nth-child(2){animation-delay:.13s}
.hm-step:nth-child(3){animation-delay:.26s}
.hm-step:nth-child(4){animation-delay:.39s}
.hm-step__number{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--rust-500),var(--rust-700));color:#fff8ee;font-size:.74rem;font-weight:700;letter-spacing:.05em;display:flex;align-items:center;justify-content:center;margin-bottom:1rem;position:relative;z-index:2;box-shadow:0 4px 16px rgba(162,74,42,.3)}
.hm-step__connector{position:absolute;top:21px;left:calc(42px + 1rem);right:-1rem;height:1.5px;background:var(--line);transform-origin:left;animation:connGrow .55s ease both;animation-play-state:paused}
.hm-step.in-view .hm-step__connector{animation-play-state:running}
.hm-step:last-child .hm-step__connector{display:none}
.hm-step__card{padding-right:1.4rem}
.hm-step__card h3{font-size:.97rem;font-weight:600;color:var(--ink);margin-bottom:.42rem}
.hm-step__card p{font-size:.86rem;font-weight:300;color:var(--ink-soft);line-height:1.68}

/* ══════════════════════
   FEATURES GRID
══════════════════════ */
.features-grid-sec{padding:5rem 0;border-top:1px solid var(--line)}
.feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);margin-top:2rem;border:1px solid var(--line);border-radius:16px;overflow:hidden}
.feat-card{background:var(--rust-50);padding:1.8rem 1.6rem;position:relative;overflow:hidden;transition:background .3s;opacity:0}
.feat-card.in-view{animation:fadeUp .5s cubic-bezier(.22,.85,.44,1) both}
.feat-card:hover{background:#f5e8d4}
.feat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2.5px;background:linear-gradient(90deg,var(--rust-400),var(--rust-300));transform:scaleX(0);transform-origin:left;transition:transform .4s}
.feat-card:hover::before{transform:scaleX(1)}
.feat-card-num{font-family:var(--ff-m);font-size:.6rem;font-weight:600;letter-spacing:.1em;color:var(--rust-400);opacity:.6;margin-bottom:.55rem}
.feat-card h3{font-family:var(--ff-d);font-size:1.08rem;font-weight:400;color:var(--ink);margin-bottom:.4rem;line-height:1.22}
.feat-card p{font-size:.86rem;font-weight:300;color:var(--ink-soft);line-height:1.72}

/* ══════════════════════
   FIT FOR
══════════════════════ */
.hm-fit{padding:5rem 0;background:linear-gradient(to bottom,rgba(250,240,225,.4),transparent)}
.hm-fit__inner{display:grid;grid-template-columns:1fr 1fr;gap:4.5rem;align-items:start}
.hm-fit__left h2{margin-top:.5rem;margin-bottom:.85rem}
.hm-fit__left>p{font-size:.97rem;font-weight:300;color:var(--ink-soft);line-height:1.78;margin-bottom:1.4rem}
.hm-fit__list{list-style:none;display:grid;gap:.65rem}
.hm-fit__item{display:flex;align-items:center;gap:.8rem;font-size:.95rem;font-weight:500;color:var(--ink)}
.hm-fit__check{width:26px;height:26px;border-radius:50%;background:rgba(162,74,42,.1);border:1.5px solid rgba(162,74,42,.22);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--rust-500)}
.hm-fit__check svg{width:12px;height:12px}
.hm-fit__right{display:flex;flex-direction:column;gap:.85rem}
.hm-stat-card{border:1.5px solid var(--line);border-radius:16px;padding:1.5rem 1.6rem;background:rgba(255,252,244,.9);display:flex;align-items:center;gap:1.3rem}
.hmsc-n{font-family:var(--ff-d);font-size:2.6rem;font-style:italic;color:var(--rust-500);line-height:1;flex-shrink:0;width:80px}
.hmsc-t{font-size:.87rem;color:var(--ink-soft);line-height:1.6}
.hmsc-t strong{color:var(--ink);font-weight:600}

/* ══════════════════════
   CTA
══════════════════════ */
.hm-cta{padding:3rem 0 5.5rem}
.hm-cta__card{position:relative;border:1.5px solid var(--line);border-radius:26px;padding:4rem 3.5rem;background:linear-gradient(148deg,rgba(255,246,230,.98),rgba(252,233,200,.9));box-shadow:0 24px 64px rgba(75,42,21,.1);text-align:center;overflow:hidden;opacity:0}
.hm-cta__card.in-view{animation:fadeUp .8s cubic-bezier(.22,.85,.44,1) forwards}
.hm-cta__glow{position:absolute;top:-70px;right:-70px;width:320px;height:320px;border-radius:50%;background:radial-gradient(circle,rgba(162,74,42,.14),transparent 70%);animation:glowPulse 4s ease-in-out infinite;pointer-events:none}
.hm-cta__card h2{font-family:var(--ff-d);font-size:clamp(1.6rem,3vw,2.4rem);letter-spacing:-.02em;line-height:1.2;color:var(--ink);max-width:46ch;margin:.6rem auto .9rem}
.hm-cta__sub{color:var(--ink-soft);font-size:.97rem;font-weight:300;max-width:52ch;margin:0 auto}

footer{background:var(--dark-bg);color:rgba(255,255,255,.35);text-align:center;padding:2rem 2.4rem;font-size:.82rem;font-weight:300}
footer strong{color:var(--rust-300);font-weight:500}

/* ── RESPONSIVE ── */
@media(max-width:980px){
  nav{padding:.9rem 1.5rem}.nav-links{display:none}
  .hm-hero__grid,.feat-row,.hm-fit__inner,.hm-problem__card{grid-template-columns:1fr}
  .feat-row.reverse .feat-copy,.feat-row.reverse .feat-illu{order:unset}
  .hm-how__steps{grid-template-columns:1fr 1fr;gap:1.4rem}.hm-step__connector{display:none}
  .stats-strip{grid-template-columns:repeat(2,1fr)}
  .demo-float-1,.demo-float-2{display:none}
  .feat-grid{grid-template-columns:1fr 1fr}
}
@media(max-width:640px){
  .hm-how__steps{grid-template-columns:1fr}
  .feat-grid{grid-template-columns:1fr}
  .hm-cta__card{padding:2.5rem 1.4rem}
  .stats-strip{grid-template-columns:repeat(2,1fr)}
}
</style>

<script is:inline>
(() => {

  /* ── NAV SCROLL ── */
  const nav = document.getElementById('mainnav');
  window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', scrollY > 40), { passive: true });

  /* ── INTERSECTION OBSERVER ── */
  const seen = new Set();
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (!e.isIntersecting || seen.has(e.target)) return;
      seen.add(e.target);
      e.target.classList.add('in-view');
      const id = e.target.id;
      if (id === 'problemCard') { /* just class add above */ }
      if (id === 'checkinPanel') triggerCheckin();
      if (id === 'hkPanel') triggerHousekeeping();
      if (id === 'occPanel') triggerOccupancy();
      io.unobserve(e.target);
    });
  }, { threshold: .18, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll(
    '.reveal-up, .reveal-fade, .hm-step, .feat-card, .hm-fit__item, #problemCard, #checkinPanel, #hkPanel, #occPanel, #ctaCard'
  ).forEach(el => io.observe(el));

  /* ── STAT COUNTERS ── */
  const cio = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const el = e.target;
      const target = +el.dataset.count;
      if (target === 0) { el.textContent = '0'; cio.unobserve(el); return; }
      let v = 0;
      const step = Math.ceil(target / 40);
      const t = setInterval(() => {
        v = Math.min(v + step, target);
        el.textContent = v;
        if (v >= target) clearInterval(t);
      }, 35);
      cio.unobserve(el);
    });
  }, { threshold: .5 });
  document.querySelectorAll('[data-count]').forEach(el => cio.observe(el));

  /* ══════════════════════════════════════
     HERO: LIVE ROOM GRID
  ══════════════════════════════════════ */
  const floors = [
    // floor 1 — 18 rooms, statuses
    [
      {n:'101',s:'occupied'},{n:'102',s:'occupied'},{n:'103',s:'vacant'},
      {n:'104',s:'occupied'},{n:'105',s:'cleaning'},{n:'106',s:'reserved'},
      {n:'107',s:'vacant'},{n:'108',s:'occupied'},{n:'109',s:'occupied'},
      {n:'110',s:'cleaning'},{n:'111',s:'reserved'},{n:'112',s:'vacant'},
      {n:'113',s:'occupied'},{n:'114',s:'occupied'},{n:'115',s:'vacant'},
      {n:'116',s:'reserved'},{n:'117',s:'occupied'},{n:'118',s:'cleaning'},
    ],
    // floor 2
    [
      {n:'201',s:'cleaning'},{n:'202',s:'occupied'},{n:'203',s:'occupied'},
      {n:'204',s:'vacant'},{n:'205',s:'occupied'},{n:'206',s:'reserved'},
      {n:'207',s:'occupied'},{n:'208',s:'cleaning'},{n:'209',s:'vacant'},
      {n:'210',s:'occupied'},{n:'211',s:'occupied'},{n:'212',s:'vacant'},
      {n:'213',s:'reserved'},{n:'214',s:'occupied'},{n:'215',s:'cleaning'},
      {n:'216',s:'occupied'},{n:'217',s:'vacant'},{n:'218',s:'occupied'},
    ],
    // floor 3
    [
      {n:'301',s:'vacant'},{n:'302',s:'vacant'},{n:'303',s:'occupied'},
      {n:'304',s:'reserved'},{n:'305',s:'occupied'},{n:'306',s:'vacant'},
      {n:'307',s:'cleaning'},{n:'308',s:'occupied'},{n:'309',s:'reserved'},
      {n:'310',s:'occupied'},{n:'311',s:'vacant'},{n:'312',s:'cleaning'},
      {n:'313',s:'occupied'},{n:'314',s:'reserved'},{n:'315',s:'vacant'},
      {n:'316',s:'occupied'},{n:'317',s:'cleaning'},{n:'318',s:'occupied'},
    ]
  ];

  const grid = document.getElementById('demoRoomGrid');
  const floorBtns = document.querySelectorAll('.demo-floor');
  let currentFloor = 0;

  function countStatuses(rooms) {
    const c = {occupied:0,vacant:0,cleaning:0,reserved:0};
    rooms.forEach(r => c[r.s]++);
    return c;
  }

  function renderFloor(floorIdx) {
    const rooms = floors[floorIdx];
    grid.innerHTML = '';
    rooms.forEach((room, i) => {
      const cell = document.createElement('div');
      cell.className = `room-cell ${room.s}`;
      cell.textContent = room.n.slice(1); // just the last 2 digits
      cell.title = `Room ${room.n} — ${room.s}`;
      setTimeout(() => cell.classList.add('pop'), i * 40);
      grid.appendChild(cell);
    });
    const c = countStatuses(rooms);
    document.getElementById('heroOcc').textContent = c.occupied;
    document.getElementById('heroVac').textContent = c.vacant;
    document.getElementById('heroCln').textContent = c.cleaning;
    document.getElementById('heroRes').textContent = c.reserved;
  }

  floorBtns.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      floorBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentFloor = i;
      renderFloor(i);
    });
  });

  renderFloor(0);

  // Auto-cycle: randomly flip one room status every 4s
  const statusCycle = ['occupied','vacant','cleaning','reserved'];
  setInterval(() => {
    const floorRooms = floors[currentFloor];
    const rIdx = Math.floor(Math.random() * floorRooms.length);
    const currStatus = floorRooms[rIdx].s;
    const nextStatuses = statusCycle.filter(s => s !== currStatus);
    floorRooms[rIdx].s = nextStatuses[Math.floor(Math.random() * nextStatuses.length)];
    const cells = grid.querySelectorAll('.room-cell');
    if (cells[rIdx]) {
      cells[rIdx].className = `room-cell ${floorRooms[rIdx].s} pop`;
    }
    // update counts
    const c = countStatuses(floorRooms);
    document.getElementById('heroOcc').textContent = c.occupied;
    document.getElementById('heroVac').textContent = c.vacant;
    document.getElementById('heroCln').textContent = c.cleaning;
    document.getElementById('heroRes').textContent = c.reserved;
  }, 3800);

  /* ══════════════════════════════════════
     PANEL 1: CHECK-IN FLOW ANIMATION
  ══════════════════════════════════════ */
  function triggerCheckin() {
    const steps = ['cs1','cs2','cs3','cs4'];
    const badge = document.getElementById('cpBadge');
    const done = document.getElementById('cpDone');

    function completeStep(idx, cb) {
      const el = document.getElementById(steps[idx]);
      if (!el) return cb && cb();
      el.classList.add('active');
      setTimeout(() => {
        el.classList.remove('active');
        el.classList.add('done');
        if (cb) setTimeout(cb, 250);
      }, 900);
    }

    setTimeout(() => {
      completeStep(0, () => {
        completeStep(1, () => {
          completeStep(2, () => {
            completeStep(3, () => {
              if (badge) { badge.textContent = 'Complete ✓'; badge.classList.add('done'); }
              setTimeout(() => { done?.classList.add('show'); }, 300);
              // restart loop
              setTimeout(() => {
                steps.forEach(id => {
                  const el = document.getElementById(id);
                  if (el) { el.classList.remove('done','active'); }
                });
                if (badge) { badge.textContent = 'In progress'; badge.classList.remove('done'); }
                done?.classList.remove('show');
                setTimeout(triggerCheckin, 400);
              }, 4000);
            });
          });
        });
      });
    }, 400);
  }

  /* ══════════════════════════════════════
     PANEL 2: HOUSEKEEPING BOARD ANIMATION
  ══════════════════════════════════════ */
  function triggerHousekeeping() {
    const tasks = ['hkt1','hkt2','hkt3','hkt4'];
    tasks.forEach((id, i) => {
      const el = document.getElementById(id);
      if (el) setTimeout(() => el.classList.add('show'), i * 180 + 100);
    });

    // progress bar to 75% (3 of 4 done conceptually)
    setTimeout(() => {
      const fill = document.getElementById('hksFill');
      const pct = document.getElementById('hksBarPct');
      if (fill) fill.style.width = '75%';
      if (pct) {
        let v = 0;
        const t = setInterval(() => {
          v = Math.min(v + 2, 75);
          pct.textContent = v + '%';
          if (v >= 75) clearInterval(t);
        }, 25);
      }
    }, 900);

    // Animate task 2 from "Queued" to "In progress" after a delay
    setTimeout(() => {
      const s = document.getElementById('hkt2s');
      const t = document.getElementById('hkt2');
      if (s) { s.className = 'hk-status hks-progress'; s.textContent = 'In progress'; }
      // task 1 completes
      const s1 = document.getElementById('hkt1s');
      const t1 = document.getElementById('hkt1');
      if (s1) { s1.className = 'hk-status hks-done'; s1.textContent = 'Done ✓'; }
      if (t1) t1.classList.add('task-done');

      // update bar to 100%
      setTimeout(() => {
        const fill = document.getElementById('hksFill');
        const p = document.getElementById('hksBarPct');
        if (fill) fill.style.width = '100%';
        if (p) {
          let v = 75;
          const ti = setInterval(() => {
            v = Math.min(v + 1, 100);
            p.textContent = v + '%';
            if (v >= 100) clearInterval(ti);
          }, 18);
        }
      }, 1200);
    }, 3500);
  }

  /* ══════════════════════════════════════
     PANEL 3: OCCUPANCY CHART + KPIs
  ══════════════════════════════════════ */
  function triggerOccupancy() {
    const days = [
      {d:'Mon',pct:72},{d:'Tue',pct:85},{d:'Wed',pct:91},
      {d:'Thu',pct:78},{d:'Fri',pct:95},{d:'Sat',pct:88},{d:'Sun',pct:62}
    ];

    const chart = document.getElementById('occChart');
    chart.innerHTML = '';

    days.forEach((day, i) => {
      const wrap = document.createElement('div');
      wrap.className = 'occ-bar-wrap';

      const pctLbl = document.createElement('div');
      pctLbl.className = 'occ-bar-pct';
      pctLbl.textContent = '';

      const track = document.createElement('div');
      track.className = 'occ-bar-track';

      const fill = document.createElement('div');
      fill.className = 'occ-bar-fill';
      track.appendChild(fill);

      const dayLbl = document.createElement('div');
      dayLbl.className = 'occ-bar-day';
      dayLbl.textContent = day.d;

      wrap.appendChild(pctLbl);
      wrap.appendChild(track);
      wrap.appendChild(dayLbl);
      chart.appendChild(wrap);

      setTimeout(() => {
        fill.style.height = day.pct + '%';
        // count up the label
        let v = 0;
        const t = setInterval(() => {
          v = Math.min(v + 3, day.pct);
          pctLbl.textContent = v + '%';
          if (v >= day.pct) clearInterval(t);
        }, 20);
      }, i * 120 + 300);
    });

    // KPIs
    const avg = Math.round(days.reduce((a,b) => a + b.pct, 0) / days.length);
    setTimeout(() => animateKpi('kpiOcc', avg + '%'), 1200);
    setTimeout(() => animateKpi('kpiRev', '1.12'), 1400);
    setTimeout(() => animateKpi('kpiTurn', '32m'), 1600);
  }

  function animateKpi(id, val) {
    const el = document.getElementById(id);
    if (!el) return;
    el.style.opacity = '0';
    el.textContent = val;
    el.style.transition = 'opacity .4s ease';
    requestAnimationFrame(() => { el.style.opacity = '1'; });
  }

})();
</script>
