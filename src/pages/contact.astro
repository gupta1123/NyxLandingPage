---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Contact | Nyx Solutions" description="Contact | Nyx Solutions">
  <nav>
    <span class="nav-logo">Nyx Solutions</span>
    <ul class="nav-links">
      <li><a href="/products">Products</a></li>
      <li><a href="/about">About</a></li>
    </ul>
    <a href="/products" class="nav-back">← Products</a>
  </nav>

  <div class="ticker-wrap" aria-hidden="true">
    <div class="ticker">
      <span class="ticker-item">Document Intelligence</span>
      <span class="ticker-item">Field Sales Tracking</span>
      <span class="ticker-item">School ERP</span>
      <span class="ticker-item">AI Photoshoots</span>
      <span class="ticker-item">Hotel Management</span>
      <span class="ticker-item">Restaurant Ordering</span>
      <span class="ticker-item">Carpooling Platform</span>
      <span class="ticker-item">Custom AI Systems</span>
      <span class="ticker-item">Document Intelligence</span>
      <span class="ticker-item">Field Sales Tracking</span>
      <span class="ticker-item">School ERP</span>
      <span class="ticker-item">AI Photoshoots</span>
      <span class="ticker-item">Hotel Management</span>
      <span class="ticker-item">Restaurant Ordering</span>
      <span class="ticker-item">Carpooling Platform</span>
      <span class="ticker-item">Custom AI Systems</span>
    </div>
  </div>

  <main>
    <div class="ring" style="width:600px;height:600px;opacity:.45" aria-hidden="true"></div>
    <div class="ring" style="width:420px;height:420px;opacity:.32" aria-hidden="true"></div>
    <div class="ring" style="width:260px;height:260px;opacity:.22" aria-hidden="true"></div>
    <div class="bg-glow" aria-hidden="true"></div>

    <div class="eyebrow-wrap">
      <span class="eyebrow-dot"></span>
      <span class="eyebrow-text">Contact</span>
    </div>

    <div class="contact-card">
      <div class="card-bar">
        <span class="bar-dot dot-r"></span>
        <span class="bar-dot dot-y"></span>
        <span class="bar-dot dot-g"></span>
        <span class="bar-title">Nyx Solutions — Get in touch</span>
      </div>

      <div class="card-inner">
        <div class="company-block">
          <div class="monogram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 21h18"/>
              <path d="M5 21V7l7-4 7 4v14"/>
              <path d="M9 21v-6h6v6"/>
            </svg>
          </div>
          <div class="company-name">Nyx Solutions</div>
          <div class="company-sub">AI &amp; Software Systems</div>
        </div>

        <div class="contact-items">
          <div class="ci">
            <div class="ci-icon-wrap">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 015.11 12.72a19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
              </svg>
            </div>
            <div class="ci-meta">
              <span class="ci-label">Phone</span>
              <span class="ci-value">+91 74154 56660</span>
            </div>
          </div>

          <div class="ci">
            <div class="ci-icon-wrap">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div class="ci-meta">
              <span class="ci-label">Email</span>
              <span class="ci-value">solutionnyx@gmail.com</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <footer>
    <p>&copy; 2026 <strong>Nyx Solutions</strong> &middot; AI &amp; Software Systems</p>
  </footer>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Sora:wght@300;400;500;600;700&family=DM+Mono:wght@300;400;500&display=swap');

    :root {
      --rust-50:#fdf8ef; --rust-100:#f5ebda; --rust-200:#e9c9a8;
      --rust-300:#da956a; --rust-400:#c56f45; --rust-500:#a24a2a;
      --rust-600:#85361c; --rust-700:#6b2a14;
      --sand-50:#fff8ed; --sand-100:#f5e8d4; --sand-200:#d8c8b3;
      --ink:#1f1a16; --ink-soft:#5f5148; --ink-muted:#7a5c4c;
      --surface:#fdf8ef; --line:rgba(216,200,179,.78); --line-mid:rgba(196,160,126,.45);
      --dark-bg:#2e1f19;
      --ff-d:'Instrument Serif',Georgia,serif;
      --ff-b:'Sora',sans-serif;
      --ff-m:'DM Mono',monospace;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{
      font-family:var(--ff-b);
      background:
        radial-gradient(circle at 92% 4%,rgba(162,74,42,.13) 0,rgba(162,74,42,0) 40%),
        radial-gradient(circle at 6% 18%,rgba(255,226,171,.26) 0,rgba(255,226,171,0) 38%),
        var(--surface);
      color:var(--ink);font-size:16px;line-height:1.7;overflow-x:hidden;
      min-height:100vh;display:flex;flex-direction:column;
    }
    @keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:none}}
    @keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    @keyframes ping{0%{box-shadow:0 0 0 0 rgba(162,74,42,.55)}70%{box-shadow:0 0 0 9px rgba(162,74,42,0)}100%{box-shadow:0 0 0 0 rgba(162,74,42,0)}}
    @keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
    @keyframes glowPulse{0%,100%{opacity:.45;transform:translate(-50%,-50%) scale(1)}50%{opacity:.7;transform:translate(-50%,-50%) scale(1.06)}}

    nav{position:sticky;top:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:.9rem 2.8rem;background:rgba(253,248,239,.93);backdrop-filter:blur(16px);border-bottom:1px solid var(--line);transition:padding .3s}
    .nav-logo{font-family:var(--ff-d);font-size:1.3rem;font-style:italic;color:var(--rust-600)}
    .nav-links{display:flex;gap:2rem;list-style:none}
    .nav-links a{font-size:.83rem;font-weight:400;color:var(--ink-soft);text-decoration:none;transition:color .2s}
    .nav-links a:hover{color:var(--rust-500)}
    .nav-back{font-size:.83rem;font-weight:600;padding:.46rem 1.15rem;border-radius:8px;background:var(--rust-500);color:#fff;text-decoration:none;transition:background .2s,transform .15s}
    .nav-back:hover{background:var(--rust-600);transform:translateY(-1px)}

    .ticker-wrap{overflow:hidden;background:linear-gradient(90deg,#f3e6cf,#ecd8b8);border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:.5rem 0}
    .ticker{display:flex;white-space:nowrap;animation:ticker 32s linear infinite}
    .ticker-item{font-size:.7rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--rust-600);padding:0 2.2rem;flex-shrink:0}
    .ticker-item::after{content:'·';margin-left:2.2rem;color:var(--rust-400)}

    main{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:5.5rem 2rem 6rem;position:relative;overflow:hidden}
    .ring{position:absolute;border-radius:50%;border:1px solid var(--line);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}
    .bg-glow{position:absolute;width:380px;height:380px;border-radius:50%;background:radial-gradient(circle,rgba(162,74,42,.08),transparent 68%);top:50%;left:50%;transform:translate(-50%,-50%);animation:glowPulse 4.8s ease-in-out infinite;pointer-events:none}

    .eyebrow-wrap{display:inline-flex;align-items:center;gap:.55rem;margin-bottom:2.4rem;position:relative;z-index:1;opacity:0;animation:fadeUp .65s cubic-bezier(.22,.85,.44,1) .1s both}
    .eyebrow-dot{width:8px;height:8px;border-radius:50%;background:var(--rust-500);animation:ping 2.2s ease-in-out infinite}
    .eyebrow-text{font-size:.7rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--rust-600);font-family:var(--ff-m)}

    .contact-card{width:100%;max-width:440px;border:1.5px solid var(--line-mid);border-radius:20px;background:rgba(255,252,242,.97);box-shadow:0 28px 72px rgba(75,42,21,.13),0 4px 18px rgba(75,42,21,.06);overflow:hidden;position:relative;z-index:1;opacity:0;animation:fadeUp .8s cubic-bezier(.22,.85,.44,1) .22s both}
    .card-bar{display:flex;align-items:center;gap:.45rem;padding:.7rem 1rem;background:rgba(245,235,218,.7);border-bottom:1px solid var(--line)}
    .bar-dot{width:10px;height:10px;border-radius:50%}
    .dot-r{background:#f06257}.dot-y{background:#f5a623}.dot-g{background:#57c257}
    .bar-title{margin-left:.4rem;font-family:var(--ff-m);font-size:.72rem;font-weight:600;color:var(--ink-soft);letter-spacing:.04em}

    .card-inner{padding:2rem 2rem 2.2rem}
    .company-block{text-align:center;margin-bottom:1.75rem;padding-bottom:1.75rem;border-bottom:1px solid var(--line)}
    .monogram{width:54px;height:54px;border-radius:50%;background:rgba(162,74,42,.08);border:1.5px solid rgba(162,74,42,.18);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;color:var(--rust-500);animation:floatY 3.8s ease-in-out infinite}
    .monogram svg{width:22px;height:22px}
    .company-name{font-family:var(--ff-d);font-size:1.55rem;font-weight:400;letter-spacing:-.01em;color:var(--ink);margin-bottom:.28rem}
    .company-sub{font-family:var(--ff-m);font-size:.63rem;font-weight:500;letter-spacing:.13em;text-transform:uppercase;color:var(--ink-muted)}

    .contact-items{display:flex;flex-direction:column;gap:.55rem}
    .ci{display:flex;align-items:center;gap:.65rem;padding:.6rem .75rem;border-radius:10px;background:rgba(162,74,42,.04);border:1px solid rgba(162,74,42,.08);color:inherit;transition:background .22s,border-color .22s,box-shadow .22s,transform .18s}
    .ci:hover{background:rgba(162,74,42,.09);border-color:rgba(162,74,42,.26);box-shadow:0 4px 18px rgba(75,42,21,.1);transform:translateY(-1px)}
    .ci-icon-wrap{width:38px;height:38px;border-radius:9px;background:rgba(255,252,242,.85);border:1px solid var(--line);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--rust-500);opacity:.75}
    .ci-icon-wrap svg{width:16px;height:16px}
    .ci-meta{flex:1}
    .ci-label{font-family:var(--ff-m);font-size:.6rem;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-muted);display:block;margin-bottom:.2rem}
    .ci-value{font-family:var(--ff-m);font-size:.86rem;font-weight:500;color:var(--ink)}
    .ci-badge{font-family:var(--ff-m);font-size:.62rem;font-weight:600;letter-spacing:.06em;border-radius:999px;padding:.16rem .5rem;flex-shrink:0;background:rgba(162,74,42,.07);color:var(--rust-600);border:1px solid rgba(162,74,42,.15);opacity:0;transition:opacity .2s}
    .ci:hover .ci-badge{opacity:1}

    footer{background:var(--dark-bg);color:rgba(255,255,255,.35);text-align:center;padding:2rem 2.4rem;font-size:.8rem;font-weight:300}
    footer strong{color:var(--rust-300);font-weight:500}

    @media(max-width:768px){
      nav{padding:.9rem 1.4rem}.nav-links{display:none}
      main{padding:3.5rem 1.2rem 5rem}
    }
  </style>
</MainLayout>
