---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/pages/briefly-docs.css';
---

<MainLayout title="Briefly Docs | Nyx Solution" description="Document intelligence and workflow support for teams handling business-critical documents.">
  <!-- NAV -->
  <nav id="mainnav">
    <div class="nav-left">
      <a class="nav-back" href="/products" aria-label="Back to products">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
      </a>
      <span class="nav-logo">Nyx Solution</span>
    </div>
    <ul class="nav-links">
      <li><a href="#search">Search</a></li>
      <li><a href="#answers">Answers</a></li>
      <li><a href="#versions">Versions</a></li>
      <li><a href="#workflow">Workflow</a></li>
    </ul>
    <div class="nav-right">
    </div>

  </nav>

  <!-- TICKER -->
  <div class="ticker-wrap" aria-hidden="true">
    <div class="ticker">
      <span class="ticker-item">Document search</span>
      <span class="ticker-item">Source-verified answers</span>
      <span class="ticker-item">Version awareness</span>
      <span class="ticker-item">Policy retrieval</span>
      <span class="ticker-item">Workflow support</span>
      <span class="ticker-item">Knowledge access</span>
      <span class="ticker-item">Institutional memory</span>
      <span class="ticker-item">Contract intelligence</span>
      <span class="ticker-item">Document search</span>
      <span class="ticker-item">Source-verified answers</span>
      <span class="ticker-item">Version awareness</span>
      <span class="ticker-item">Policy retrieval</span>
      <span class="ticker-item">Workflow support</span>
      <span class="ticker-item">Knowledge access</span>
      <span class="ticker-item">Institutional memory</span>
      <span class="ticker-item">Contract intelligence</span>
      <span class="ticker-item">Document search</span>
      <span class="ticker-item">Source-verified answers</span>
      <span class="ticker-item">Version awareness</span>
      <span class="ticker-item">Policy retrieval</span>
      <span class="ticker-item">Workflow support</span>
      <span class="ticker-item">Knowledge access</span>
      <span class="ticker-item">Institutional memory</span>
      <span class="ticker-item">Contract intelligence</span>
      <span class="ticker-item">Document search</span>
      <span class="ticker-item">Source-verified answers</span>
      <span class="ticker-item">Version awareness</span>
      <span class="ticker-item">Policy retrieval</span>
      <span class="ticker-item">Workflow support</span>
      <span class="ticker-item">Knowledge access</span>
      <span class="ticker-item">Institutional memory</span>
      <span class="ticker-item">Contract intelligence</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="bd-hero">
    <div class="container">
      <div class="bd-hero__grid">

        <div>
          <div class="bd-hero__eyebrow reveal-up">
            <span class="eyebrow-dot"></span>
            <span class="eyebrow-text">Document Intelligence Product</span>
          </div>
          <h1 class="bd-hero__h1 reveal-up" style="animation-delay:.1s">
            Find answers in your documents.<br />
            <em>Verify them.</em> Move work forward.
          </h1>
          <p class="bd-hero__lead reveal-up" style="animation-delay:.2s">
            A document intelligence and workflow platform for organisations that need fast, trustworthy access to information across business-critical documents — without manual digging.
          </p>
          <div class="cta-row reveal-up" style="animation-delay:.3s">
            <a class="btn ghost" href="#search">See Platform</a>
          </div>
        </div>

        <!-- HERO DEMO WINDOW -->
        <div class="bd-hero__demo reveal-fade" style="animation-delay:.45s">
          <div class="demo-window">
            <div class="demo-bar">
              <span class="demo-dot demo-dot-r"></span>
              <span class="demo-dot demo-dot-y"></span>
              <span class="demo-dot demo-dot-g"></span>
              <span class="demo-bar-title">Briefly Docs</span>
            </div>
            <div class="demo-body">
              <!-- Search bar with typewriter -->
              <div class="demo-search" id="demoSearch">
                <svg class="demo-search-icon" width="16" height="16" viewBox="0 0 20 20" fill="none"><circle cx="9" cy="9" r="5.5" stroke="currentColor" stroke-width="1.5"></circle><path d="M13 13l3.5 3.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path></svg>
                <span class="demo-typed" id="demoTyped"></span><span class="demo-cursor" id="demoCursor">|</span>
              </div>

              <!-- Document library being scanned -->
              <div class="demo-library" id="demoLibrary">
                <div class="demo-lib-item" id="lib1" data-state="idle">
                  <svg class="demo-lib-icon" width="13" height="13" viewBox="0 0 16 16" fill="none"><rect x="2" y="1" width="10" height="13" rx="1.5" stroke="currentColor" stroke-width="1.2"></rect><path d="M4 5h6M4 7.5h4" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path></svg>
                  <span class="demo-lib-name">Leave_Policy_v4.pdf</span>
                  <span class="demo-lib-tag idle" id="lib1-tag">Indexed</span>
                </div>
                <div class="demo-lib-item" id="lib2" data-state="idle">
                  <svg class="demo-lib-icon" width="13" height="13" viewBox="0 0 16 16" fill="none"><rect x="2" y="1" width="10" height="13" rx="1.5" stroke="currentColor" stroke-width="1.2"></rect><path d="M4 5h6M4 7.5h4" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path></svg>
                  <span class="demo-lib-name">Vendor_Agreement_2024.pdf</span>
                  <span class="demo-lib-tag idle" id="lib2-tag">Indexed</span>
                </div>
                <div class="demo-lib-item" id="lib3" data-state="idle">
                  <svg class="demo-lib-icon" width="13" height="13" viewBox="0 0 16 16" fill="none"><rect x="2" y="1" width="10" height="13" rx="1.5" stroke="currentColor" stroke-width="1.2"></rect><path d="M4 5h6M4 7.5h4" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path></svg>
                  <span class="demo-lib-name">Travel_Reimbursement_SOP.docx</span>
                  <span class="demo-lib-tag idle" id="lib3-tag">Indexed</span>
                </div>
              </div>

              <!-- Answer result -->
              <div class="demo-answer" id="demoAnswer">
                <div class="demo-answer-head">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="2" y="1" width="10" height="13" rx="1.5" stroke="currentColor" stroke-width="1.2"></rect><path d="M4 5h6M4 7.5h4M4 10h2" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path></svg>
                  <span class="demo-answer-doc">Leave_Policy_v4.pdf</span>
                  <span class="demo-answer-badge">Source verified</span>
                </div>
                <div class="demo-answer-text">
                  Employees are entitled to <mark class="hl" id="hl1">18 days of annual leave</mark> per calendar year, accrued monthly. Carry-forward is capped at <mark class="hl" id="hl2">6 days</mark> subject to manager approval.
                </div>
                <div class="demo-answer-source">
                  <svg viewBox="0 0 14 14" fill="none" width="12" height="12"><path d="M7 1v6l3 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"></circle></svg>
                  Page 3 · Section 2.1 · Last updated Mar 2024
                </div>
              </div>
            </div>
          </div>

          <!-- floating badges -->
          <div class="demo-float demo-float-1 reveal-fade" style="animation-delay:.9s">
            <svg viewBox="0 0 16 16" fill="none" width="13" height="13"><path d="M8 1l1.8 3.6L14 5.5l-3 2.9.7 4.1L8 10.4l-3.7 2.1.7-4.1L2 5.5l4.2-.9L8 1z" stroke="currentColor" stroke-width="1.2" fill="currentColor" fill-opacity=".15"></path></svg>
            Proof-grounded
          </div>
          <div class="demo-float demo-float-2 reveal-fade" style="animation-delay:1.1s">
            <svg viewBox="0 0 16 16" fill="none" width="13" height="13"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3"></circle><path d="M5.5 8l2 2 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            Version-aware
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- STATS -->
  <div class="stats-strip">
    <div class="stat-item"><span class="stat-num" data-count="100">0</span><span class="stat-label">% source-grounded answers</span></div>
    <div class="stat-item"><span class="stat-num" data-count="5">0</span><span class="stat-label">document types supported</span></div>
    <div class="stat-item"><span class="stat-num" data-count="3">0</span><span class="stat-label">seconds average to answer</span></div>
    <div class="stat-item"><span class="stat-num" data-count="12">0</span><span class="stat-label">× faster than manual search</span></div>
  </div>

  <!-- PROBLEM -->
  <section class="bd-problem">
    <div class="narrow">
      <div class="bd-problem__card" id="problemCard">
        <div class="bd-problem-icon">
          <svg width="52" height="52" viewBox="0 0 48 48" fill="none"><rect x="6" y="4" width="24" height="30" rx="3" stroke="currentColor" stroke-width="1.8" stroke-dasharray="4 3"></rect><rect x="14" y="12" width="24" height="30" rx="3" fill="rgba(162,74,42,.06)" stroke="currentColor" stroke-width="1.8" stroke-dasharray="4 3"></rect><circle cx="38" cy="38" r="7" fill="var(--rust-50)" stroke="currentColor" stroke-width="1.8"></circle><path d="M38 34v4h3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg>
        </div>
        <div class="bd-problem__text">
          <h2>Most teams don't struggle because information is missing. They struggle because it is buried.</h2>
          <p>Policies, SOPs, contracts, circulars, and approvals exist across folders and systems. But finding the right answer still takes too long — and when it is found, teams may not be sure it is the latest version or something they can confidently act on.</p>
          <p>Briefly Docs is built to reduce that friction.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURE ROWS -->
  <section class="feat-section">
    <div class="container">

      <!-- 1 · SEARCH ACROSS DOCUMENTS -->
      <div class="feat-row" id="search">
        <div class="feat-copy reveal-up">
          <span class="eyebrow">Search across documents</span>
          <h2 class="sh2">Find what matters — <em>across your entire library</em></h2>
          <p>No more manual digging through folders, drives, or email threads. Ask in plain language and get to the right document — and the right passage — instantly.</p>
          <ul class="bullet-list">
            <li>Search across PDFs, Word files, and folders at once</li>
            <li>Natural language — no query syntax to learn</li>
            <li>Results ranked by relevance, not last modified</li>
          </ul>
        </div>
        <div class="feat-illu reveal-fade" style="animation-delay:.1s">
          <div class="illu-panel doc-flow-panel" id="docFlowPanel">
            <div class="dfp-header">
              <div class="dfp-title">Document Library — 48 files indexed</div>
              <div class="dfp-live"><div class="dfp-live-dot"></div>Live</div>
            </div>
            <div class="doc-row" id="dr1">
              <svg class="doc-icon" width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="2" y="1" width="10" height="13" rx="1.5" stroke="currentColor" stroke-width="1.2"></rect><path d="M4 5h6M4 7.5h4M4 10h2" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path></svg>
              <div><div class="doc-name">Leave_Policy_v4.pdf</div><div class="doc-meta">HR Policies · 2.1 MB</div></div>
              <span class="doc-status status-ok">Indexed</span>
            </div>
            <div class="doc-row" id="dr2">
              <svg class="doc-icon" width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="2" y="1" width="10" height="13" rx="1.5" stroke="currentColor" stroke-width="1.2"></rect><path d="M4 5h6M4 7.5h4M4 10h2" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path></svg>
              <div><div class="doc-name">Vendor_Agreement_2024.pdf</div><div class="doc-meta">Contracts · 4.7 MB</div></div>
              <span class="doc-status status-ok">Indexed</span>
            </div>
            <div class="doc-row" id="dr3">
              <svg class="doc-icon" width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="2" y="1" width="10" height="13" rx="1.5" stroke="currentColor" stroke-width="1.2"></rect><path d="M4 5h6M4 7.5h4M4 10h2" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path></svg>
              <div><div class="doc-name">Travel_Reimbursement_SOP.docx</div><div class="doc-meta">SOPs · 1.4 MB</div></div>
              <span class="doc-status status-scanning" id="dr3-status">Scanning…</span>
            </div>
            <div class="doc-row" id="dr4">
              <svg class="doc-icon" width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="2" y="1" width="10" height="13" rx="1.5" stroke="currentColor" stroke-width="1.2"></rect><path d="M4 5h6M4 7.5h4M4 10h2" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path></svg>
              <div><div class="doc-name">Finance_Approval_Matrix.pdf</div><div class="doc-meta">Finance · 892 KB</div></div>
              <span class="doc-status status-queued">Queued</span>
            </div>
            <div class="dfp-progress" id="dfpProgress">
              <div class="dfp-progress-label"><span>Indexing progress</span><span>78%</span></div>
              <div class="dfp-bar-track"><div class="dfp-bar-fill" id="dfpFill"></div></div>
            </div>
          </div>
        </div>
      </div>

      <!-- 2 · ANSWERS WITH PROOF -->
      <div class="feat-row reverse" id="answers">
        <div class="feat-copy reveal-up">
          <span class="eyebrow">Answers with proof</span>
          <h2 class="sh2">Every answer tied back to its <em>exact source</em></h2>
          <p>Every answer is linked to the exact paragraph it came from, with document name, page number, and section reference — so your team can verify before acting, not just trust the output.</p>
          <ul class="bullet-list">
            <li>Source paragraph highlighted in the original document</li>
            <li>Document name, page, and section cited on every answer</li>
            <li>Acts as evidence, not just information</li>
          </ul>
        </div>
        <div class="feat-illu reveal-fade" style="animation-delay:.1s">
          <div class="illu-panel answer-panel" id="answerPanel">
            <div class="ap-query">
              <svg width="13" height="13" viewBox="0 0 20 20" fill="none"><circle cx="9" cy="9" r="5.5" stroke="currentColor" stroke-width="1.5"></circle><path d="M13 13l3.5 3.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path></svg>
              <span class="ap-query-text">"How many annual leave days are employees entitled to?"</span>
            </div>
            <div class="ap-source" id="apSource">
              <div class="ap-source-bar" id="apBar"></div>
              <div class="ap-source-file">
                <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><rect x="2" y="1" width="10" height="13" rx="1.5" stroke="currentColor" stroke-width="1.2"></rect><path d="M4 5h6M4 7.5h4" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path></svg>
                Leave_Policy_v4.pdf — Page 3, Section 2.1
              </div>
              <div class="ap-source-text">
                …<mark class="hl" id="apHl1">Employees are entitled to 18 days of annual leave per calendar year</mark>, accrued at 1.5 days per month. Leaves may be carried forward into the following year, subject to a cap of <mark class="hl" id="apHl2">6 days maximum</mark>, with explicit manager approval required…
              </div>
              <div class="ap-source-page">
                <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M7 1v6l3 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"></circle></svg>
                Source locked · Mar 2024 · v4 (current)
              </div>
            </div>
            <div class="ap-answer-box" id="apAnswer">
              <div class="ap-answer-label">Answer</div>
              <div class="ap-answer-text">Employees get <strong>18 days</strong> of annual leave, with a carry-forward cap of <strong>6 days</strong> subject to manager approval.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- 3 · VERSION AWARENESS -->
      <div class="feat-row" id="versions">
        <div class="feat-copy reveal-up">
          <span class="eyebrow">Version awareness</span>
          <h2 class="sh2">Always know which version <em>the answer came from</em></h2>
          <p>Stop acting on outdated policies or superseded procedures. Briefly Docs tells you exactly which document version an answer references — so version confusion becomes a problem of the past.</p>
          <ul class="bullet-list">
            <li>Document version cited on every answer</li>
            <li>Flags when a newer version of a file exists</li>
            <li>Historical versions still queryable, but clearly marked</li>
          </ul>
        </div>
        <div class="feat-illu reveal-fade" style="animation-delay:.1s">
          <div class="illu-panel scan-panel" id="scanPanel">
            <div class="scan-doc" id="scanDoc">
              <div class="scan-doc-header">
                <span class="scan-doc-name">Leave_Policy_v4.pdf</span>
                <span class="scan-doc-version">v4 — Mar 2024 (current)</span>
              </div>
              <!-- Text lines -->
              <div class="scan-line" style="width:88%"></div>
              <div class="scan-line" style="width:72%"></div>
              <div class="scan-line highlight" id="hl-line-1" style="width:91%"></div>
              <div class="scan-line" style="width:65%"></div>
              <div class="scan-line" style="width:80%"></div>
              <div class="scan-line highlight" id="hl-line-2" style="width:58%"></div>
              <div class="scan-line" style="width:75%"></div>
              <div class="scan-line" style="width:82%"></div>
              <div class="scan-line" style="width:60%"></div>
              <div class="scan-line" style="width:88%"></div>
              <div class="scan-line" style="width:70%"></div>
            </div>
            <div class="scan-beam"></div>
            <div class="scan-found-badge" id="scanFoundBadge">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3"></circle><path d="M5 8l2.5 2.5L11 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
              Answer found — Page 3
            </div>
            <div class="scan-versions" id="scanVersions">
              <div class="scan-ver-card">
                <div class="scan-ver-tag current">✓ v4 — Current</div>
                <div class="scan-ver-date">Updated Mar 2024</div>
              </div>
              <div class="scan-ver-card">
                <div class="scan-ver-tag old">v3 — Superseded</div>
                <div class="scan-ver-date">Jan 2023 · archived</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 4 · WORKFLOW SUPPORT -->
      <div class="feat-row reverse" id="workflow">
        <div class="feat-copy reveal-up">
          <span class="eyebrow">Workflow support</span>
          <h2 class="sh2">Not just search — <em>built into how work gets done</em></h2>
          <p>Briefly Docs is built around document-heavy workflows, not just passive search. Handle queries that feed directly into approvals, actions, and decisions without switching tools.</p>
          <ul class="bullet-list">
            <li>Link answers directly to approval or routing steps</li>
            <li>Handle compliance and operational queries in context</li>
            <li>Share verified answers with teams — not raw files</li>
          </ul>
        </div>
        <div class="feat-illu reveal-fade" style="animation-delay:.1s">
          <div class="illu-panel workflow-panel" id="workflowPanel">
            <div class="wf-step" id="wf1">
              <div class="wf-step-num">1</div>
              <span class="wf-step-label">Employee asks: "What is our notice period?"</span>
            </div>
            <div class="wf-connector"><div class="wf-conn-line"></div></div>
            <div class="wf-step" id="wf2">
              <div class="wf-step-num">2</div>
              <span class="wf-step-label">Briefly Docs searches across HR docs</span>
              <span class="wf-step-tag status-scanning">Live</span>
            </div>
            <div class="wf-connector"><div class="wf-conn-line"></div></div>
            <div class="wf-step" id="wf3">
              <div class="wf-step-num">3</div>
              <span class="wf-step-label">Answer returned with source paragraph</span>
              <span class="wf-step-tag status-ok">Verified</span>
            </div>
            <div class="wf-connector"><div class="wf-conn-line"></div></div>
            <div class="wf-step" id="wf4">
              <div class="wf-step-num">4</div>
              <span class="wf-step-label">Manager approves and routes to HR</span>
              <span class="wf-step-tag status-ok">Actioned</span>
            </div>
            <div class="wf-outcome" id="wfOutcome">
              <div class="wf-outcome-label">Outcome</div>
              <div class="wf-outcome-text">Decision made in 40 seconds. No email threads. No document hunting. Source on record.</div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="bd-how">
    <div class="container">
      <div class="bd-how__header">
        <span class="eyebrow">How it works</span>
        <h2 class="sh2">From question to <em>verified answer</em> in seconds</h2>
      </div>
      <div class="bd-how__steps">
        <div class="bd-step"><div class="bd-step__number">01</div><div class="bd-step__connector"></div><div class="bd-step__card"><h3>Upload your documents</h3><p>Connect or upload your document library — PDFs, Word files, folders, or integrated sources.</p></div></div>
        <div class="bd-step"><div class="bd-step__number">02</div><div class="bd-step__connector"></div><div class="bd-step__card"><h3>Ask in plain language</h3><p>Type a question the way your team would ask it. No query syntax, no filters to learn.</p></div></div>
        <div class="bd-step"><div class="bd-step__number">03</div><div class="bd-step__connector"></div><div class="bd-step__card"><h3>Get an answer with its source</h3><p>See the answer alongside the exact excerpt it came from, with document name and version.</p></div></div>
        <div class="bd-step"><div class="bd-step__number">04</div><div class="bd-step__card"><h3>Act with confidence</h3><p>Share, verify, or act on the answer knowing exactly where it came from and when it was last updated.</p></div></div>
      </div>
    </div>
  </section>

  <!-- AUDIENCE -->
  <section class="bd-audience">
    <div class="container">
      <div class="bd-audience__grid">
        <div>
          <span class="eyebrow">Who it is for</span>
          <h2 class="sh2">Teams dealing with large and <em>operationally important</em> document environments</h2>
          <p class="bd-audience__sub">If your team regularly works with or depends on any of these — Briefly Docs is built for you.</p>
        </div>
        <ul class="bd-audience__list">
          <li class="bd-audience__item" style="animation-delay:.0s"><span class="bd-audience__check"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>SOPs and internal policies</li>
          <li class="bd-audience__item" style="animation-delay:.08s"><span class="bd-audience__check"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>Contracts and legal agreements</li>
          <li class="bd-audience__item" style="animation-delay:.16s"><span class="bd-audience__check"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>Circulars and regulatory notices</li>
          <li class="bd-audience__item" style="animation-delay:.24s"><span class="bd-audience__check"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>Compliance and operational documents</li>
          <li class="bd-audience__item" style="animation-delay:.32s"><span class="bd-audience__check"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>Approvals and workflow-heavy documentation</li>
          <li class="bd-audience__item" style="animation-delay:.40s"><span class="bd-audience__check"><svg viewBox="0 0 14 14" fill="none"><path d="M2.5 7l3.5 3.5 5.5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>Large internal knowledge sets</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bd-cta" id="cta">
    <div class="narrow">
      <div class="bd-cta__card" id="ctaCard">
        <div class="bd-cta__glow" aria-hidden="true"></div>
        <span class="eyebrow">Get started</span>
        <h2>If your team spends too much time searching, cross-checking, and chasing clarity across documents — Briefly Docs can help.</h2>
        <p class="bd-cta__sub">We will show you how it works with your document types.</p>
        <div class="cta-row center" style="margin-top:1.8rem">

        </div>
      </div>
    </div>
  </section>

  <footer><p>&copy; 2026 <strong>Nyx Solution</strong> · Briefly Docs — Document Intelligence Product</p></footer>

  <script is:inline>
    /* ── NAV ── */
    const nav = document.getElementById('mainnav');
    window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', scrollY > 40), { passive: true });

    /* ── INTERSECTION OBSERVER ── */
    const seen = new Set();
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting || seen.has(e.target)) return;
        seen.add(e.target);
        e.target.classList.add('in-view');
        const id = e.target.id;
        if (id === 'docFlowPanel') triggerDocFlow();
        if (id === 'answerPanel') triggerAnswerPanel();
        if (id === 'scanPanel') triggerScanPanel();
        if (id === 'workflowPanel') triggerWorkflow();
        if (id === 'problemCard') e.target.classList.add('in-view');
        if (id === 'ctaCard') e.target.classList.add('in-view');
        io.unobserve(e.target);
      });
    }, { threshold: .15, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll(
      '.reveal-up, .reveal-fade, .bd-step, .bd-audience__item, #docFlowPanel, #answerPanel, #scanPanel, #workflowPanel, #problemCard, #ctaCard'
    ).forEach(el => io.observe(el));

    /* ── COUNT-UP ── */
    const cio = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const el = e.target;
        const target = +el.dataset.count;
        let v = 0;
        const step = Math.ceil(target / 40);
        const t = setInterval(() => { v = Math.min(v + step, target); el.textContent = v; if (v >= target) clearInterval(t); }, 35);
        cio.unobserve(el);
      });
    }, { threshold: .5 });
    document.querySelectorAll('[data-count]').forEach(el => cio.observe(el));

    /* ── HERO TYPEWRITER ── */
    const phrases = [
      'How many annual leave days are employees entitled to?',
      'What is the notice period for contract termination?',
      'Which SOP covers the travel reimbursement process?',
    ];
    const typed = document.getElementById('demoTyped');
    const searchEl = document.getElementById('demoSearch');
    const answerEl = document.getElementById('demoAnswer');
    const hls = [document.getElementById('hl1'), document.getElementById('hl2')];
    const libItems = [
      { el: document.getElementById('lib1'), tag: document.getElementById('lib1-tag') },
      { el: document.getElementById('lib2'), tag: document.getElementById('lib2-tag') },
      { el: document.getElementById('lib3'), tag: document.getElementById('lib3-tag') },
    ];
    let phraseIdx = 0;

    function resetDemo() {
      answerEl?.classList.remove('show');
      hls.forEach(h => h?.classList.remove('lit'));
      libItems.forEach(item => {
        item.el?.classList.remove('scanning', 'done');
        if (item.tag) {
          item.tag.className = 'demo-lib-tag idle';
          item.tag.textContent = 'Indexed';
        }
      });
      searchEl?.classList.remove('active');
    }

    function typePhrase(phrase, done) {
      if (!typed) return;
      resetDemo();
      searchEl?.classList.add('active');
      let i = 0;
      typed.textContent = '';
      const iv = setInterval(() => {
        typed.textContent = phrase.slice(0, ++i);
        if (i >= phrase.length) {
          clearInterval(iv);
          // animate scanning
          setTimeout(() => {
            libItems[0].el?.classList.add('scanning');
            if (libItems[0].tag) {
              libItems[0].tag.className = 'demo-lib-tag scan';
              libItems[0].tag.textContent = 'Scanning…';
            }
          }, 300);
          setTimeout(() => {
            libItems[0].el?.classList.remove('scanning');
            libItems[0].el?.classList.add('done');
            if (libItems[0].tag) {
              libItems[0].tag.className = 'demo-lib-tag found';
              libItems[0].tag.textContent = 'Found ✓';
            }
            libItems[1].el?.classList.add('scanning');
            if (libItems[1].tag) {
              libItems[1].tag.className = 'demo-lib-tag scan';
              libItems[1].tag.textContent = 'Scanning…';
            }
          }, 900);
          setTimeout(() => {
            libItems[1].el?.classList.remove('scanning');
            if (libItems[1].tag) {
              libItems[1].tag.className = 'demo-lib-tag idle';
              libItems[1].tag.textContent = 'Indexed';
            }
            libItems[2].el?.classList.add('scanning');
            if (libItems[2].tag) {
              libItems[2].tag.className = 'demo-lib-tag scan';
              libItems[2].tag.textContent = 'Scanning…';
            }
          }, 1500);
          setTimeout(() => {
            libItems[2].el?.classList.remove('scanning');
            if (libItems[2].tag) {
              libItems[2].tag.className = 'demo-lib-tag idle';
              libItems[2].tag.textContent = 'Indexed';
            }
            answerEl?.classList.add('show');
            setTimeout(() => hls.forEach(h => h?.classList.add('lit')), 350);
            setTimeout(done, 4000);
          }, 2100);
        }
      }, 40);
    }

    function runCycle() {
      typePhrase(phrases[phraseIdx], () => {
        phraseIdx = (phraseIdx + 1) % phrases.length;
        setTimeout(runCycle, 400);
      });
    }
    // start after page loads
    setTimeout(runCycle, 800);

    /* ── FEATURE PANEL 1: DOC FLOW ── */
    function triggerDocFlow() {
      ['dr1', 'dr2', 'dr3', 'dr4'].forEach((id, i) => {
        const el = document.getElementById(id);
        if (el) setTimeout(() => el.classList.add('show'), i * 150 + 100);
      });
      setTimeout(() => {
        const fill = document.getElementById('dfpFill');
        fill?.classList.add('go');
      }, 800);
      // animate scanning state
      setTimeout(() => {
        const s = document.getElementById('dr3-status');
        if (s) {
          s.textContent = 'Indexed';
          s.className = 'doc-status status-ok';
        }
        const dr3 = document.getElementById('dr3');
        dr3?.classList.remove('scanning');
      }, 3500);
    }

    /* ── FEATURE PANEL 2: ANSWER PANEL ── */
    function triggerAnswerPanel() {
      setTimeout(() => {
        const bar = document.getElementById('apBar');
        bar?.classList.add('go');
        setTimeout(() => {
          [document.getElementById('apHl1'), document.getElementById('apHl2')]
            .forEach(h => h?.classList.add('lit'));
          setTimeout(() => {
            const ans = document.getElementById('apAnswer');
            ans?.classList.add('show');
          }, 600);
        }, 800);
      }, 300);
    }

    /* ── FEATURE PANEL 3: SCAN + VERSION ── */
    function triggerScanPanel() {
      // highlight lines pulse in
      ['hl-line-1', 'hl-line-2'].forEach((id, i) => {
        const el = document.getElementById(id);
        if (el) {
          el.style.backgroundColor = 'transparent';
          setTimeout(() => {
            el.style.transition = 'background-color .6s ease';
            el.style.backgroundColor = 'rgba(255,190,80,.5)';
          }, 600 + i * 400);
        }
      });
      // versions card
      setTimeout(() => {
        const v = document.getElementById('scanVersions');
        if (v) v.style.opacity = '0';
      }, 0);
    }

    /* ── FEATURE PANEL 4: WORKFLOW ── */
    function triggerWorkflow() {
      ['wf1', 'wf2', 'wf3', 'wf4'].forEach((id, i) => {
        const el = document.getElementById(id);
        if (el) setTimeout(() => el.classList.add('show'), i * 200 + 100);
      });
      setTimeout(() => {
        const out = document.getElementById('wfOutcome');
        out?.classList.add('show');
      }, 1200);
    }
  </script>
</MainLayout>
