<style>
@import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Sora:wght@300;400;500;600;700&family=DM+Mono:wght@300;400;500&display=swap');

/* ══════════════════════════════════════════
   TOKENS  — identical to briefly-docs
══════════════════════════════════════════ */
:root {
  --rust-50:#fdf8ef; --rust-100:#f5ebda; --rust-200:#e9c9a8;
  --rust-300:#da956a; --rust-400:#c56f45; --rust-500:#a24a2a;
  --rust-600:#85361c; --rust-700:#6b2a14;
  --sand-50:#fff8ed; --sand-100:#f5e8d4; --sand-200:#d8c8b3;
  --ink:#1f1a16; --ink-soft:#5f5148; --ink-muted:#7a5c4c;
  --surface:#fdf8ef; --line:rgba(216,200,179,.78); --line-mid:rgba(196,160,126,.45);
  --green:#2e8c4f; --amber:#c07820; --blue:#2c5fa8; --dark-bg:#2e1f19;
  --ff-d:'Instrument Serif',Georgia,serif;
  --ff-b:'Sora',sans-serif;
  --ff-m:'DM Mono',monospace;
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  background:
    radial-gradient(circle at 92% 4%,rgba(162,74,42,.13) 0,rgba(162,74,42,0) 40%),
    radial-gradient(circle at 6% 18%,rgba(255,226,171,.26) 0,rgba(255,226,171,0) 38%),
    var(--surface);
  color:var(--ink);font-family:var(--ff-b);font-size:16px;line-height:1.7;overflow-x:hidden;
}

/* ═══ KEYFRAMES ═══ */
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:none}}
@keyframes fadeScale{from{opacity:0;transform:scale(.93)}to{opacity:1;transform:scale(1)}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
@keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-7px)}}
@keyframes ping{0%{box-shadow:0 0 0 0 rgba(162,74,42,.55)}70%{box-shadow:0 0 0 10px rgba(162,74,42,0)}100%{box-shadow:0 0 0 0 rgba(162,74,42,0)}}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@keyframes glowPulse{0%,100%{opacity:.5;transform:scale(1)}50%{opacity:.8;transform:scale(1.07)}}
@keyframes resultSlide{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}
@keyframes badgeIn{from{opacity:0;transform:scale(.8) translateY(6px)}to{opacity:1;transform:scale(1) translateY(0)}}
@keyframes connGrow{from{transform:scaleX(0)}to{transform:scaleX(1)}}
@keyframes stepIn{from{opacity:0;transform:translateX(-20px)}to{opacity:1;transform:none}}
@keyframes listIn{from{opacity:0;transform:translateX(16px)}to{opacity:1;transform:none}}
@keyframes cardFadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:none}}
@keyframes scanPulse{0%{box-shadow:0 0 0 0 rgba(162,74,42,.35)}70%{box-shadow:0 0 0 8px rgba(162,74,42,0)}100%{box-shadow:0 0 0 0 rgba(162,74,42,0)}}
@keyframes barRise{from{height:0}to{height:var(--bh)}}
@keyframes countUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
@keyframes highlightGrow{from{background-size:0% 85%}to{background-size:100% 85%}}
@keyframes pinBounce{0%,100%{transform:translateY(0) scale(1)}40%{transform:translateY(-8px) scale(1.15)}60%{transform:translateY(-4px) scale(1.05)}}
@keyframes notifSlide{from{opacity:0;transform:translateX(14px)}to{opacity:1;transform:none}}

.reveal-up{animation:fadeUp .75s cubic-bezier(.22,.85,.44,1) both}
.reveal-fade{animation:fadeScale .7s cubic-bezier(.22,.85,.44,1) both}

/* ═══ NAV ═══ */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:.9rem 2.8rem;background:rgba(253,248,239,.93);backdrop-filter:blur(16px);border-bottom:1px solid var(--line);transition:padding .3s}
nav.scrolled{padding-top:.6rem;padding-bottom:.6rem}
.nav-left{display:flex;align-items:center;gap:.7rem}
.nav-back{width:34px;height:34px;border-radius:8px;border:1px solid var(--line);background:rgba(255,252,244,.7);color:var(--rust-600);text-decoration:none;display:inline-flex;align-items:center;justify-content:center;transition:background .2s,border-color .2s,transform .15s}
.nav-back:hover{background:var(--rust-50);border-color:var(--rust-300);transform:translateY(-1px)}
.nav-back svg{width:14px;height:14px}
.nav-logo{font-family:var(--ff-d);font-size:1.3rem;font-style:italic;color:var(--rust-600)}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{font-size:.83rem;font-weight:400;color:var(--ink-soft);text-decoration:none;transition:color .2s}
.nav-links a:hover{color:var(--rust-500)}
.nav-cta{font-size:.83rem;font-weight:600;padding:.46rem 1.15rem;border-radius:8px;background:var(--rust-500);color:#fff;text-decoration:none;transition:background .2s,transform .15s}
.nav-cta:hover{background:var(--rust-600);transform:translateY(-1px)}

/* ═══ TICKER ═══ */
.ticker-wrap{margin-top:63px;overflow:hidden;background:linear-gradient(90deg,#f3e6cf,#ecd8b8);border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:.5rem 0}
.ticker{display:flex;white-space:nowrap;animation:ticker 30s linear infinite}
.ticker-item{font-size:.7rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--rust-600);padding:0 2.2rem;flex-shrink:0}
.ticker-item::after{content:'·';margin-left:2.2rem;color:var(--rust-400)}

/* ═══ LAYOUT ═══ */
.container{max-width:1160px;margin:0 auto;padding:0 2.4rem}
.narrow{max-width:820px;margin:0 auto;padding:0 2.4rem}
.eyebrow{font-size:.7rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--rust-500);display:block;margin-bottom:.55rem}
.sh2{font-family:var(--ff-d);font-size:clamp(1.8rem,3.2vw,2.6rem);font-weight:400;line-height:1.18;letter-spacing:-.01em;color:var(--ink)}
.sh2 em{font-style:italic;color:var(--rust-500)}
.btn{display:inline-block;font-size:.88rem;font-weight:600;border-radius:8px;text-decoration:none;padding:.66rem 1.5rem;transition:background .2s,transform .15s,box-shadow .2s}
.btn.primary{background:var(--rust-500);color:#fff;box-shadow:0 4px 18px rgba(162,74,42,.28)}
.btn.primary:hover{background:var(--rust-600);transform:translateY(-2px)}
.btn.ghost{border:1.5px solid var(--line-mid);color:var(--rust-600)}
.btn.ghost:hover{background:var(--rust-50);transform:translateY(-2px)}
.cta-row{display:flex;gap:.85rem;flex-wrap:wrap}
.cta-row.center{justify-content:center}

/* ═══ HERO ═══ */
.cp-hero{padding:5.5rem 0 4.5rem;position:relative;overflow:hidden}
.cp-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 55% at 80% 10%,rgba(162,74,42,.11),transparent),radial-gradient(ellipse 45% 55% at 5% 90%,rgba(255,215,140,.18),transparent);pointer-events:none}
.cp-hero::after{content:'';position:absolute;inset:0;background-image:linear-gradient(var(--line) 1px,transparent 1px),linear-gradient(90deg,var(--line) 1px,transparent 1px);background-size:48px 48px;mask-image:radial-gradient(ellipse 75% 75% at 68% 38%,black 0%,transparent 100%);pointer-events:none}

.cp-hero__grid{display:grid;grid-template-columns:1fr 1.1fr;gap:3.5rem;align-items:center}
.cp-hero__eyebrow{display:inline-flex;align-items:center;gap:.55rem;margin-bottom:.9rem}
.eyebrow-dot{width:8px;height:8px;border-radius:50%;background:var(--rust-500);animation:ping 2.2s ease-in-out infinite}
.eyebrow-text{font-size:.7rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--rust-600)}
.cp-hero__h1{font-family:var(--ff-d);font-size:clamp(2.4rem,4.8vw,4rem);line-height:1.1;letter-spacing:-.01em;color:var(--ink);margin-bottom:1.2rem}
.cp-hero__h1 em{font-style:italic;color:var(--rust-500);position:relative}
.cp-hero__h1 em::after{content:'';position:absolute;left:0;right:0;bottom:-3px;height:2px;border-radius:2px;background:var(--rust-400);opacity:.4}
.cp-hero__lead{font-size:1.04rem;font-weight:300;color:var(--ink-soft);line-height:1.75;max-width:50ch;margin-bottom:1.9rem}

/* ─ HERO DEMO WINDOW ─ */
.cp-hero__demo{position:relative}
.demo-window{border:1.5px solid var(--line-mid);border-radius:20px;background:rgba(255,252,242,.97);box-shadow:0 28px 72px rgba(75,42,21,.13),0 4px 18px rgba(75,42,21,.06);overflow:hidden}
.demo-bar{display:flex;align-items:center;gap:.45rem;padding:.7rem 1rem;background:rgba(245,235,218,.7);border-bottom:1px solid var(--line)}
.demo-dot{width:10px;height:10px;border-radius:50%}
.demo-dot-r{background:#f06257}.demo-dot-y{background:#f5a623}.demo-dot-g{background:#57c257}
.demo-bar-title{margin-left:.4rem;font-size:.78rem;font-weight:600;color:var(--ink-soft);letter-spacing:.04em;font-family:var(--ff-m)}
.demo-bar-sub{margin-left:auto;font-size:.65rem;color:var(--ink-muted);font-family:var(--ff-m)}

.demo-body{padding:1.1rem;display:flex;flex-direction:column;gap:.85rem}

/* hero map view */
.demo-map{border-radius:12px;overflow:hidden;position:relative;height:148px;background:linear-gradient(145deg,#f0e8d8,#e8dcc8)}
.demo-map-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(162,74,42,.07) 1px,transparent 1px),linear-gradient(90deg,rgba(162,74,42,.07) 1px,transparent 1px);background-size:20px 20px}
/* roads */
.demo-road{position:absolute;border-radius:3px;background:rgba(255,252,248,.85)}
.demo-road-h1{left:0;right:0;top:42%;height:6px}
.demo-road-h2{left:0;right:0;top:72%;height:4px}
.demo-road-v1{top:0;bottom:0;left:28%;width:5px}
.demo-road-v2{top:0;bottom:0;left:68%;width:4px}
/* route line */
.demo-route{position:absolute;top:0;left:0;width:100%;height:100%;overflow:visible;pointer-events:none}
/* pins */
.demo-pin{position:absolute;display:flex;flex-direction:column;align-items:center;opacity:0}
.demo-pin.show{animation:pinBounce .7s cubic-bezier(.22,.85,.44,1) forwards}
.pin-dot{width:14px;height:14px;border-radius:50%;border:2.5px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,.25)}
.pin-leg{width:2px;height:8px;border-radius:1px}
.pin-label{font-family:var(--ff-m);font-size:.58rem;font-weight:600;margin-top:2px;white-space:nowrap;background:rgba(255,252,248,.92);padding:1px 5px;border-radius:4px;border:1px solid var(--line)}
.pin-pickup{bottom:38%;left:20%}
.pin-drop{bottom:20%;left:60%}
.pin-pickup .pin-dot{background:var(--rust-500)}
.pin-drop   .pin-dot{background:var(--green)}
.pin-pickup .pin-leg,.pin-pickup .pin-label{color:var(--rust-600)}
.pin-drop   .pin-leg,.pin-drop   .pin-label{color:var(--green)}

/* moving car marker */
.demo-car-dot{position:absolute;width:16px;height:16px;border-radius:50%;background:var(--rust-400);border:2.5px solid #fff;box-shadow:0 2px 10px rgba(162,74,42,.55);display:flex;align-items:center;justify-content:center;font-size:.6rem;opacity:0;transition:none}

/* status rows */
.demo-status-row{display:flex;align-items:center;gap:.6rem;padding:.45rem .65rem;border-radius:8px;background:#fffaef;border:1px solid rgba(162,74,42,.1)}
.demo-status-role{font-family:var(--ff-m);font-size:.64rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--rust-600);min-width:42px}
.demo-status-val{font-size:.82rem;font-weight:500;color:var(--ink);flex:1}
.demo-status-badge{font-family:var(--ff-m);font-size:.62rem;font-weight:600;border-radius:999px;padding:.14rem .5rem;flex-shrink:0}
.badge-moving{background:rgba(44,95,168,.1);color:#1a4080;border:1px solid rgba(44,95,168,.2)}
.badge-waiting{background:rgba(192,120,32,.12);color:var(--amber);border:1px solid rgba(192,120,32,.2)}
.badge-done{background:rgba(46,140,79,.1);color:#1c6535;border:1px solid rgba(46,140,79,.2)}

/* float badges */
.demo-float{position:absolute;display:flex;align-items:center;gap:.4rem;font-size:.74rem;font-weight:600;color:#5a3d2e;background:rgba(255,248,232,.95);border:1.5px solid var(--line);border-radius:999px;padding:.42rem .82rem;box-shadow:0 6px 20px rgba(75,42,21,.12);white-space:nowrap;animation:floatY 3s ease-in-out infinite}
.demo-float svg{width:13px;height:13px;flex-shrink:0}
.demo-float-1{bottom:-1rem;left:-1.8rem;animation-delay:0s}
.demo-float-2{top:1.2rem;right:-1.8rem;animation-delay:1.4s}

/* ═══ STATS ═══ */
.stats-strip{background:var(--dark-bg);display:grid;grid-template-columns:repeat(4,1fr);gap:1px;overflow:hidden}
.stat-item{text-align:center;padding:2.2rem 1rem;position:relative}
.stat-item:not(:last-child)::after{content:'';position:absolute;right:0;top:25%;bottom:25%;width:1px;background:rgba(255,255,255,.07)}
.stat-num{font-family:var(--ff-d);font-size:2.6rem;font-style:italic;color:var(--rust-300);display:block;line-height:1;margin-bottom:.35rem}
.stat-label{font-size:.72rem;font-weight:400;color:rgba(255,255,255,.38);letter-spacing:.06em;text-transform:uppercase}

/* ═══ PROBLEM ═══ */
.cp-problem{padding:4rem 0}
.cp-problem__card{display:grid;grid-template-columns:auto 1fr;gap:2.4rem;align-items:start;border:1.5px solid var(--line);border-radius:26px;padding:2.8rem 2.4rem;background:linear-gradient(148deg,rgba(255,245,228,.98),rgba(250,232,198,.9));box-shadow:0 16px 48px rgba(75,42,21,.09);opacity:0}
.cp-problem__card.in-view{animation:fadeUp .8s cubic-bezier(.22,.85,.44,1) forwards}
.cp-problem-icon{color:var(--rust-500);flex-shrink:0}
.cp-problem__text h2{font-family:var(--ff-d);font-size:clamp(1.6rem,2.8vw,2.3rem);letter-spacing:-.02em;line-height:1.2;color:var(--ink);margin-bottom:1rem}
.cp-problem__text p{color:var(--ink-soft);line-height:1.72;max-width:66ch}
.cp-problem__text p+p{margin-top:.7rem}

/* ═══ FEATURE ROWS ═══ */
.feat-section{padding:4rem 0 2rem}
.feat-row{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;padding:5rem 0;border-bottom:1px solid var(--line)}
.feat-row:last-child{border-bottom:none}
.feat-row.reverse .feat-copy{order:2}
.feat-row.reverse .feat-illu{order:1}
.feat-copy .sh2{margin-bottom:1rem}
.feat-copy p{font-size:.97rem;font-weight:300;color:var(--ink-soft);line-height:1.75;margin-bottom:1rem}
.feat-copy .bullet-list{list-style:none;display:grid;gap:.55rem}
.feat-copy .bullet-list li{position:relative;padding-left:1.1rem;font-size:.9rem;color:var(--ink-soft)}
.feat-copy .bullet-list li::before{content:'';position:absolute;left:0;top:.6em;width:6px;height:6px;border-radius:50%;background:var(--rust-400)}

/* ═══ ILLUSTRATION PANELS ═══ */
.illu-panel{border:1.5px solid var(--line-mid);border-radius:18px;background:var(--sand-50);overflow:hidden;position:relative}

/* ─ PANEL 1: Rider App ─ */
.rider-panel{padding:1.4rem;display:flex;flex-direction:column;gap:.75rem;min-height:340px}
.rp-header{display:flex;justify-content:space-between;align-items:center}
.rp-title{font-family:var(--ff-m);font-size:.72rem;font-weight:600;color:var(--ink)}
.rp-live{display:flex;align-items:center;gap:.35rem;font-family:var(--ff-m);font-size:.65rem;color:var(--green)}
.rp-live-dot{width:5px;height:5px;border-radius:50%;background:var(--green);animation:ping 2s ease-in-out infinite}

.rp-map{border-radius:12px;overflow:hidden;position:relative;height:130px;background:linear-gradient(145deg,#f2ece0,#ebe0cc);flex-shrink:0}
.rp-map-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(162,74,42,.06) 1px,transparent 1px),linear-gradient(90deg,rgba(162,74,42,.06) 1px,transparent 1px);background-size:18px 18px}
.rp-road-h{position:absolute;left:0;right:0;background:rgba(255,252,248,.8);border-radius:3px}
.rp-road-v{position:absolute;top:0;bottom:0;background:rgba(255,252,248,.8);border-radius:3px}
.rp-pin{position:absolute;display:flex;flex-direction:column;align-items:center}
.rp-pin-dot{width:12px;height:12px;border-radius:50%;border:2px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,.2)}
.rp-pin-a .rp-pin-dot{background:var(--rust-500)}
.rp-pin-b .rp-pin-dot{background:var(--green)}
.rp-car{position:absolute;width:14px;height:14px;border-radius:50%;background:var(--rust-400);border:2.5px solid #fff;box-shadow:0 2px 8px rgba(162,74,42,.5);opacity:0;transition:left .8s cubic-bezier(.4,0,.2,1),top .8s cubic-bezier(.4,0,.2,1)}

.rp-ride-card{display:flex;align-items:center;gap:.7rem;padding:.6rem .8rem;border-radius:10px;background:#fff;border:1px solid var(--line);opacity:0}
