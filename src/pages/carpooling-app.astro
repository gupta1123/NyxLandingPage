<!-- ═════════════ SCRIPTS ═════════════ -->
<script is:inline>
/* ── NAV ── */
const nav = document.getElementById('mainnav');
window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', scrollY > 40), { passive: true });

/* ── INTERSECTION OBSERVER ── */
const seen = new Set();
const io = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (!e.isIntersecting || seen.has(e.target)) return;
    seen.add(e.target);
    e.target.classList.add('in-view');
    const id = e.target.id;
    if (id === 'riderPanel')     triggerRiderPanel();
    if (id === 'driverPanel')    triggerDriverPanel();
    if (id === 'adminPanel')     triggerAdminPanel();
    if (id === 'lifecyclePanel') triggerLifecyclePanel();
    if (id === 'problemCard')    e.target.classList.add('in-view');
    if (id === 'ctaCard')        e.target.classList.add('in-view');
    io.unobserve(e.target);
  });
}, { threshold: .15, rootMargin: '0px 0px -40px 0px' });

document.querySelectorAll(
  '.reveal-up, .reveal-fade, .cp-step, .cp-audience__item, #riderPanel, #driverPanel, #adminPanel, #lifecyclePanel, #problemCard, #ctaCard'
).forEach(el => io.observe(el));

/* ── COUNT-UP ── */
const cio = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    const el = e.target;
    const target = +el.dataset.count;
    let v = 0;
    const step = Math.ceil(target / 40);
    const t = setInterval(() => {
      v = Math.min(v + step, target);
      el.textContent = v;
      if (v >= target) clearInterval(t);
    }, 35);
    cio.unobserve(el);
  });
}, { threshold: .5 });
document.querySelectorAll('[data-count]').forEach(el => cio.observe(el));

/* ── HERO ANIMATION ── */
(function heroAnim() {
  const car = document.getElementById('heroCarDot');
  if (!car) return;
  const positions = [
    { l: '18%', t: '36%' },
    { l: '30%', t: '36%' },
    { l: '42%', t: '36%' },
    { l: '55%', t: '36%' },
    { l: '66%', t: '36%' }
  ];
  let idx = 0;
  car.style.opacity = '1';
  car.style.transition = 'left .9s cubic-bezier(.4,0,.2,1), top .9s cubic-bezier(.4,0,.2,1)';

  const riderStatus  = document.getElementById('heroRiderStatus');
  const riderBadge   = document.getElementById('heroRiderBadge');
  const driverStatus = document.getElementById('heroDriverStatus');
  const driverBadge  = document.getElementById('heroDriverBadge');
  const adminStatus  = document.getElementById('heroAdminStatus');

  setInterval(() => {
    idx = (idx + 1) % positions.length;
    car.style.left = positions[idx].l;
    car.style.top  = positions[idx].t;

    if (idx === 2 && riderStatus) {
      riderStatus.textContent = 'Priya — driver arriving';
      if (riderBadge) { riderBadge.textContent = 'Arriving'; riderBadge.className = 'demo-status-badge badge-moving'; }
      if (driverStatus) driverStatus.textContent = 'Rahul — at pickup point';
      if (driverBadge)  { driverBadge.textContent = 'Arrived'; driverBadge.className = 'demo-status-badge badge-done'; }
    }
    if (idx === 4 && riderStatus) {
      riderStatus.textContent = 'Priya — in transit';
      if (riderBadge)  { riderBadge.textContent = 'In trip'; riderBadge.className = 'demo-status-badge badge-done'; }
      if (driverStatus) driverStatus.textContent = 'Rahul — en route to Whitefield';
      if (driverBadge)  { driverBadge.textContent = 'En route'; driverBadge.className = 'demo-status-badge badge-moving'; }
      if (adminStatus)  adminStatus.textContent = 'Route 7 — all riders aboard, ETA 08:05';
    }
    if (idx === 0 && riderStatus) {
      riderStatus.textContent = 'Priya — waiting for pickup';
      if (riderBadge)  { riderBadge.textContent = 'Waiting'; riderBadge.className = 'demo-status-badge badge-waiting'; }
      if (driverStatus) driverStatus.textContent = 'Rahul — 3 min away';
      if (driverBadge)  { driverBadge.textContent = 'En route'; driverBadge.className = 'demo-status-badge badge-moving'; }
      if (adminStatus)  adminStatus.textContent = 'Route 7 — 4 of 4 pickups confirmed';
    }
  }, 1800);
})();

/* ── PANEL 1: RIDER ── */
function triggerRiderPanel() {
  const car    = document.getElementById('riderCar');
  const card   = document.getElementById('riderCard');
  const notif  = document.getElementById('riderNotif');
  const eta    = document.getElementById('riderEta');

  if (card) setTimeout(() => card.classList.add('show'), 200);

  if (car) {
    car.style.transition = 'left 1.1s cubic-bezier(.4,0,.2,1), top 1.1s cubic-bezier(.4,0,.2,1)';
    car.style.opacity    = '1';
    const stops = [
      { l:'22%', t:'42%' }, { l:'30%', t:'42%' }, { l:'38%', t:'18%' },
      { l:'52%', t:'18%' }, { l:'62%', t:'42%' }, { l:'72%', t:'42%' }
    ];
    let si = 0;
    const etaVals = ['3 min', '2 min', '1 min', 'Arriving', '0 min', '🏁'];
    const iv = setInterval(() => {
      si++;
      if (si >= stops.length) { clearInterval(iv); return; }
      car.style.left = stops[si].l;
      car.style.top  = stops[si].t;
      if (eta && etaVals[si]) eta.textContent = etaVals[si];
    }, 1200);
  }

  if (notif) setTimeout(() => notif.classList.add('show'), 6500);
}

/* ── PANEL 2: DRIVER ── */
function triggerDriverPanel() {
  const tripCard   = document.getElementById('driverTripCard');
  const drrs       = ['drr1','drr2','drr3','drr4'];
  const action     = document.getElementById('driverAction');
  const meeraSt    = document.getElementById('drrMeeraSt');

  if (tripCard) setTimeout(() => tripCard.classList.add('show'), 100);

  drrs.forEach((id, i) => {
    const el = document.getElementById(id);
    if (el) setTimeout(() => el.classList.add('show'), 350 + i * 150);
  });

  if (action) setTimeout(() => action.classList.add('show'), 1200);

  // animate Meera status → boarded
  if (meeraSt) {
    setTimeout(() => {
      meeraSt.textContent = 'Boarded';
      meeraSt.className   = 'dp-rider-st st-boarded';
    }, 3500);
  }
}

/* ── PANEL 3: ADMIN ── */
function triggerAdminPanel() {
  const metrics = ['admM1','admM2','admM3'];
  const nums    = ['admN1','admN2','admN3'];
  const targets = [12, 47, 94];
  const alerts  = ['admAlert1','admAlert2','admAlert3'];

  // show metrics with count-up
  metrics.forEach((id, i) => {
    const mEl = document.getElementById(id);
    const nEl = document.getElementById(nums[i]);
    if (!mEl || !nEl) return;
    setTimeout(() => {
      mEl.classList.add('show');
      let v = 0;
      const step = Math.ceil(targets[i] / 30);
      const t = setInterval(() => {
        v = Math.min(v + step, targets[i]);
        nEl.textContent = v;
        if (v >= targets[i]) clearInterval(t);
      }, 40);
    }, i * 120);
  });

  // animate car positions on mini map
  const carMoves = [
    { id:'admCar1', positions:[{ l:'15%',t:'38%' },{ l:'25%',t:'38%' },{ l:'35%',t:'38%' },{ l:'42%',t:'38%' }] },
    { id:'admCar2', positions:[{ l:'42%',t:'64%' },{ l:'52%',t:'64%' },{ l:'60%',t:'38%' }] },
    { id:'admCar3', positions:[{ l:'58%',t:'38%' },{ l:'66%',t:'38%' },{ l:'76%',t:'38%' }] },
  ];

  carMoves.forEach(({ id, positions }) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.style.transition = 'left .9s cubic-bezier(.4,0,.2,1), top .9s cubic-bezier(.4,0,.2,1)';
    positions.forEach((pos, i) => {
      setTimeout(() => { el.style.left = pos.l; el.style.top = pos.t; }, 800 + i * 1200);
    });
  });

  // slide in alerts
  alerts.forEach((id, i) => {
    const el = document.getElementById(id);
    if (el) setTimeout(() => el.classList.add('show'), 400 + i * 250);
  });
}

/* ── PANEL 4: LIFECYCLE ── */
function triggerLifecyclePanel() {
  const steps   = ['lc1','lc2','lc3','lc4','lc5'];
  const summary = document.getElementById('lcSummary');
  const hl1     = document.getElementById('lcHl1');
  const hl2     = document.getElementById('lcHl2');

  steps.forEach((id, i) => {
    const el = document.getElementById(id);
    if (el) setTimeout(() => el.classList.add('show'), 150 + i * 200);
  });

  if (summary) setTimeout(() => {
    summary.classList.add('show');
    setTimeout(() => { hl1?.classList.add('lit'); }, 400);
    setTimeout(() => { hl2?.classList.add('lit'); }, 700);
  }, 1500);
}

/* ── LIVE CLOCK ── */
(function liveClock() {
  const el = document.getElementById('admTime');
  if (!el) return;
  const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  function update() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2,'0');
    const m = String(now.getMinutes()).padStart(2,'0');
    el.textContent = `${h}:${m} · ${days[now.getDay()]}`;
  }
  update();
  setInterval(update, 30000);
})();
</script>

