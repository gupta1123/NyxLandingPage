---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Carpooling App | Nyx Solutions"
  description="A full mobility stack for rider bookings, driver execution, and admin-level coordination. Carpooling software built for simplicity and operational control."
>

<!-- ═════════════ NAV ═════════════ -->
<nav id="mainnav">
  <div class="nav-left">
    <a class="nav-back" href="/products" aria-label="Back to products">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    </a>
    <span class="nav-logo">Nyx Solutions</span>
  </div>
  <ul class="nav-links">
    <li><a href="#rider">Rider App</a></li>
    <li><a href="#driver">Driver App</a></li>
    <li><a href="#admin">Admin Console</a></li>
    <li><a href="#lifecycle">Trip Lifecycle</a></li>
  </ul>
  <a class="nav-cta" href="/contact">Contact Us</a>
</nav>

<!-- ═════════════ TICKER ═════════════ -->
<div class="ticker-wrap" aria-hidden="true">
  <div class="ticker">
    <span class="ticker-item">Rider booking</span>
    <span class="ticker-item">Driver dispatch</span>
    <span class="ticker-item">Live trip tracking</span>
    <span class="ticker-item">Route management</span>
    <span class="ticker-item">Fleet visibility</span>
    <span class="ticker-item">Admin operations</span>
    <span class="ticker-item">Boarding control</span>
    <span class="ticker-item">Service metrics</span>
    <span class="ticker-item">Multi-role platform</span>
    <span class="ticker-item">Rider booking</span>
    <span class="ticker-item">Driver dispatch</span>
    <span class="ticker-item">Live trip tracking</span>
    <span class="ticker-item">Route management</span>
    <span class="ticker-item">Fleet visibility</span>
    <span class="ticker-item">Admin operations</span>
    <span class="ticker-item">Boarding control</span>
    <span class="ticker-item">Service metrics</span>
    <span class="ticker-item">Multi-role platform</span>
  </div>
</div>

<!-- ═════════════ HERO ═════════════ -->
<section class="cp-hero">
  <div class="container">
    <div class="cp-hero__grid">

      <div>
        <div class="cp-hero__eyebrow reveal-up">
          <span class="eyebrow-dot"></span>
          <span class="eyebrow-text">Mobility Product</span>
        </div>
        <h1 class="cp-hero__h1 reveal-up" style="animation-delay:.1s">
          Carpooling software with <em>rider simplicity</em> and operational control.
        </h1>
        <p class="cp-hero__lead reveal-up" style="animation-delay:.2s">
          A full mobility stack for rider bookings, driver execution, and admin-level coordination — built so every role has exactly what they need, without the chaos of disconnected tools.
        </p>
        <div class="cta-row reveal-up" style="animation-delay:.3s">
          <a class="btn primary" href="/contact">Contact Us</a>
          <a class="btn ghost" href="#rider">See Platform</a>
        </div>
      </div>

      <!-- HERO DEMO WINDOW -->
      <div class="cp-hero__demo reveal-fade" style="animation-delay:.45s">
        <div class="demo-window">
          <div class="demo-bar">
            <span class="demo-dot demo-dot-r"></span>
            <span class="demo-dot demo-dot-y"></span>
            <span class="demo-dot demo-dot-g"></span>
            <span class="demo-bar-title">Carpooling — Operations View</span>
            <span class="demo-bar-sub" id="heroLiveTime">Live</span>
          </div>
          <div class="demo-body">
            <!-- mini map -->
            <div class="demo-map" id="heroMap">
              <div class="demo-map-grid"></div>
              <div class="demo-road demo-road-h1"></div>
              <div class="demo-road demo-road-h2"></div>
              <div class="demo-road demo-road-v1"></div>
              <div class="demo-road demo-road-v2"></div>
              <svg class="demo-route" id="heroRouteSvg" viewBox="0 0 380 148" preserveAspectRatio="none">
                <path id="heroRoutePath" d="M 75 108 Q 100 108 106 62 Q 112 18 145 18 Q 200 18 200 62 Q 200 108 260 108" fill="none" stroke="var(--rust-300)" stroke-width="2.5" stroke-dasharray="5 3" opacity=".6"/>
              </svg>
              <div class="demo-pin pin-pickup show" style="animation-delay:.8s">
                <div class="pin-dot" style="background:var(--rust-500)"></div>
                <div class="pin-leg" style="background:var(--rust-400);width:2px;height:8px;border-radius:1px"></div>
                <div class="pin-label" style="color:var(--rust-600)">Pickup</div>
              </div>
              <div class="demo-pin pin-drop show" style="animation-delay:1s">
                <div class="pin-dot" style="background:var(--green)"></div>
                <div class="pin-leg" style="background:var(--green);width:2px;height:8px;border-radius:1px;opacity:.6"></div>
                <div class="pin-label" style="color:var(--green)">Drop-off</div>
              </div>
              <div class="demo-car-dot" id="heroCarDot" style="top:36%;left:18%">🚗</div>
            </div>
            <!-- status rows -->
            <div class="demo-status-row">
              <span class="demo-status-role">Rider</span>
              <span class="demo-status-val" id="heroRiderStatus">Priya — waiting for pickup</span>
              <span class="demo-status-badge badge-waiting" id="heroRiderBadge">Waiting</span>
            </div>
            <div class="demo-status-row">
              <span class="demo-status-role">Driver</span>
              <span class="demo-status-val" id="heroDriverStatus">Rahul — 3 min away</span>
              <span class="demo-status-badge badge-moving" id="heroDriverBadge">En route</span>
            </div>
            <div class="demo-status-row">
              <span class="demo-status-role">Admin</span>
              <span class="demo-status-val" id="heroAdminStatus">Route 7 — 4 of 4 pickups confirmed</span>
              <span class="demo-status-badge badge-done" id="heroAdminBadge">On track</span>
            </div>
          </div>
        </div>

        <div class="demo-float demo-float-1 reveal-fade" style="animation-delay:.9s">
          <svg viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3"/><path d="M5 8l2.5 2.5L11 5.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Multi-role platform
        </div>
        <div class="demo-float demo-float-2 reveal-fade" style="animation-delay:1.1s">
          <svg viewBox="0 0 16 16" fill="none"><path d="M8 2l1.4 2.9L13 5.5l-2.5 2.4.6 3.4L8 9.7l-3.1 1.6.6-3.4L3 5.5l3.6-.6L8 2z" stroke="currentColor" stroke-width="1.2" fill="currentColor" fill-opacity=".12"/></svg>
          Ops-first design
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ═════════════ STATS ═════════════ -->
<div class="stats-strip">
  <div class="stat-item"><span class="stat-num" data-count="3">0</span><span class="stat-label">connected roles in one system</span></div>
  <div class="stat-item"><span class="stat-num" data-count="100">0</span><span class="stat-label">% trip lifecycle visibility</span></div>
  <div class="stat-item"><span class="stat-num" data-count="6">0</span><span class="stat-label">core modules out of the box</span></div>
  <div class="stat-item"><span class="stat-num" data-count="40">0</span><span class="stat-label">% reduction in coordinator overhead</span></div>
</div>

<!-- ═════════════ PROBLEM ═════════════ -->
<section class="cp-problem">
  <div class="narrow">
    <div class="cp-problem__card" id="problemCard">
      <div class="cp-problem-icon">
        <svg width="52" height="52" viewBox="0 0 48 48" fill="none">
          <circle cx="24" cy="24" r="18" stroke="currentColor" stroke-width="1.8" stroke-dasharray="5 3"/>
          <path d="M12 24h6l4-8 4 14 4-10 3 4h3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="36" cy="36" r="7" fill="var(--rust-50)" stroke="currentColor" stroke-width="1.8"/>
          <path d="M36 33v3h2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="cp-problem__text">
        <h2>Most carpooling operations fail not because of bad drivers — but because the three roles never had a single system to work from.</h2>
        <p>Riders chase updates over WhatsApp. Drivers work off printed sheets. Admins rely on phone calls to know if a route is running. The product and the operation are disconnected.</p>
        <p>Carpooling App is built to close that gap — one platform where riders book, drivers execute, and operations teams see everything.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═════════════ FEATURE ROWS ═════════════ -->
<section class="feat-section">
  <div class="container">

    <!-- ── ROW 1: RIDER APP ── -->
    <div class="feat-row" id="rider">
      <div class="feat-copy reveal-up">
        <span class="eyebrow">Rider app experience</span>
        <h2 class="sh2">Search, book, track — <em>no friction between request and ride</em></h2>
        <p>Riders can discover available rides, request seats, track their driver in real time, and manage their bookings without calling anyone or checking a spreadsheet.</p>
        <ul class="bullet-list">
          <li>Search and request available rides by route or time</li>
          <li>Track pickup and trip status in real time on a live map</li>
          <li>Manage bookings, cancellations, and travel history</li>
          <li>Receive route updates, delay alerts, and driver ETA</li>
        </ul>
      </div>
      <div class="feat-illu reveal-fade" style="animation-delay:.1s">
        <div class="illu-panel rider-panel" id="riderPanel">
          <div class="rp-header">
            <div class="rp-title">Rider App — Priya S.</div>
            <div class="rp-live"><div class="rp-live-dot"></div>Trip active</div>
          </div>
          <!-- map -->
          <div class="rp-map" id="riderMap">
            <div class="rp-map-grid"></div>
            <div class="rp-road-h" style="top:38%;height:5px;left:0;right:0"></div>
            <div class="rp-road-h" style="top:68%;height:4px;left:0;right:0"></div>
            <div class="rp-road-v" style="left:25%;width:4px;top:0;bottom:0"></div>
            <div class="rp-road-v" style="left:65%;width:4px;top:0;bottom:0"></div>
            <svg style="position:absolute;inset:0;width:100%;height:100%;overflow:visible;pointer-events:none" viewBox="0 0 300 130" preserveAspectRatio="none">
              <path d="M 60 105 Q 75 105 75 55 Q 75 20 120 20 Q 180 20 195 55 Q 195 105 250 105" fill="none" stroke="var(--rust-300)" stroke-width="2.5" stroke-dasharray="5 3" opacity=".65" id="riderRoutePathSvg"/>
            </svg>
            <!-- pickup pin -->
            <div class="rp-pin rp-pin-a" style="bottom:8px;left:14%">
              <div class="rp-pin-dot"></div>
            </div>
            <!-- drop pin -->
            <div class="rp-pin rp-pin-b" style="bottom:8px;left:72%">
              <div class="rp-pin-dot"></div>
            </div>
            <!-- driver car -->
            <div class="rp-car" id="riderCar" style="top:42%;left:22%;opacity:1">🚗</div>
          </div>
          <!-- ride card -->
          <div class="rp-ride-card" id="riderCard">
            <div class="rp-ride-avatar">R</div>
            <div class="rp-ride-info">
              <div class="rp-ride-name">Rahul M. — Toyota Innova · KA05</div>
              <div class="rp-ride-route">Koramangala → Whitefield · Route 7</div>
            </div>
            <span class="rp-ride-eta" id="riderEta">3 min</span>
          </div>
          <!-- notification -->
          <div class="rp-notif" id="riderNotif">
            <div class="rp-notif-icon">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3"/><path d="M5 8l2.5 2.5L11 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span class="rp-notif-text">Driver arrived — please proceed to pickup point</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ── ROW 2: DRIVER APP ── -->
    <div class="feat-row reverse" id="driver">
      <div class="feat-copy reveal-up">
        <span class="eyebrow">Driver app experience</span>
        <h2 class="sh2">Trips, riders, and route — <em>all in one driver view</em></h2>
        <p>Drivers get a clean view of their assigned trips, the riders on each run, boarding confirmations, and route progress. No calls to dispatch. No paper sheets.</p>
        <ul class="bullet-list">
          <li>Accept and manage assigned trips from dispatch</li>
          <li>See all riders on the run with stop and status details</li>
          <li>Confirm boarding and drop-off for each rider</li>
          <li>Stay aligned with operations through live status updates</li>
        </ul>
      </div>
      <div class="feat-illu reveal-fade" style="animation-delay:.1s">
        <div class="illu-panel driver-panel" id="driverPanel">
          <div class="dp-header">
            <div class="dp-title">Driver App — Rahul M.</div>
            <div class="dp-shift"><div class="dp-shift-dot"></div>On shift</div>
          </div>
          <!-- trip card -->
          <div class="dp-trip-card" id="driverTripCard">
            <div class="dp-trip-head">
              <span class="dp-trip-id">Trip #T-0047 · Route 7</span>
              <span class="dp-trip-badge badge-moving">Active</span>
            </div>
            <div class="dp-route-line">
              <div class="dp-route-dots">
                <div class="dp-rdot dp-rdot-a"></div>
                <div class="dp-route-vline"></div>
                <div class="dp-rdot dp-rdot-b"></div>
              </div>
              <div class="dp-route-text">
                <div class="dp-route-pt">Koramangala 5th Block <span>07:14 AM</span></div>
                <div class="dp-route-pt">Whitefield Tech Park <span>08:05 AM</span></div>
              </div>
            </div>
          </div>
          <!-- riders list -->
          <div class="dp-riders" id="driverRiders">
            <div class="dp-rider-row" id="drr1">
              <div class="dp-rider-av">P</div>
              <span class="dp-rider-name">Priya S.</span>
              <span class="dp-rider-stop">Stop 2</span>
              <span class="dp-rider-st st-boarded">Boarded</span>
            </div>
            <div class="dp-rider-row" id="drr2">
              <div class="dp-rider-av">A</div>
              <span class="dp-rider-name">Arjun K.</span>
              <span class="dp-rider-stop">Stop 2</span>
              <span class="dp-rider-st st-boarded">Boarded</span>
            </div>
            <div class="dp-rider-row" id="drr3">
              <div class="dp-rider-av">M</div>
              <span class="dp-rider-name">Meera R.</span>
              <span class="dp-rider-stop">Stop 3</span>
              <span class="dp-rider-st st-waiting" id="drrMeeraSt">Waiting</span>
            </div>
            <div class="dp-rider-row" id="drr4">
              <div class="dp-rider-av">S</div>
              <span class="dp-rider-name">Suresh P.</span>
              <span class="dp-rider-stop">Stop 3</span>
              <span class="dp-rider-st st-pending">Pending</span>
            </div>
          </div>
          <!-- action buttons -->
          <div class="dp-action" id="driverAction">
            <div class="dp-btn dp-btn-primary">Confirm Boarding</div>
            <div class="dp-btn dp-btn-ghost">Update Status</div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── ROW 3: ADMIN CONSOLE ── -->
    <div class="feat-row" id="admin">
      <div class="feat-copy reveal-up">
        <span class="eyebrow">Admin operations console</span>
        <h2 class="sh2">Full fleet visibility — <em>without calling a single driver</em></h2>
        <p>Operations teams get a live web dashboard showing active trips, route performance, fleet positions, and service alerts. Manage issues before they become complaints.</p>
        <ul class="bullet-list">
          <li>Monitor all active trips and fleet positions in real time</li>
          <li>Manage users, drivers, vehicles, and route configurations</li>
          <li>Handle escalations, exceptions, and support tickets</li>
          <li>Review service KPIs, utilization, and operational metrics</li>
        </ul>
      </div>
      <div class="feat-illu reveal-fade" style="animation-delay:.1s">
        <div class="illu-panel admin-panel" id="adminPanel">
          <div class="adm-header">
            <div class="adm-title">Admin Console — Operations</div>
            <div class="adm-time" id="admTime">07:22 AM · Monday</div>
          </div>
          <!-- metrics -->
          <div class="adm-metrics">
            <div class="adm-metric" id="admM1">
              <span class="adm-metric-num" id="admN1">0</span>
              <span class="adm-metric-label">Active Trips</span>
            </div>
            <div class="adm-metric" id="admM2">
              <span class="adm-metric-num" id="admN2">0</span>
              <span class="adm-metric-label">Riders Today</span>
            </div>
            <div class="adm-metric" id="admM3">
              <span class="adm-metric-num" id="admN3">0</span>
              <span class="adm-metric-label">On-Time %</span>
            </div>
          </div>
          <!-- mini map -->
          <div class="adm-map" id="adminMap">
            <div class="adm-map-grid"></div>
            <div class="adm-road-h" style="top:40%;height:4px;left:0;right:0"></div>
            <div class="adm-road-h" style="top:68%;height:3px;left:0;right:0"></div>
            <div class="adm-road-v" style="left:30%;width:3px;top:0;bottom:0"></div>
            <div class="adm-road-v" style="left:65%;width:3px;top:0;bottom:0"></div>
            <!-- route dots -->
            <div class="adm-route-dot" style="top:28%;left:10%;background:var(--rust-400)"></div>
            <div class="adm-route-dot" style="top:28%;left:38%;background:var(--rust-300)"></div>
            <div class="adm-route-dot" style="top:28%;left:62%;background:var(--rust-300)"></div>
            <div class="adm-route-dot" style="top:28%;left:80%;background:var(--green)"></div>
            <!-- cars -->
            <div class="adm-car" id="admCar1" style="top:38%;left:15%;background:var(--rust-500);opacity:1">🚗</div>
            <div class="adm-car" id="admCar2" style="top:64%;left:42%;background:var(--amber);opacity:1">🚗</div>
            <div class="adm-car" id="admCar3" style="top:38%;left:58%;background:var(--green);opacity:1">🚗</div>
          </div>
          <!-- live alerts -->
          <div class="adm-alerts">
            <div class="adm-alert alert-ok" id="admAlert1">
              <div class="adm-alert-dot"></div>
              <span class="adm-alert-text">Route 7 — all pickups confirmed, ETA on track</span>
              <span class="adm-alert-time">07:18</span>
            </div>
            <div class="adm-alert alert-warn" id="admAlert2">
              <div class="adm-alert-dot"></div>
              <span class="adm-alert-text">Route 3 — driver reporting 8-min delay at Stop 2</span>
              <span class="adm-alert-time">07:20</span>
            </div>
            <div class="adm-alert alert-info" id="admAlert3">
              <div class="adm-alert-dot"></div>
              <span class="adm-alert-text">Route 12 — 3 new seat requests pending approval</span>
              <span class="adm-alert-time">07:22</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── ROW 4: TRIP LIFECYCLE ── -->
    <div class="feat-row reverse" id="lifecycle">
      <div class="feat-copy reveal-up">
        <span class="eyebrow">Trip lifecycle management</span>
        <h2 class="sh2">Every trip tracked — from <em>booking to completion</em></h2>
        <p>Each trip moves through a defined lifecycle with clear status transitions. Operations teams always know where every trip stands — without chasing updates.</p>
        <ul class="bullet-list">
          <li>Booking confirmed, assigned, and dispatched automatically</li>
          <li>Live status updates at each lifecycle stage</li>
          <li>Driver arrival, boarding, in-transit, and drop-off tracked</li>
          <li>Completion logged with time, rider, and route on record</li>
        </ul>
      </div>
      <div class="feat-illu reveal-fade" style="animation-delay:.1s">
        <div class="illu-panel lifecycle-panel" id="lifecyclePanel">
          <div class="lc-header">Trip #T-0047 · Route 7 · Lifecycle</div>
          <div class="lc-step complete lc-step-idle" id="lc1" style="opacity:0">
            <div class="lc-step-icon">✅</div>
            <div class="lc-step-text">
              <div class="lc-step-name">Booking confirmed</div>
              <div class="lc-step-detail">Priya S. · 3 riders · Route 7</div>
            </div>
            <span class="lc-step-time">06:45</span>
          </div>
          <div class="lc-conn"><div class="lc-conn-line"></div></div>
          <div class="lc-step complete lc-step-idle" id="lc2" style="opacity:0">
            <div class="lc-step-icon">🔧</div>
            <div class="lc-step-text">
              <div class="lc-step-name">Driver assigned &amp; dispatched</div>
              <div class="lc-step-detail">Rahul M. · Toyota Innova KA05</div>
            </div>
            <span class="lc-step-time">07:00</span>
          </div>
          <div class="lc-conn"><div class="lc-conn-line"></div></div>
          <div class="lc-step active lc-step-idle" id="lc3" style="opacity:0">
            <div class="lc-step-icon">📍</div>
            <div class="lc-step-text">
              <div class="lc-step-name">Pickup in progress</div>
              <div class="lc-step-detail">Stop 2 · 2 of 4 riders boarded</div>
            </div>
            <span class="lc-step-time">07:22</span>
          </div>
          <div class="lc-conn"><div class="lc-conn-line"></div></div>
          <div class="lc-step lc-step-idle" id="lc4" style="opacity:0">
            <div class="lc-step-icon" style="font-size:.8rem">🚗</div>
            <div class="lc-step-text">
              <div class="lc-step-name">In transit</div>
              <div class="lc-step-detail">All riders aboard · en route</div>
            </div>
            <span class="lc-step-time lc-step-idle" style="color:var(--ink-muted)">Pending</span>
          </div>
          <div class="lc-conn"><div class="lc-conn-line"></div></div>
          <div class="lc-step lc-step-idle" id="lc5" style="opacity:0">
            <div class="lc-step-icon">🏁</div>
            <div class="lc-step-text">
              <div class="lc-step-name">Trip completed</div>
              <div class="lc-step-detail">Drop-off confirmed · record closed</div>
            </div>
            <span class="lc-step-time" style="color:var(--ink-muted)">—</span>
          </div>
          <div class="lc-summary" id="lcSummary">
            <div class="lc-summary-label">Ops note</div>
            <div class="lc-summary-text">Admin confirmed all stops on schedule. <span class="hl" id="lcHl1">4 of 4 riders accounted for.</span> ETA to destination: <span class="hl" id="lcHl2">08:05 AM</span>, on track.</div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ═════════════ HOW IT WORKS ═════════════ -->
<section class="cp-how">
  <div class="container">
    <div class="cp-how__header">
      <span class="eyebrow">How it works</span>
      <h2 class="sh2">From rider request to <em>completed trip</em> — coordinated at every step</h2>
    </div>
    <div class="cp-how__steps">
      <div class="cp-step">
        <div class="cp-step__number">01</div>
        <div class="cp-step__connector"></div>
        <div class="cp-step__card">
          <h3>Rider books a seat</h3>
